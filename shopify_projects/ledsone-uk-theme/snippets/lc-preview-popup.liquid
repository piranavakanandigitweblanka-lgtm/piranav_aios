<div id="lc-preview-popup" style="display:none; position:fixed; top:0; left:0; 
width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:99999; 
align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:12px; padding:32px; 
  max-width:480px; width:90%; text-align:center; 
  box-shadow:0 20px 60px rgba(0,0,0,0.3);">
    <h2 style="margin:0 0 8px; font-size:20px;">✅ Added to Cart!</h2>
    <p style="margin:0 0 20px; color:#666;">Here's your custom design preview</p>
    <img id="lc-popup-img" src="" alt="Your Design" style="width:100%; 
    max-height:300px; object-fit:contain; border-radius:8px; 
    border:1px solid #eee; margin-bottom:20px;" />
    <div style="display:flex; gap:12px; justify-content:center;">
      <button onclick="document.getElementById('lc-preview-popup').style.display='none'" 
      style="padding:12px 24px; border:2px solid #333; background:#fff; 
      border-radius:8px; cursor:pointer; font-size:14px;">
        Continue Shopping
      </button>
      <button id="lc-popup-cart-btn" 
      style="padding:12px 24px; background:#333; color:#fff; border:none; 
      border-radius:8px; cursor:pointer; font-size:14px;">
        View Cart
      </button>
    </div>
  </div>
</div>

<script>
function showLcPreviewPopup(previewUrl, cartUrl) {
  var popup = document.getElementById('lc-preview-popup');
  var img = document.getElementById('lc-popup-img');
  var cartBtn = document.getElementById('lc-popup-cart-btn');
  
  img.src = previewUrl;
  popup.style.display = 'flex';
  
  cartBtn.onclick = function() {
    popup.style.display = 'none';
    window.location.href = cartUrl;
  };
  
  popup.addEventListener('click', function(e) {
    if (e.target === popup) {
      popup.style.display = 'none';
    }
  });
}
</script>