  const noticeElement = document.getElementById('variant-length-notice');
  // Check selected variant and toggle notice visibility
  function updateNoticeVisibility() {
    let currentVariantId = null;
    // Method 1: Variant selector dropdown
    const variantSelect = document.querySelector('select[name="id"]');
    if (variantSelect && variantSelect.value) {
      currentVariantId = parseInt(variantSelect.value);
    }
    // Method 2: Hidden variant input
    if (!currentVariantId) {
      const variantInput = document.querySelector('input[name="id"]');
      if (variantInput && variantInput.value) {
        currentVariantId = parseInt(variantInput.value);
      }
    }
    // Method 3: URL query parameter
    if (!currentVariantId) {
      const urlParams = new URLSearchParams(window.location.search);
      const variantParam = urlParams.get('variant');
      if (variantParam) {
        currentVariantId = parseInt(variantParam);
      }
    }
    console.log('Current variant ID:', currentVariantId);
    console.log('Should show notice:', CABLE_LENGTH_VARIANTS.includes(currentVariantId));
    // Show notice only for qualifying variants
    if (currentVariantId && CABLE_LENGTH_VARIANTS.includes(currentVariantId)) {
      console.log('✓ Displaying notice for variant:', currentVariantId);
      if (noticeElement) {
        noticeElement.style.display = 'block';
      }
    } else {
      console.log('✗ Hiding notice');
      if (noticeElement) {
        noticeElement.style.display = 'none';
      }
    }
  }
  // Initialize on page load
  setTimeout(updateNoticeVisibility, 100);
  // Listen for variant selector changes
  document.addEventListener('change', function(e) {
    if (e.target.name === 'id' || e.target.closest('[name="id"]')) {
      console.log('Variant selector changed');
      setTimeout(updateNoticeVisibility, 50);
    }
  });
  // Listen for variant option changes (radio/select)
  document.addEventListener('change', function(e) {
    if (e.target.matches('input[type="radio"][name*="option"]') || 
        e.target.matches('select[name*="option"]')) {
      console.log('Variant option changed');
      setTimeout(updateNoticeVisibility, 150);
    }
  });
  // Monitor URL changes for themes that update URL on variant selection
  let previousUrl = location.href;
  new MutationObserver(() => {
    const currentUrl = location.href;
    if (currentUrl !== previousUrl) {
      previousUrl = currentUrl;
      console.log('URL changed');
      setTimeout(updateNoticeVisibility, 100);
    }
  }).observe(document, {subtree: true, childList: true});
})();
