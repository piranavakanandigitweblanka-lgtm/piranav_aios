  var DISCOUNT_CODE = "B2P10";

  // ─── Elements ────────────────────────────────────────────────────────────────
  var pop1 = document.getElementById("spicely-pop1");
  var pop2 = document.getElementById("spicely-pop2");
  var timers = { pop1: null, pop2: null };
  var previousCount = 0;

  // ─── Toast open/close ────────────────────────────────────────────────────────
  function openToast(popup, key) {
    var otherPopup = key === 'pop1' ? pop2 : pop1;
    var otherKey   = key === 'pop1' ? 'pop2' : 'pop1';
    closeToast(otherPopup, otherKey);

    popup.classList.add("is-open");
    clearTimeout(timers[key]);
    timers[key] = setTimeout(function () {
      closeToast(popup, key);
    }, 6000);
  }

  function closeToast(popup, key) {
    popup.classList.remove("is-open");
    clearTimeout(timers[key]);
  }

  // Close buttons
  pop1.querySelector(".toast-close").addEventListener("click", function () { closeToast(pop1, 'pop1'); });
  pop2.querySelector(".toast-close").addEventListener("click", function () { closeToast(pop2, 'pop2'); });

  // ─── Copy code ───────────────────────────────────────────────────────────────
  var copyBtn   = document.getElementById("spicely-copy-btn");
  var copyIcon  = document.getElementById("spicely-copy-icon");
  var codeLabel = copyBtn.querySelector(".code-label");
  var copyResetTimer = null;

  copyBtn.addEventListener("click", function () {
    navigator.clipboard.writeText(DISCOUNT_CODE)
      .then(showCopied)
      .catch(function () {
        var el = document.createElement("textarea");
        el.value = DISCOUNT_CODE;
        el.style.cssText = "position:fixed;opacity:0;";
        document.body.appendChild(el);
        el.select();
        document.execCommand("copy");
        document.body.removeChild(el);
        showCopied();
      });
  });

  function showCopied() {
    copyBtn.classList.add("copied");
    copyIcon.textContent = "✅";
    codeLabel.textContent = "Copied!";
    clearTimeout(copyResetTimer);
    copyResetTimer = setTimeout(function () {
      copyBtn.classList.remove("copied");
      copyIcon.textContent = "📋";
      codeLabel.textContent = "Use Code";
    }, 2000);
  }

  // ─── Cart check ──────────────────────────────────────────────────────────────
  function checkCartAndShowPopup() {
    fetch('/cart.js')
      .then(function (res) { return res.json(); })
      .then(function (cart) {

        // Count qualifying items by variant ID
        var qualifyingTotal = 0;
        cart.items.forEach(function (item) {
          if (QUALIFYING_VARIANT_IDS.has(Number(item.variant_id))) {
            qualifyingTotal += item.quantity;
          }
        });

        // Transition: 0 → 1  → show Pop 1
        if (qualifyingTotal === 1 && previousCount === 0) {
          openToast(pop1, 'pop1');
        }
        // Transition: <2 → 2+  → show Pop 2
        else if (qualifyingTotal >= 2 && previousCount < 2) {
          openToast(pop2, 'pop2');
        }

        previousCount = qualifyingTotal;
      })
      .catch(function (err) {
        console.error("Spicely toast: failed to fetch cart:", err);
      });
  }

  // ─── Event listeners ─────────────────────────────────────────────────────────

  // Add to cart button (product page)
  document.body.addEventListener("click", function (e) {
    if (e.target.closest('[name="add"]') || e.target.closest('[data-add-to-cart]')) {
      setTimeout(checkCartAndShowPopup, 1200);
    }
  });

  // Quantity input changes (cart drawer / cart page)
  document.body.addEventListener("change", function (e) {
    if (
      e.target.matches('[name="updates[]"]') ||
      e.target.matches('.cart-item__quantity') ||
      e.target.matches('input[type="number"][name*="quantity"]')
    ) {
      setTimeout(checkCartAndShowPopup, 800);
    }
  });

  // +/- quantity buttons (cart drawer)
  document.body.addEventListener("click", function (e) {
    if (
      e.target.closest('.cart-item__quantity-button') ||
      e.target.closest('[data-quantity-button]') ||
      e.target.closest('.quantity__button')
    ) {
      setTimeout(checkCartAndShowPopup, 800);
    }
  });

});
</script>
