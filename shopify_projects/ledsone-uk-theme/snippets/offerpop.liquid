<!-- SPICELY COLLECTION — BUY 2 GET 10% TOAST POPUPS -->
<!-- Pop 1: Buy 2 alert (1 qualifying item in cart) -->
<div id="spicely-pop1" class="spicely-toast pop1">
  <div class="toast-inner">
    <button class="toast-close" aria-label="Close">&times;</button>
    <div class="toast-icon">🔥</div>
    <div class="toast-body">
      <p class="toast-title">Add One More to Save!</p>
      <p class="toast-message">Buy 2 items get <strong>15% off</strong> both.</p>
    </div>
  </div>
  <div class="toast-progress"></div>
</div>

<!-- Pop 2: Eligible discount (2+ qualifying items in cart) -->
<div id="spicely-pop2" class="spicely-toast pop2">
  <div class="toast-inner">
    <button class="toast-close" aria-label="Close">&times;</button>
    <div class="toast-icon">🎉</div>
    <div class="toast-body">
      <p class="toast-title">You're eligible for 15% off now!</p>
      <p class="toast-discount">Save 15%</p>
      <p class="toast-message">Click below to copy your discount code.</p>
      <div class="toast-code" id="spicely-copy-btn" title="Click to copy">
        <span class="code-label">Use Code</span>
        <span class="code-value">B2P10</span>
        <span class="copy-icon" id="spicely-copy-icon">📋</span>
      </div>
    </div>
  </div>
  <div class="toast-progress"></div>
</div>

<style>
  {% comment %} @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap'); {% endcomment %}

  .spicely-toast {
    font-family: 'DM Sans', sans-serif;
    position: fixed;
    top: 50%;
    right: 24px;
    transform: translateY(-50%) translateX(calc(100% + 40px));
    width: 320px;
    border-radius: 14px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.28), 0 1.5px 4px rgba(0,0,0,0.12);
    z-index: 9999;
    overflow: hidden;
    opacity: 0;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.35s ease;
    pointer-events: none;
  }

  .spicely-toast.pop1 {
    background: #1a1a1a;
    color: #f5f5f5;
  }

  .spicely-toast.pop2 {
    background: #1c0f0f;
    color: #f5f5f5;
    border: 1px solid rgba(220, 80, 50, 0.25);
  }

  .spicely-toast.is-open {
    transform: translateY(-50%) translateX(0);
    opacity: 1;
    pointer-events: auto;
  }

  .toast-inner {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 18px 18px 16px 18px;
    position: relative;
  }

  .toast-close {
    position: absolute;
    top: 12px;
    right: 14px;
    background: none;
    border: none;
    color: #888;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    padding: 2px 5px;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }

  .toast-close:hover {
    color: #f5f5f5;
    background: rgba(255,255,255,0.08);
  }

  .toast-icon {
    font-size: 26px;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .toast-body {
    flex: 1;
    padding-right: 20px;
  }

  .toast-title {
    font-size: 15px;
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 4px 0;
    letter-spacing: -0.01em;
  }

  .toast-discount {
    font-size: 13px;
    font-weight: 600;
    color: #f57642;
    margin: 0 0 6px 0;
    letter-spacing: 0.01em;
  }

  .toast-message {
    font-size: 13px;
    color: #aaa;
    margin: 0 0 12px 0;
    line-height: 1.45;
  }

  .toast-message strong {
    color: #f5f5f5;
  }

  .pop1 .toast-message {
    margin-bottom: 0;
  }

  /* Copy code block */
  .toast-code {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(245, 118, 66, 0.1);
    border: 1px dashed rgba(245, 118, 66, 0.4);
    border-radius: 8px;
    padding: 6px 12px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.1s;
    user-select: none;
  }

  .toast-code:hover {
    background: rgba(245, 118, 66, 0.2);
    border-color: rgba(245, 118, 66, 0.7);
  }

  .toast-code:active {
    transform: scale(0.97);
  }

  .code-label {
    font-size: 11px;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    transition: color 0.2s;
  }

  .code-value {
    font-size: 13px;
    font-weight: 700;
    color: #f57642;
    letter-spacing: 0.06em;
  }

  .copy-icon {
    font-size: 13px;
    margin-left: 2px;
    line-height: 1;
  }

  .toast-code.copied .code-label {
    color: #6ee7b7;
  }

  /* Progress bar */
  .toast-progress {
    height: 3px;
    width: 100%;
    transform-origin: left;
    transform: scaleX(0);
    border-radius: 0 0 14px 14px;
    transition: none;
  }

  .pop1 .toast-progress {
    background: #888;
  }

  .pop2 .toast-progress {
    background: #f57642;
  }

  .spicely-toast.is-open .toast-progress {
    transform: scaleX(1);
    transition: transform 6s linear;
  }
</style>

