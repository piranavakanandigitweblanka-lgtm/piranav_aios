{% comment %}
  Amazon-style Customer Reviews Section in a Popup
  Metafield: product.metafields.custom.amazon_reviews
{% endcomment %}

{% if product.metafields.custom.amazon_reviews != blank %}
  {% assign reviews = product.metafields.custom.amazon_reviews.value %}

  <!-- BUTTON -->
  <button id="open-amazon-reviews" class="amazon-reviews-btn">
    Amazon Reviews
  </button>

  <!-- POPUP MODAL -->
  <div id="amazon-reviews-modal" class="amazon-modal">
    <div class="amazon-modal-overlay"></div>

    <div class="amazon-modal-content">
      <span class="amazon-modal-close">&times;</span>

      <section class="amazon-reviews">
        <h2 class="amazon-reviews__heading">Customer Reviews from Amazon</h2>
        <div class="amazon-reviews__divider"></div>

        {% for review in reviews %}
          <article class="amazon-review">
            <header class="amazon-review__header">
              <div class="amazon-review__avatar">
                {{ review.customer_name | slice: 0,1 | upcase }}
              </div>
              <div>
                <span class="amazon-review__author">{{ review.customer_name }}</span><br>
                <span class="amazon-review__verified">Verified Purchase</span>
              </div>
            </header>

            <div class="amazon-review__rating">
              {% for i in (1..review.star_rating) %}
                <span class="amazon-review__star">★</span>
              {% endfor %}
            </div>

            <h4 class="amazon-review__title">{{ review.review_title }}</h4>
            <p class="amazon-review__text">{{ review.review_text }}</p>
            <p class="amazon-review__date">{{ review.date }}</p>

            {% if review.images %}
              <div class="amazon-review__images">
                {% for image in review.images %}
                  <img src="{{ image }}" alt="Review image" loading="lazy">
                {% endfor %}
              </div>
            {% endif %}

            <a href="{{ review.product_url }}" target="_blank" rel="noopener noreferrer" class="amazon-review__link">
              View on Amazon
            </a>
          </article>
        {% endfor %}
      </section>

    </div>
  </div>

{% endif %}


<style>
/* ------------------------------
   BUTTON
------------------------------ */
.amazon-reviews-btn {
  background: #2563eb;
  color: white;
  padding: 12px 22px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  margin: 25px 0;
  display: inline-block;
  transition: 0.25s ease;
}
.amazon-reviews-btn:hover { opacity: 0.9; }

/* ------------------------------
   POPUP MODAL (FULL SCREEN OVERLAY)
------------------------------ */
.amazon-modal {
  display: none;
  position: fixed !important;
  inset: 0 !important;
  width: 100%;
  height: 100%;
  z-index: 999999999 !important;
}

.amazon-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  backdrop-filter: blur(2px);
  z-index: 999999998;
}

/* Modal content */
.amazon-modal-content {
  background: white;
  position: relative;
  margin: 80px auto;
  padding: 20px;
  width: 90%;
  max-width: 800px;
  border-radius: 12px;
  z-index: 999999999;
  animation: modalFade 0.3s ease;
}

@keyframes modalFade {
  from { opacity: 0; transform: scale(0.95);}
  to   { opacity: 1; transform: scale(1);}
}

.amazon-modal-close {
  position: absolute;
  right: 18px;
  top: 10px;
  font-size: 28px;
  cursor: pointer;
  color: #333;
  transition: 0.25s ease;
}
.amazon-modal-close:hover { color: #000; }

/* ------------------------------
   ALWAYS FORCE OVERLAY ABOVE THEME HEADER
------------------------------ */
header, .header, .site-header, .header-wrapper, .shopify-section-header {
  z-index: 1 !important;
  position: relative;
}

/* ------------------------------
   AMAZON REVIEWS STYLE
------------------------------ */
.amazon-reviews {
  background: #ffffff;
  padding: 30px;
  border-radius: 12px;
  border: 1px solid #e2e8f0;
  margin-top: 10px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.amazon-reviews__heading {
  font-size: 1.6rem;
  font-weight: 700;
  text-align: center;
  margin-bottom: 20px;
}

.amazon-reviews__divider {
  width: 80px;
  height: 3px;
  background: #2563eb;
  margin: 0 auto 30px;
  border-radius: 4px;
}

.amazon-review {
  padding: 25px;
  border-radius: 12px;
  border: 1px solid #e2e8f0;
  background: #ffffff;
  margin-bottom: 20px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.04);
  transition: transform 0.2s ease;
}
.amazon-review:hover {
  transform: translateY(-3px);
}

.amazon-review__header {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 12px;
}

.amazon-review__avatar {
  background: #2563eb;
  color: white;
  font-weight: 700;
  width: 42px;
  height: 42px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 18px;
}

.amazon-review__author {
  font-weight: 600;
  font-size: 16px;
}

.amazon-review__verified {
  font-size: 13px;
  color: #10b981;
}

.amazon-review__rating {
  color: #fbbf24;
  font-size: 18px;
  margin-bottom: 8px;
}

.amazon-review__title {
  font-weight: 600;
  margin-bottom: 6px;
}

.amazon-review__text {
  font-size: 15px;
  line-height: 1.6;
  margin-bottom: 8px;
}

.amazon-review__date {
  font-size: 13px;
  color: #718096;
}

.amazon-review__images {
  display: flex;
  gap: 10px;
  margin-top: 12px;
  flex-wrap: wrap;
}

.amazon-review__images img {
  width: 90px;
  height: 90px;
  border-radius: 8px;
  object-fit: cover;
  border: 1px solid #e2e8f0;
  transition: transform 0.25s ease;
}
.amazon-review__images img:hover {
  transform: scale(1.05);
}

.amazon-review__link {
  display: inline-block;
  color: #2563eb;
  font-weight: 600;
  margin-top: 10px;
  text-decoration: none;
}
.amazon-review__link:hover {
  text-decoration: underline;
}

</style>
<script>
  const modal = document.getElementById("amazon-reviews-modal");
  const btn = document.getElementById("open-amazon-reviews");
  const closeBtn = document.querySelector(".amazon-modal-close");
  const overlay = document.querySelector(".amazon-modal-overlay");

  if (btn) {
    btn.addEventListener("click", () => {
      modal.style.display = "block";
      document.body.style.overflow = "hidden"; // stop scroll behind popup
    });

    closeBtn.addEventListener("click", () => {
      modal.style.display = "none";
      document.body.style.overflow = "auto";
    });

    overlay.addEventListener("click", () => {
      modal.style.display = "none";
      document.body.style.overflow = "auto";
    });
  }
</script>

