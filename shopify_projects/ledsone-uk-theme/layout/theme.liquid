{% liquid
  assign enable_rtl = settings.rtl
  assign iso_code = request.locale.iso_code
  assign lis_language_rtl = settings.language_rtl
  if lis_language_rtl != blank
    if lis_language_rtl contains iso_code
      assign enable_rtl = true
    else
      assign enable_rtl = false
    endif
  endif
%}

<!doctype html>
<html class="no-js{% if enable_rtl %} body-rtl{% endif %}" lang="{{ iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">

    <!-- Preconnect to third-party origins to speed up discovery -->
    <link rel="preconnect" href="https://connect.facebook.net" crossorigin>
    <link rel="preconnect" href="https://www.facebook.com" crossorigin>
    <link rel="preconnect" href="https://www.clarity.ms" crossorigin>
    <link rel="preconnect" href="https://static.klaviyo.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- puvii added 21st Jan, 2025 for redirection -->
    <script>
      (function redirectIfNeeded() {
        var oldBaseUrl = 'https://ledsone.co.uk/de/';
        var newBaseUrl = 'https://ledsone.co.uk/';

        // Get the current URL
        var currentUrl = window.location.href;

        // Check if the current URL starts with the old base URL
        if (currentUrl.indexOf(oldBaseUrl) === 0) {
          // Replace the old base URL with the new base URL
          var updatedUrl = currentUrl.replace(oldBaseUrl, newBaseUrl);

          // Redirect to the updated URL
          window.location.href = updatedUrl;
        }
      })();
    </script>
    <!-- puvii added 21st Jan, 2025 for redirection -->
 {% comment %} <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"> {% endcomment %}
<meta name="google-site-verification" content="yrZJ5nkQV6kiYsEC0nn-tz7Iy0gaaEDKeZbimb3FN6I">

    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>
    <meta name="description" content="{{ page_description | default: shop.description | default: shop.name | escape }}">
    {% render 'meta-tags' %}

    {%- render 'head-assets' -%}
   <!-- [SEO-PERFORMANCE] P1-B: cart.css loaded async globally, blocking only on cart template -->
    {%- if template == 'cart' -%}
      {{ 'cart.css' | asset_url | stylesheet_tag: preload: true }}
    {%- else -%}
      <link rel="preload" href="{{ 'cart.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
      <noscript>{{ 'cart.css' | asset_url | stylesheet_tag }}</noscript>
    {%- endif -%}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
       if (typeof Shopify !== 'undefined' && Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>

    {{ content_for_header }}

    <meta name="p:domain_verify" content="9b0645b57f690155160cac12806badb4">
    <meta name="facebook-domain-verification" content="fstoak96x3qug4u4pl2ym0sm0k5100">

    {% render 'gsf-conversion-pixels' %}


    <!-- add for catalog -start -->
    {% if page.handle == 'catalogue' %}
      {% comment %} <meta name="viewport" content="width = 1050, user-scalable = no"> {% endcomment %}
      <script type="text/javascript" async src="{{ 'jquery.min.1.7.js' | asset_url }}"></script>
      <script type="text/javascript" async src="{{	'modernizrcatalog.2.5.3.min.js' | asset_url	}}"></script>
      <script type="text/javascript" async src="{{	'hash.js' | asset_url	}}"></script>

      <style>
        header#page-header,
        div#shopify-section-footer-2 {
          display: none;
        }

        .shopify-section.slider-section,
        .site-wrapper,
        .wrapper.main-content {
          margin: 0 auto;
          padding: 0;
          width: 100%;
        }

        .main-content {
          width: 100%;
          margin-top: 0;
        }

        body {
          font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans',
