{"sections":{"main":{"type":"page-contact","disabled":true,"settings":{"container":"container-fluid","iframe":"<iframe src=\"https:\/\/www.google.com\/maps\/embed?pb=!1m18!1m12!1m3!1d3154.8939060848147!2d144.81158271584684!3d-37.74563313792195!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6ad65fa6debeb781%3A0xe1d23f5d1759961e!2s184%20Main%20Rd%20E%2C%20St%20Albans%20VIC%203021%2C%20%C3%9Ac!5e0!3m2!1svi!2s!4v1618277125252!5m2!1svi!2s\" width=\"100%\" height=\"500\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\"><\/iframe>","show_map":false,"contact_form_heading":"Get in Touch","contact_form_sub_heading":"<p>We'd love to hear from you about our entire service. Your comments and suggestions will be highly appreciated. Please complete the form below.<\/p>","contact_info_heading":"Here to Help","contact_info_sub_heading":"<p>Have a question? You may find an answer in our FAQs. But you can also contact us:<\/p>","store_1":"LEDSone UK","contact_info_content":"<p> Unit 3 Marshbrook Cl, Lythalls Ln, Aldermans Green Industrial Estate, Coventry CV2 2NW<\/p><p>sales@ledsone.co.uk<\/p><p><strong>02476154687<\/strong><\/p><p><\/p>","store_2":"LEDSone DE","contact_info_content_2":"<p>Ledsone LTD, Schmutter Str. 16<br\/>78647 Trossingen Germany<\/p><p>admin@ledsone.de<\/p><p><strong>+49 01782350248<\/strong><\/p>","store_3":"LEDSone FR","contact_info_content_3":"<p> Unit 3 Marshbrook Cl, Lythalls Ln, Aldermans Green Industrial Estate, Coventry CV2 2NW<\/p><p>admin@ledsone.fr<\/p><p><strong>02476154687<\/strong><\/p>","store_4":"LED Sone US","contact_info_content_4":"<p>2607 Brahms Ave, San Jose, CA 95122,<br\/>United States San jose California 95148 US<\/p><p>info@ledsone.us<\/p><p><strong>+1-732-668-5425<\/strong><\/p>"}},"custom_html_ngWAdX":{"type":"custom-html","name":"Custom HTML","settings":{"heading":"","description":"","text_alignment":"text-center","container":"container","background_color":"","content_html":"<style>\n        \/* LEDsone Contact Page Styles - Scoped to prevent theme conflicts *\/\n        .ledsone-contact-page * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n        \n        .ledsone-contact-page {\n            background-color: #f8f9fa;\n            color: #333;\n            line-height: 1.6;\n        }\n        \n        .ledsone-contact-page .container {\n            max-width: 1400px;\n            margin: 0 auto;\n            padding: 0 20px;\n        }\n        \n        \/* Header Section *\/\n        .ledsone-contact-page .header {\n            background: linear-gradient(135deg, #1a2a57 0%, #2c3e50 100%);\n            color: white;\n            padding: 60px 0;\n            text-align: center;\n        }\n        \n        .ledsone-contact-page .header h1 {\n            font-size: 2.8rem;\n            margin-bottom: 20px;\n            font-weight: 700;\n            color:white;\n        }\n        \n        .ledsone-contact-page .header p {\n            font-size: 1.5rem;\n            max-width: 800px;\n            margin: 0 auto;\n            opacity: 0.9;\n        }\n        \n        \/* Contact Methods Summary *\/\n        .ledsone-contact-page .contact-summary {\n            background-color: #fff;\n            padding: 50px;\n            margin: 40px 0;\n            border-radius: 10px;\n            box-shadow: 0 5px 20px rgba(0,0,0,0.08);\n            text-align: center;\n        }\n        \n        .ledsone-contact-page .contact-summary h2 {\n            color: #1a2a57;\n            margin-bottom: 20px;\n            font-size: 1.8rem;\n        }\n        \n        .ledsone-contact-page .contact-summary p {\n            margin-bottom: 15px;\n            font-size: 1.4rem;\n            color: #555;\n        }\n        \n        \/* Regional Offices *\/\n        .ledsone-contact-page .regional-offices {\n            margin: 50px 0;\n        }\n        \n        .ledsone-contact-page .regional-offices h2 {\n            color: #1a2a57;\n            margin-bottom: 40px;\n            font-size: 2rem;\n            text-align: center;\n            position: relative;\n        }\n        \n        .ledsone-contact-page .regional-offices h2:after {\n            content: '';\n            display: block;\n            width: 80px;\n            height: 4px;\n            background: #3498db;\n            margin: 15px auto;\n            border-radius: 2px;\n        }\n        \n        .ledsone-contact-page .offices-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n            gap: 30px;\n        }\n        \n        .ledsone-contact-page .office-card {\n            background-color: #fff;\n            padding: 30px;\n            border-radius: 10px;\n            box-shadow: 0 5px 15px rgba(0,0,0,0.08);\n            transition: transform 0.3s ease, box-shadow 0.3s ease;\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .ledsone-contact-page .office-card:before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 5px;\n            background: #3498db;\n        }\n        \n        .ledsone-contact-page .office-card:hover {\n            \n            box-shadow: 0 15px 30px rgba(0,0,0,0.15);\n        }\n        \n        .ledsone-contact-page .office-card h3 {\n            color: #1a2a57;\n            margin-bottom: 20px;\n            font-size: 1.5rem;\n            display: flex;\n            align-items: center;\n        }\n        \n        .ledsone-contact-page .office-card h3 i {\n            margin-right: 10px;\n            color: #3498db;\n        }\n        \n        .ledsone-contact-page .office-card p {\n            margin-bottom: 10px;\n            color: #555;\n            line-height: 1.7;\n        }\n        \n        .ledsone-contact-page .contact-info {\n            margin-top: 20px;\n            padding-top: 20px;\n            border-top: 1px solid #eee;\n        }\n        \n        .ledsone-contact-page .contact-info a {\n            color: #3498db;\n            text-decoration: none;\n            display: flex;\n            align-items: center;\n            margin-bottom: 12px;\n            transition: color 0.2s;\n            font-weight: 500;\n        }\n        \n        .ledsone-contact-page .contact-info a:hover {\n            color: #1a2a57;\n        }\n        \n        .ledsone-contact-page .contact-info i {\n            margin-right: 10px;\n            width: 20px;\n            text-align: center;\n        }\n        \n        \/* FAQ Reminder *\/\n        .ledsone-contact-page .faq-reminder {\n            text-align: center;\n            padding: 40px;\n            background: linear-gradient(135deg, #1a2a57 0%, #2c3e50 100%);\n            color: white;\n            border-radius: 10px;\n            margin: 50px 0;\n        }\n        \n        .ledsone-contact-page .faq-reminder h3 {\n            font-size: 1.5rem;\n            margin-bottom: 15px;\n            color:white;\n        }\n        \n        .ledsone-contact-page .faq-reminder p {\n            margin-bottom: 20px;\n            opacity: 0.9;\n        }\n        \n        .ledsone-contact-page .faq-reminder a {\n            display: inline-block;\n            background-color: #3498db;\n            color: white;\n            padding: 12px 30px;\n            border-radius: 30px;\n            text-decoration: none;\n            font-weight: 600;\n            transition: all 0.3s ease;\n        }\n        \n        .ledsone-contact-page .faq-reminder a:hover {\n            background-color: #2980b9;\n            transform: translateY(-3px);\n            box-shadow: 0 5px 15px rgba(0,0,0,0.2);\n        }\n        \n        \/* Footer *\/\n        .ledsone-contact-page .footer {\n            background-color: #1a2a57;\n            color: #ecf0f1;\n            text-align: center;\n            padding: 30px 0;\n            margin-top: 50px;\n        }\n        \n        .ledsone-contact-page .footer p {\n            opacity: 0.8;\n        }\n        \n        \/* Responsive Design *\/\n        @media (max-width: 768px) {\n            .ledsone-contact-page .header h1 {\n                font-size: 2.2rem;\n            }\n            \n            .ledsone-contact-page .contact-summary {\n                padding: 30px 20px;\n            }\n            \n            .ledsone-contact-page .office-card {\n                padding: 25px 20px;\n            }\n        }\n    <\/style>\n\n    <!-- LEDsone Contact Page - Wrapped in specific class to prevent theme conflicts -->\n    <div class=\"ledsone-contact-page\">\n        <!-- Header Section -->\n        <div class=\"header\">\n            <div class=\"container\">\n                <h1>We're Here to Help<\/h1>\n                <p>Have a question about a product, an order, or a project? Our global team is ready to assist. Find the best way to reach your local LEDsone team below.<\/p>\n            <\/div>\n        <\/div>\n        \n        <div class=\"container\">\n            <!-- Contact Methods Summary -->\n            <section class=\"contact-summary\">\n                <h2>Contact Methods Summary<\/h2>\n                <p>For general enquiries, please use the contact information below. For the fastest, most direct support regarding orders and local stock, please contact the LEDsone office in your region.<\/p>\n            <\/section>\n            \n            <!-- Regional Offices -->\n            <section class=\"regional-offices\">\n                <h2>Regional Office Details<\/h2>\n                <div class=\"offices-grid\">\n                    <!-- UK Office -->\n                    <div class=\"office-card\">\n                        <h3>\n<i class=\"fas fa-flag\"><\/i> LEDsone United Kingdom<\/h3>\n                     