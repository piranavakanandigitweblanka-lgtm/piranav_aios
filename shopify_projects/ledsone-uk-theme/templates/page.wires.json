obile-btn {\n        background-color: #fff;\n        color: #012f6d;\n        padding: 4px 20px;\n        border-radius: 10px;\n        font-weight: 600;\n        display: inline-block;\n        text-decoration: none;\n        margin-top: 10px;\n        transition: 0.25s ease;\n    }\n\n    .mobile-btn:hover {\n        background-color: #e8e8e8;\ncolor:black;\n    }\n\n    .slider-nav {\n        display: flex;\n        justify-content: center;\n        margin: 10px 0 20px;\n        gap: 10px;\n    }\n\n    .slider-dot {\n        width: 8px;\n        height:8px;\n        border-radius: 50%;\n        background-color: #bfbfbf;\n        transition: 0.2s ease;\n        cursor: pointer;\n    }\n\n    .slider-dot.active {\n        background-color: #012f6d;\n        transform: scale(1.2);\n    }\n\n    \/* Mobile Breakpoint *\/\n    @media (max-width: 768px) {\n        .desktop-menu {\n            display: none;\n        }\n        .mobile-slider-container {\n            display: block;\n        }\n    }\n<\/style>\n\n<div class=\"transformer-selector\">\n\n    <!-- Desktop Buttons -->\n    <div class=\"desktop-menu\">\n        <a href=\"https:\/\/ledsone.co.uk\/collections\/2core-round\" class=\"desktop-btn\">\n            <i class=\"fa-solid fa-bolt\"><\/i> 2 Core Round\n        <\/a>\n\n        <a href=\"https:\/\/ledsone.co.uk\/collections\/2core-twisted\" class=\"desktop-btn\">\n            <i class=\"fa-solid fa-bolt\"><\/i> 2 Core Twisted\n        <\/a>\n\n        <a href=\"http:\/\/ledsone.co.uk\/collections\/3core-round\" class=\"desktop-btn\">\n            <i class=\"fa-solid fa-bolt\"><\/i> 3 Core Round\n        <\/a>\n\n        <a href=\"https:\/\/ledsone.co.uk\/collections\/3core-twisted\" class=\"desktop-btn\">\n            <i class=\"fa-solid fa-gauge-high\"><\/i>  3 Core Twisted\n        <\/a>\n    <\/div>\n\n    <!-- Mobile Slider -->\n    <div class=\"mobile-slider-container\">\n        <div class=\"mobile-slider\">\n\n            <div class=\"mobile-slide\">\n                <h3>2 Core Round<\/h3>\n                <a href=\"https:\/\/ledsone.co.uk\/collections\/2core-round\" class=\"mobile-btn\">View Products<\/a>\n            <\/div>\n\n            <div class=\"mobile-slide\">\n                <h3> 2 Core Twisted<\/h3>\n                <a href=\"https:\/\/ledsone.co.uk\/collections\/2core-twisted\" class=\"mobile-btn\">View Products<\/a>\n            <\/div>\n\n            <div class=\"mobile-slide\">\n                <h3>3 Core Round<\/h3>\n                <a href=\"http:\/\/ledsone.co.uk\/collections\/3core-round\" class=\"mobile-btn\">View Products<\/a>\n            <\/div>\n\n            <div class=\"mobile-slide\">\n                <h3> 3 Core Twisted<\/h3>\n                <a href=\"https:\/\/ledsone.co.uk\/collections\/3core-twisted\" class=\"mobile-btn\">View Products<\/a>\n            <\/div>\n\n        <\/div>\n\n        <div class=\"slider-nav\">\n            <div class=\"slider-dot active\" data-slide=\"0\"><\/div>\n            <div class=\"slider-dot\" data-slide=\"1\"><\/div>\n            <div class=\"slider-dot\" data-slide=\"2\"><\/div>\n            <div class=\"slider-dot\" data-slide=\"3\"><\/div>\n        <\/div>\n    <\/div>\n\n<\/div>\n\n\n<script>\n    const sliderDots = document.querySelectorAll('.slider-dot');\n    const mobileSlider = document.querySelector('.mobile-slider');\n    let currentSlide = 0;\n\n    sliderDots.forEach(dot => {\n        dot.addEventListener('click', () => {\n            currentSlide = parseInt(dot.dataset.slide);\n\n            sliderDots.forEach(d => d.classList.remove('active'));\n            dot.classList.add('active');\n\n            mobileSlider.style.transform = `translateX(-${currentSlide * 100}%)`;\n        });\n    });\n\n    \/\/ Auto-slide (mobile only)\n    setInterval(() => {\n        if (window.innerWidth <= 768) {\n            currentSlide = (currentSlide + 1) % 4;\n\n            sliderDots.forEach((dot, i) =>\n                dot.classList.toggle('active', i === currentSlide)\n            );\n\n            mobileSlider.style.transform = `translateX(-${currentSlide * 100}%)`;\n        }\n    }, 4000);\n<\/script>","padding_top":0,"padding_bottom":0,"reset_spacing":false}},"collection_link_jVyRKX":{"type":"collection-link","blocks":{"link_item_8PJEyq":{"type":"link_item","settings":{"title_collection":"","collection":"2core-round"}},"link_item_4C6bHA":{"type":"link_item","settings":{"title_collection":"","collection":"2core-twisted"}},"link_item_wbARLp":{"type":"link_item","settings":{"title_collection":"","collection":"3core-round"}},"link_item_mLpAYP":{"type":"link_item","settings":{"title_collection":"","collection":"3core-twisted"}}},"block_order":["link_item_8PJEyq","link_item_4C6bHA","link_item_wbARLp","link_item_mLpAYP"],"disabled":true,"name":"Collection link","settings":{"heading":"","description":"","text_alignment":"text-center","container":"container","background_color":"","design_collection":"clt-dark","show_count_product":false,"content_width_box_link":100,"link_font_size":16,"link_font_weight":400,"collection_type":"primary","column_gap":30,"padding_top":0,"padding_bottom":0,"reset_spacing":false}},"category_navigation_UWmyGy":{"type":"category-navigation","blocks":{"category_wfXAeg":{"type":"category","settings":{"title":"All","link":"","tag":"","tag_color":"#ff0000","tag_text_color":"#ffffff"}},"category_cLCULU":{"type":"category","settings":{"title":"Women","link":"","tag":"new","tag_color":"#00cc66","tag_text_color":"#ffffff"}},"category_UAhJpM":{"type":"category","settings":{"title":"Men","link":"","tag":"hot","tag_color":"#ff3366","tag_text_color":"#ffffff"}}},"block_order":["category_wfXAeg","category_cLCULU","category_UAhJpM"],"disabled":true,"name":"Category Navigation","settings":{"heading":"Shop by Category"}},"custom_menu_yjNWbX":{"type":"custom-menu","disabled":true,"name":"Custom Menu","settings":{"heading":"","menu":"main-cat-transformers","menu_direction":"row","spacing":8}},"co