heading_fs":40,"heading_fw":500,"heading_tf":"unset","heading_mt":14,"heading_mb":0}}},"block_order":["heading_R87WVJ"],"settings":{"container":"container","text_align":"text-center","bg_color":"","custom_class":"","padding_top":0,"padding_bottom":0,"reset_spacing":false}},"banner_image_bUhTqD":{"type":"banner-image","blocks":{"image_banner_DAU4XK":{"type":"image_banner","settings":{"banner_type":"image","banner_width":"12","image":"shopify:\/\/shop_images\/1_b8f39204-4c71-4405-82f0-fb9b63dd965a.jpg","background_color":"","video_options":"local","video_url":"","link":"https:\/\/ledsone.co.uk\/collections\/chandelier","color":"default","content_spacing":"default","text_size":"medium","h_text_weight":400,"title":"","subtext":"","content":"","button_type":"primary","btn_content":"","open_link":"_blank"}}},"block_order":["image_banner_DAU4XK"],"settings":{"show_heading_header":false,"heading":"LED MODULE","description":"","text_alignment":"text-center","container":"container-fluid","banner_background_color":"","hover_effect":"translate-to-top","design_banner":"text-overlay-image","text_position":"center","text_align":"text-left","content_on_mobile":false,"column_gap":0,"padding_top":0,"padding_bottom":0,"reset_spacing":false}},"custom_liquid_BPkHwA":{"type":"custom-liquid","settings":{"heading":"","description":"","text_alignment":"text-center","container":"container","background_color":"","content_liquid":"<p>&nbsp;<span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-weight: 700; white-space-collapse: preserve;\">Introduction<\/span><\/p><span id=\"docs-internal-guid-4b93b83c-7fff-aa76-63b6-df53585170aa\"><p dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 12pt; margin-top: 12pt;\"><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">Chandeliers have long been synonymous with elegance, sophistication, and timeless beauty. At LEDsone, we offer a wide range of chandeliers, ceiling lights, and other lighting options, perfect as dining room centerpieces or stylish accents for any space.<\/span><\/p><p dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 12pt; margin-top: 12pt;\"><\/p><hr \/><p><\/p><h3 dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 4pt; margin-top: 14pt;\"><span style=\"font-family: Arial, sans-serif; font-size: 13pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">What Is a Chandelier? A Glimpse Into Elegance<\/span><\/h3><p dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 12pt; margin-top: 12pt;\"><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">A <\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; font-weight: 700; vertical-align: baseline; white-space-collapse: preserve;\">chandelier<\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\"> is more than just a lighting fixture; it’s a statement piece that elevates the aesthetics of any room. People traditionally designed chandeliers to hold candles, placing them in medieval castles and churches. Over time, these candle-lit beauties evolved into modern marvels featuring bulbs, crystals, and intricate designs.<\/span><\/p><p dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 12pt; margin-top: 12pt;\"><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">Today, chandeliers come in various styles, including <\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; font-weight: 700; vertical-align: baseline; white-space-collapse: preserve;\">chandelier ceiling lights<\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">, <\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; font-weight: 700; vertical-align: baseline; white-space-collapse: preserve;\">ceiling chandelier lamps<\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">, and even minimalist designs to fit contemporary interiors. They serve not only as a source of illumination but also as an artistic expression of luxury and taste.<\/span><\/p><p dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 0pt; margin-top: 0pt;\"><\/p><hr \/><p><\/p><h3 dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 4pt; margin-top: 14pt;\"><span style=\"font-family: Arial, sans-serif; font-size: 13pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">The History and Symbolism of Chandeliers<\/span><\/h3><p dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 12pt; margin-top: 12pt;\"><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">The term <\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-style: italic; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">chandelier<\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\"> originates from the French word <\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-style: italic; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">chandelle<\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">, meaning \"candle.\" In the early days, chandeliers were simple wooden or metal frames designed to hold candles. By the 18th century, chandeliers became elaborate works of art adorned with crystals and glass, symbolizing wealth and grandeur.<\/span><\/p><p dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 12pt; margin-top: 12pt;\"><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">Even today, <\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; font-weight: 700; vertical-align: baseline; white-space-collapse: preserve;\">ceiling chandeliers<\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\"> are a symbol of luxury and elegance, making them a popular choice for both residential and commercial spaces. From traditional <\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; font-weight: 700; vertical-align: baseline; white-space-collapse: preserve;\">chandelier ceiling lamps<\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\"> to modern <\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; font-weight: 700; vertical-align: baseline; white-space-collapse: preserve;\">ceiling light chandeliers<\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">, their appeal remains timeless.<\/span><\/p><p dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 0pt; margin-top: 0pt;\"><\/p><hr \/><p><\/p><h3 dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 4pt; margin-top: 14pt;\"><span style=\"font-family: Arial, sans-serif; font-size: 13pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">Why Are Chandeliers So Expensive?<\/span><\/h3><p dir=\"ltr\" style=\"line-height: 1.38; margin-bottom: 12pt; margin-top: 12pt;\"><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; vertical-align: baseline; white-space-collapse: preserve;\">The cost of a chandelier often reflects its craftsmanship, materials, and design complexity. Here’s why high-quality <\/span><span style=\"font-family: Arial, sans-serif; font-size: 11pt; font-variant-alternates: normal; font-variant-east-asian: normal; font-variant-emoji: normal; font-variant-numeric: normal; font-variant-position: normal; font-weight: 700; vertical-align: baseline; white-space-collapse: preserve;\">chandeliers and lamp