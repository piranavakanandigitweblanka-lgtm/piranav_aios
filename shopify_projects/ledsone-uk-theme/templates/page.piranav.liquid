{%- layout none -%}<?xml version="1.0" encoding="UTF-8" ?>
<rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">

<channel>
  <title>{{ shop.name | escape }} Products</title>
  <link>{{ shop.url }}</link>
  <description>{{ shop.name | escape }} - Product Feed for Google Merchant Center</description>

  {% assign target_collection = collections['electrical-lighting'] %}
  {% paginate target_collection.products by 5000 %}

  {% for product in target_collection.products %}
    <!-- Item #{{ forloop.index }} -->
    <item>
      <g:id>{{ product.id }}</g:id>

      <g:title><![CDATA[{{ product.title | strip_html | strip_newlines | escape | replace: 'amp;', 'and' | replace: '&#38;', 'and' | replace: "Ã©", "e" | replace: "Ã ", "a" }}]]></g:title>

      <g:description><![CDATA[{{ product.description | strip_html | strip_newlines | replace: 'amp;', 'and' | replace: '&#38;', 'and' | replace: "..", ". " | replace: " ", " " | replace: "â€˜", "&#39;" | replace: "â€™", "&#39;" | replace: "&#8216;", "&#39;" | replace: "&#8217;", "&#39;" | replace: "Ã¢â‚¬â„¢", "&#39;" | replace: "Ã¢â‚¬Å"", "&#39;" | replace: "Ã¢â‚¬Ëœ", "&#39;" | replace: "Ã‚Â´", "&#39;" | replace: "â€œ", "&#34;" | replace: "â€", "&#34;" | replace: "&#8211;", "-" | replace: "Ã¢â‚¬â€œ", "-" | replace: "Ã¢â‚¬â€", "-" | replace: "â€"", "&mdash;" | replace: "â€"", "&mdash;" | replace: "%", "&#37;" | replace: "Ã‚Â©", "&copy;" | replace: "Ã‚Â®", "&reg;" | replace: "Ã¢â€žÂ¢", "&trade;" | replace: "Ã‚Â£", "&pound;" | replace: "Ã¯Â¿Â", "&#42;" | replace: "Ã¢â‚¬Â¢", "&#42;" | replace: "Ã¢â‚¬Â", "&#39;" | replace: "&#233;", "e" | replace: "Ã©", "e" | replace: "Ã ", "a" | replace: "Ã³", "o" | replace: "Ãª", "e" | replace: "ÃƒËœ", "O" | replace: "&#8482;", "" | replace: "&#174;", "" }}]]></g:description>

      <g:link>{{ shop.url }}{{ product.url }}</g:link>

      <g:image_link>{{ product.featured_image | product_img_url: 'large' }}</g:image_link>

      <!-- FIX: lowercase 'new' as required by Google -->
      <g:condition>new</g:condition>

      <!-- FIX: 'in stock' / 'out of stock' with space as required by Google -->
      <g:availability>{% if product.available %}in stock{%- else -%}out of stock{%- endif %}</g:availability>

      <g:price>{{ product.price | money_without_currency }} {{ shop.currency }}</g:price>
      <!-- <g:sale_price>{{ product.price | money_without_currency }} {{ shop.currency }}</g:sale_price> -->

      <!-- Optional: Add shipping block if needed (update country/service/price to match your store) -->
      <!--
      <g:shipping>
        <g:country>GB</g:country>
        <g:service>Standard</g:service>
        <g:price>0.00 GBP</g:price>
      </g:shipping>
      -->

      <g:gtin>
        {%- assign current_variant = product.selected_or_first_available_variant -%}
        {%- if current_variant.barcode %}{{ current_variant.barcode }}{%- endif -%}
      </g:gtin>

      <g:brand>{{ product.vendor | escape }}</g:brand>
      <g:product_type>{{ product.type | escape }}</g:product_type>
      <!-- <g:google_product_category>{{ product.type | escape }}</g:google_product_category> -->
    </item>

    {% if product.variants.size > 1 %}
      {% for variant in product.variants %}
        <!-- Variant #{{ forloop.index }} for Product ID {{ product.id }} -->
        <item>
          <g:id>{{ variant.id }}</g:id>

          <g:title><![CDATA[{{ product.title | strip_html | strip_newlines | escape | replace: 'amp;', 'and' | replace: '&#38;', 'and' | replace: "Ã©", "e" | replace: "Ã ", "a" }} - Variant: {{ variant.title | escape }}]]></g:title>

          <!-- FIX: variant.description does not exist — using product.description -->
          <g:description><![CDATA[{{ product.description | strip_html | strip_newlines | replace: 'amp;', 'and' | replace: '&#38;', 'and' | replace: "..", ". " | replace: " ", " " | replace: "â€˜", "&#39;" | replace: "â€™", "&#39;" | replace: "&#8216;", "&#39;" | replace: "&#8217;", "&#39;" | replace: "Ã¢â‚¬â„¢", "&#39;" | replace: "Ã¢â‚¬Å"", "&#39;" | replace: "Ã¢â‚¬Ëœ", "&#39;" | replace: "Ã‚Â´", "&#39;" | replace: "â€œ", "&#34;" | replace: "â€", "&#34;" | replace: "&#8211;", "-" | replace: "Ã¢â‚¬â€œ", "-" | replace: "Ã¢â‚¬â€", "-" | replace: "â€"", "&mdash;" | replace: "â€"", "&mdash;" | replace: "%", "&#37;" | replace: "Ã‚Â©", "&copy;" | replace: "Ã‚Â®", "&reg;" | replace: "Ã¢â€žÂ¢", "&trade;" | replace: "Ã‚Â£", "&pound;" | replace: "Ã¯Â¿Â", "&#42;" | replace: "Ã¢â‚¬Â¢", "&#42;" | replace: "Ã¢â‚¬Â", "&#39;" | replace: "&#233;", "e" | replace: "Ã©", "e" | replace: "Ã ", "a" | replace: "Ã³", "o" | replace: "Ãª", "e" | replace: "ÃƒËœ", "O" | replace: "&#8482;", "" | replace: "&#174;", "" }}]]></g:description>

          <g:link>{{ shop.url }}{{ variant.url }}</g:link>

          <!-- FIX: fallback to product image if variant has no image -->
          <g:image_link>
            {%- if variant.featured_image -%}
              {{ variant.featured_image | product_img_url: 'large' }}
            {%- else -%}
              {{ product.featured_image | product_img_url: 'large' }}
            {%- endif -%}
          </g:image_link>

          <!-- FIX: lowercase 'new' -->
          <g:condition>new</g:condition>

          <!-- FIX: 'in stock' / 'out of stock' with space -->
          <g:availability>{% if variant.available %}in stock{%- else -%}out of stock{%- endif %}</g:availability>

          <g:price>{{ variant.price | money_without_currency }} {{ shop.currency }}</g:price>
          <!-- <g:sale_price>{{ variant.price | money_without_currency }} {{ shop.currency }}</g:sale_price> -->

          <!-- Optional: Add shipping block if needed -->
          <!--
          <g:shipping>
            <g:country>GB</g:country>
            <g:service>Standard</g:service>
            <g:price>0.00 GBP</g:price>
          </g:shipping>
          -->

          <!-- FIX: guard against empty barcode -->
          <g:gtin>{% if variant.barcode %}{{ variant.barcode }}{% endif %}</g:gtin>

          <g:brand>{{ product.vendor | escape }}</g:brand>
          <g:product_type>{{ product.type | escape }}</g:product_type>
          <!-- <g:google_product_category>{{ product.type | escape }}</g:google_product_category> -->
        </item>
      {% endfor %}
    {% endif %}

  {% endfor %}
  {% endpaginate %}

</channel>
</rss>
