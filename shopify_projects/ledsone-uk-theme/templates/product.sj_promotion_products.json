ow_countdown_timer":true,"message":"Hurry Up! Sale ends in:"}},"3870a5bb-fec0-4b82-9405-e324077ed947":{"type":"product_swatch","settings":{}},"f98b666a-7c37-41ed-be7b-4a28f4a1e8b4":{"type":"stock_countdown","settings":{"message":"Hurry Up! Only [count] left in stock!","qty":35}},"custom_html_dEEDdU":{"type":"custom_html","settings":{"content":"<style>\n    .description-btn, .dropbtn {\n        color: #fff;\n        background-color: #a80c1e; \/* Changed to promotional red *\/\n        border: 1px solid #e63946; \/* Changed to promotional red *\/\n        padding: 12px;\n        font-size: 12px;\n        cursor: pointer;\n        border-radius: 15px;\n        font-weight: bold;\n        text-transform: uppercase;\n        transition: all 0.3s ease;\n        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n        display: inline-block;\n        margin:2px;\n    }\n    .description-btn:hover, .dropbtn:hover {\n        background-color: white;\n        color: #e63946; \/* Changed hover text to promotional red *\/\n    }\n \n    .dropdown {\n        position: relative;\n        display: inline-block;\n    }\n \n    .dropdown-content {\n        position: absolute;\n        width: 100%;\n        z-index: 1;\n        \/* Animation initial state: hidden *\/\n        opacity: 0;\n        transform: translateY(-10px);\n        visibility: hidden;\n        transition: opacity 0.3s ease-in-out, transform 0.3s ease-in-out, visibility 0.3s;\n    }\n \n    .dropdown.active .dropdown-content {\n        \/* Animation final state: visible *\/\n        opacity: 1;\n        transform: translateY(0);\n        visibility: visible;\n    }\n \n    .promo-code {\n        padding: 10px;\n        \/* Changed to a red and orange gradient *\/\n        background: linear-gradient(135deg, #e63946, #f4a261); \n        color: white;\n        text-transform: uppercase;\n        font-size: 12px;\n        cursor: pointer;\n        border-radius: 15px;\n        margin-bottom: 4px;\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        font-weight: bold;\n        transition: background 0.3s ease;\n    }\n \n    .promo-code:hover {\n        \/* Reversed red and orange gradient for hover *\/\n        background: ;\n    }\n \n    .promo-check {\n        \/* Kept as a semi-transparent overlay, which works on the new background *\/\n        background-color: rgba(255, 255, 255, 0.2);\n        padding: 4px 10px;\n        border-radius: 10px;\n        font-size: 12px;\n        color: #fff;\n        font-weight: bold;\n        white-space: nowrap;\n    }\n \n    #toast {\n        display: none;\n        background-color: #000000; \/* Changed to black for high contrast *\/\n        color: #fff;\n        padding: 15px;\n        position: fixed;\n        top: 20px;\n        left: 50%;\n        transform: translateX(-50%);\n        z-index: 1000;\n        border-radius: 10px;\n        width: 80%;\n        max-width: 300px;\n        text-align: center;\n    }\n \n    .button-container {\n        display: flex;\n        width: 100%;\n    }\n<\/style>\n \n<div class=\"button-container\">\n<div class=\"dropdown\" id=\"promoDropdown\">\n<button class=\"dropbtn\" onclick=\"toggleDropdown()\">Deals & Click with Copy ▼<\/button>\n<div class=\"dropdown-content\">\n<div class=\"promo-code\" onclick=\"copyPromoCode('LIGHT10')\">10% off Buy 2 Wall Lights<\/div>\n<div class=\"promo-code\" onclick=\"copyPromoCode('SAVESJ15')\">15% Off Orders Over £500<\/div>\n<div class=\"promo-code\" onclick=\"copyPromoCode('SDMSJ20')\">20% OFF Buy 1000+ LED Modules<\/div>\n<div class=\"promo-code\" onclick=\"copyPromoCode('HLIGHT10')\">10% Off on 2 Pcs Pendant Lights<\/div>\n<\/div>\n<\/div>\n<a href=\"#dec\"><button class=\"description-btn\">View Description<\/button><\/a>\n<\/div>\n \n<div id=\"toast\">Promo code copied!<\/div>\n \n<script>\n    function toggleDropdown() {\n        const dropdown = document.getElementById('promoDropdown');\n        dropdown.classList.toggle('active');\n    }\n \n    document.addEventListener('click', function(event) {\n        const dropdown = document.getElementById('promoDropdown');\n        if (!dropdown.contains(event.target)) {\n            dropdown.classList.remove('active');\n        }\n    });\n \n    function copyPromoCode(code) {\n        navigator.clipboard.writeText(code).then(function() {\n            showToast('Copied: ' + code);\n        }, function(err) {\n            console.error('Could not copy text: ', err);\n            showToast('Failed to copy');\n        });\n    }\n \n    function showToast(message) {\n        const toast = document.getElementById('toast');\n        toast.innerText = message;\n        toast.style.display = 'block';\n        setTimeout(function() {\n            toast.style.display = 'none';\n        }, 2000);\n    }\n<\/script>"}},"custom_html_4UG7wW":{"type":"custom_html","settings":{"content":"<body>\n\n\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Promotional Banner<\/title>\n  <style>\n    \/* \n      This is the CSS for the promotional banner.\n      The rules for the countdown timer have been removed.\n    *\/\n    body {\n      margin: 0;\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol';\n      background-color: #f0f0f0; \/* Added a light gray background for contrast *\/\n      padding: 2rem; \/* Added some padding to see the component clearly *\/\n    }\n\n    :root {\n      --promo-green: #6bdb7f;\n      --promo-text-dark: #1e1e1e;\n      --promo-background: #f4f3ec;\n    }\n\n    .promo-countdown-banner {\n      background-color: var(--promo-background);\n      padding: 1.5rem 2rem;\n    }\n\n    .promo-banner__container {\n      display: flex;\n      \/* Changed to 'center' since the timer is gone *\/\n      justify-content: center; \n      align-items: center;\n      max-width: 1200px;\n      margin: 0 auto;\n      gap: 2rem;\n    }\n\n    \/* Badge styling *\/\n    .promo-banner__badge-wrapper {\n      position: relative;\n      filter: drop-shadow(0 2px 5px rgba(0, 0, 0, 0.1));\n    }\n    \n    \/* Decorative 'xxx' element *\/\n    .promo-banner__badge-wrapper::before {\n      content: 'xxx';\n      position: absolute;\n      top: -5px;\n      left: 10px;\n      z-index: 2;\n      font-size: 1rem;\n      font-weight: 700;\n      color: var(--promo-green);\n      transform: rotate(-5deg);\n    }\n    \n    \/* Decorative dots element *\/\n    .promo-banner__badge-wrapper::after {\n      content: '.....\\A.....\\A.....\\A.....';\n      white-space: pre;\n      position: absolute;\n      z-index: -1;\n      right: -20px;\n      top: 50%;\n      transform: translateY(-50%);\n      line-height: 0.6;\n      font-weight: bold;\n      color: #d1d1d1;\n      opacity: 0.8;\n    }\n\n    .promo-banner__badge {\n      text-align: center;\n    }\n\n    .badge-top {\n      background-color: white;\n      padding: 0.6rem 1.75rem;\n      border: 1px solid rgba(0, 0, 0, 0.15);\n      border-bottom: none;\n      clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);\n    }\n    \n    .badge-bottom {\n      background-color: var(--promo-green);\n      padding: 0.75rem 1.75rem;\n      border: 1px solid rgba(0, 0, 0, 0.15);\n      border-top-width: 2px;\n      border-top-color: var(--promo-text-dark);\n      clip-path: polygon(0 0, 100% 0, 100% 80%, 95% 100%, 0 100%);\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 1.5rem;\n    }\n\n    .badge__main-text {\n      font-weight: 800;\n      color: var(--promo-text-dark);\n      font-size: 1.1rem;\n      text-transform: uppercase;\n      margin: 0;\n    }\n\n    .badge__subtext {\n      font-weight: 700;\n      font-size: 1rem;\n      color: var(--promo-text-dark);\n      margin: 0;\n    }\n\n    .badge__copy-button {\n      background-color: transparent;\n      border: 2px solid var(--promo-text-dark);\n      color: var(--promo-text-dark);\n      font-weight: 700;\n      padding: 0.3rem 0.8rem;\n      border-radius: 4px;\n      cursor: pointer;\n      flex-shrink: 0;\n      transition: all 0.2s ease-in-out;\n    }\n\n    .badge__copy-button:hover {\n      background-color: var(--promo-text-dark);\n      color: white;\n    }\n    \n    .badge__copy-button.copied {\n      background-color: var(--promo-text-dark);\n      color: white;\n      cursor: default;\n    }\n\n    \/* Responsive styling *\/\n    @media screen and (max-width: 800px) {\n      body {\n        padding: 0;\n      }\n      .promo-countdown-banner {\n        padding: 2rem 1rem;\n      }\n      .promo-banner__container {\n        flex-direction: column;\n        gap: 2rem;\n        text-align: center;\n      }\n      \n      .promo-banner__badge-wrapper::after {\n          display: none;\n      }\n    }\n\n    @media screen and (max-width: 480px) {\n       .badge-bottom {\n          flex-direction: column;\n          align-items: center;\n          gap: 0.75rem;\n          padding-top: 1rem;\n          padding-bottom: 1.25rem;\n          clip-path: none;\n          text-align: center;\n      }\n      .badge__subtext {\n          font-size: 0.9rem;\n      }\n    }\n  <\/style>\n\n\n\n  <section class=\"promo-countdown-banner\">\n    <div class=\"promo-banner__container\">\n      \n      <!-- The countdown timer element has been removed -->\n\n      <!-- Promotional Badge -->\n      <div class=\"promo-banner__badge-wrapper\">\n        <div class=\"promo-banner__badge\">\n          <div class=\"badge-top\">\n            <p class=\"badge__main-text\">Double Up & Get 5% Off Instantly<\/p>\n          <\/div>\n          <div class=\"badge-bottom\">\n            <span class=\"badge__subtext\">Buy 2, save 5%<\/span>\n            <button class=\"badge__copy-button\" onclick=\"copyPromoCode(this, '593T2F7JSCGR')\">\n              Copy Code\n            <\/button>\n          <\/div>\n        <\/div>\n      <\/div>\n      \n    <\/div>\n  <\/section>\n  \n  <script>\n    \/\/ The countdown timer JavaScript has been removed.\n    \n    \/\/ --- START OF COPY CODE LOGIC ---\n    function copyPromoCode(button, code) {\n      \/\/ Check if the Clipboard API is available\n      if (!navigator.clipboard) {\n        alert('Clipboard API not available. Please copy the code manually: ' + code);\n        return;\n      }\n\n      \/\/ Use the Clipboard API to write the text\n      navigator.clipboard.writeText(code).then(function() {\n        const originalText = button.innerHTML;\n        \/\/ Provide user feedback\n        button.innerHTML = 'Copied!';\n        button.classList.add('copied');\n        button.disabled = true;\n\n        \/\/ Reset the button after a delay\n        setTimeout(() => {\n          button.innerHTML = originalText;\n          button.classList.remove('copied');\n          button.disabled = false;\n        }, 2500);\n        \n      }).catch(err => {\n        console.error('Failed to copy code: ', err);\n        alert('Failed to copy the code. Please try again.');\n      });\n    }\n    \/\/ --- END OF COPY CODE LOGIC ---\n  <\/script>\n\n\n<\/body>"}},"custom_html_8M6PbV":{"type":"custom_html","settings":{"content":"<div style=\"height:1px\">\n\n<\/div>"}},"37f20969-8bae-47ff-89e1-b0be3169e19a":{"type":"product_form","settings":{"button_animation":"flash-move","show_buy_now":true}},"custom_text_jXjPp8":{"type":"custom_text","settings":{"content":"<h3>100% Money Back Guaranteed<\/h3><p><\/p>"}},"fb4d791a-e332-4dc8-b188-114a9e802869":{"type":"pickup_availability","settings":{}},"c772ce81-4aa5-415d-8939-631c6d4897ff":{"type":"delivery_return","settings":{"show_delivery":true,"delivery_text":"<p>Estimate delivery times: <strong>1-3 days <\/strong>(UK), <strong>7-15 days<\/strong> (Europe), <strong>5 -7days<\/strong> (France)<\/p>","show_return":false,"return_text":"<p>Return within <strong>30 d