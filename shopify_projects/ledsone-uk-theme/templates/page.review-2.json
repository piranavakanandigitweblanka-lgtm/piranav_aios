e our services and product offerings for your benefit and the entire community.  Thank you for being a part of our journey!<\/p>","desc_color":"","desc_fs":16,"desc_fw":500,"content_width":98,"desc_tf":"unset","desc_mt":0,"desc_mb":0}},"buttons_LNgbVU":{"type":"buttons","disabled":true,"settings":{"btn_content":"LED Sone Trustpilot Review","button_type":"primary","button_link":"https:\/\/uk.trustpilot.com\/review\/ledsone.co.uk","button_target":false,"b_mt":16,"b_mb":27}}},"block_order":["sub_heading_mYykyT","heading_VzMW9b","desc_q4UUGa","buttons_LNgbVU"],"custom_css":["p {margin-bottom: 15px; line-height: 1.6; text-align: justify;}"],"settings":{"container":"container-fluid","text_align":"text-center","bg_color":"","custom_class":"","padding_top":49,"padding_bottom":0,"reset_spacing":false}},"custom_html_mWjz4e":{"type":"custom-html","settings":{"heading":"","description":"","text_alignment":"text-center","container":"container","background_color":"","content_html":"<div class=\"review-section-wrapper\" style=\"padding: 20px; background-color: #f8f9fc;\">\n\n  <style>\n    .review-section {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 25px;\n    flex-wrap: wrap; \/* allows stacking on mobile *\/\n    max-width: 100%;\n    text-align: center;\n}\n\n@media (max-width: 600px) {\n  .review-section {\n    flex-direction: column;\n    gap: 15px;\n  }\n\n  .google-review-button,\n  .trustpilot-clean-button {\n    width: 100%;\n    justify-content: center;\n  }\n}\n    .google-review-button {\n        display: inline-flex;\n        align-items: center;\n        background-color: #e4e9f0;\n        color: black;\n        text-decoration: none;\n        padding: 10px 20px;\n        border-radius: 8px;\n        font-weight: bold;\n        font-size: 16px;\n        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);\n        transition: background-color 0.3s, box-shadow 0.3s;\n        white-space: nowrap;\n    }\n\n    .google-review-button img {\n        width: 24px;\n        height: 24px;\n        margin-right: 10px;\n        border-radius: 5px;\n    }\n\n    .google-review-button:hover {\n        background-color: white;\n        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);\n    }\n\n    .google-star {\n        width: 20px;\n        height: 20px;\n        margin-left: 5px;\n        fill: #FFC300;\n    }\n\n    .separator-line {\n        width: 1px;\n        height: 40px;\n        background-color: #ccc;\n    }\n\n    .trustpilot-widget {\n        min-width: 250px;\n        white-space: nowrap;\n    }\n  <\/style>\n\n  <div class=\"review-section\">\n    <!-- Google Review Button -->\n    <a href=\"https:\/\/search.google.com\/local\/writereview?placeid=ChIJWR7GeYhLd0gR-kkzQoy2fhQ\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"google-review-button\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0250\/4094\/5248\/files\/google_logo.png?v=1732103956\" alt=\"Google G icon\">\n      Google Review\n      <svg class=\"google-star\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" viewbox=\"0 0 24 24\">\n        <path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"><\/path>\n      <\/svg>\n    <\/a>\n\n<a href=\"https:\/\/uk.trustpilot.com\/review\/ledsone.co.uk\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"trustpilot-clean-button\">\n  Review us on \n  <svg class=\"trustpilot-star\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" viewbox=\"0 0 24 24\">\n    <path d=\"M12 .587l3.668 7.431L24 9.748l-6 5.847 1.416 8.261L12 19.896l-7.416 3.96L6 15.595 0 9.748l8.332-1.73z\"><\/path>\n  <\/svg> \n  <strong>Trustpilot<\/strong>\n<\/a>\n\n<style>\n  .trustpilot-clean-button {\n    display: inline-flex;\n    align-items: center;\n    padding: 8px 16px;\n    border: 1px solid #00B67A;         \/* Fixed green border *\/\n    border-radius: 4px;                 \/* Slight rounded corners (not bent) *\/\n    background-color: #ffffff;          \/* White background *\/\n    color: black;                       \/* Black text *\/\n    font-size: 15px;\n    font-weight: 500;\n    text-decoration: none;\n    cursor: pointer;\n  }\n\n  .trustpilot-clean-button:hover {\n    background-color: #ffffff;          \/* No change on hover *\/\n    border-color: #00B67A;              \/* Keep the same green border *\/\n    color: black;                       \/* Text stays black *\/\n    box-shadow: none;                   \/* No shadow *\/\n  }\n\n  .trustpilot-clean-button .trustpilot-star {\n    width: 18px;\n    height: 18px;\n    fill: #00B67A;                      \/* Trustpilot green *\/\n    margin: 0 5px;\n  }\n<\/style>\n<\/div>\n<\/div>","padding_top":0,"padding_bottom":0,"reset_spacing":false}},"custom_html_gczxTe":{"type":"custom-html","settings":{"heading":"What our customers say about us","description":"","text_alignment":"text-center","container":"container","background_color":"","content_html":"<style>\n    * {\n      box-sizing: border-box;\n    }\n\n    body {\n      font-family: Arial, sans-serif;\n      background: #f9f9f9;\n      margin: 20px;\n      padding: 0;\n      color: #333;\n    }\n\n    .review-card {\n      background: #fff;\n      border: 1px solid #ddd;\n      padding: 20px;\n      margin-bottom: 20px;\n      border-radius: 8px;\n      box-shadow: 0 2px 5px rgba(0,0,0,0.05);\n      display: flex;\n      flex-direction: column;\n    }\n\n    .review-header {\n      display: flex;\n      flex-wrap: wrap;\n      align-items: center;\n      justify-content: space-between;\n      margin-bottom: 10px;\n    }\n\n    .stars {\n      color: #00b67a;\n      font-size: 18px;\n      flex: 1;\n    }\n\n    .verified {\n      color: #666;\n      font-size: 14px;\n      margin-left: 10px;\n    }\n\n    .review-time {\n      color: #888;\n      font-size: 13px;\n      text-align: right;\n      flex-shrink: 0;\n    }\n\n    .review-title {\n      font-weight: bold;\n      font-size: 18px;\n      margin: 5px 0 10px;\n    }\n\n    .review-text {\n      line-height: 1.6;\n      font-size: 15px;\n    }\n\n    @media (max-width: 600px) {\n      .review-header {\n        flex-direction: column;\n        align-items: flex-start;\n      }\n\n      .review-time {\n        margin-top: 5px;\n        text-align: left;\n      }\n    }\n  <\/style>\n<div class=\"review-card\">\n    <div class=\"review-header\">\n      <div class=\"stars\">★★★★★ <span class=\"verified\">✔ Verified<\/span>\n<\/div>\n      <div class=\"review-time\">4 hours ago<\/div>\n    <\/div>\n    <div class=\"review-title\">Fantastic Company – Highly Recommend<\/div>\n    <div class=\"review-text\">\n      LED Sone.co.uk has been a pleasure to deal with—efficient, professional, and incredibly easy to work with. We purchased a ceiling fan that’s both quiet and powerful—perfect for keeping the room cool overnight during hot summer nights. This is actually our second fan from them, after being really impressed with the first one we installed in our main bedroom.\n    <\/div>\n  <\/div>\n\n  <div class=\"review-card\">\n    <div class=\"review-header\">\n      <div class=\"stars\">★★★★★ <span class=\"verified\">✔ Verified<\/span>\n<\/div>\n      <div class=\"review-time\">3 days ago<\/div>\n    <\/div>\n    <div class=\"review-title\">Top-Notch Service &amp; Reliable Products<\/div>\n    <div class=\"review-text\">\n      I had a great experience shopping with LED Sone.co.uk. The website is user-friendly, the checkout process was smooth, and I received timely updates all the way to delivery via DPD. The quality of the products is excellent—especially those from Steinel, which have proven to be dependable and well-made. Very satisfied with the entire process. Thank you to the LED Sone.co.uk team!\n    <\/div>\n  <\/div>\n\n  <div class=\"review-card\">\n    <div class=\"review-header\">\n      <div class=\"stars\">★★★★★ <span class=\"verified\">✔ Verified<\/span>\n<\/div>\n      <div class=\"review-time\">8 days ago<\/div>\n    <\/div>\n    <div class=\"review-title\">Great Range &amp; Supportive Service<\/div>\n    <div class=\"review-text\">\n      LED Sone.co.uk offers a fantastic selection of outdoor lighting. The website is easy to navigate, and placing my order was quick and simple. When I called in with a few questions, the customer service was excellent—friendly, helpful, and easy to reach. I haven’t installed the lights yet, but they look and feel high quality. Very happy so far!\n    <\/div>\n  <\/div>","padding_top":0,"padding_bottom":0,"reset_spacing":false}},"1743743476e954b660":{"type":"apps","blocks":{"judge_me_reviews_featured_carousel_nmQkEX":{"type":"shopify:\/\/apps\/judge-me-reviews\/blocks\/featured_carousel\/61ccd3b1-a9f2-4160-9fe9-4fec8413e5d8","settings":{"maxwidth":1080}}},"block_order":["judge_me_reviews_featured_carousel_nmQkEX"],"settings":{}},"custom_html_p7JgbA":{"type":"custom-html","settings":{"heading":"","description":"","text_alignment":"text-center","container":"container","background_color":"","content_html":"<div id=\"judgeme_all_reviews_widget\"><\/div>","padding_top":0,"padding_bottom":0,"reset_spacing":false}},"1743747558e1f39f5c":{"type":"apps","blocks":{"judge_me_reviews_review_widget_homepage_QQTWEG":{"type":"shopify:\/\/apps\/judge-me-reviews\/blocks\/review_widget_homepage\/61ccd3b1-a9f2-4160-9fe9-4fec8413e5d8","settings":{"product":"waterproof-dc12v-ip67-30w-led-driver-power-supply-transformer","review_data":"sample_data","max_width":1200}}},"block_order":["judge_me_reviews_review_widget_homepage_QQTWEG"],"disabled":true,"settings":{}},"custom_liquid_qe7A8h":{"type":"custom-liquid","disabled":true,"settings":{"heading":"Custom liquid","description":"","text_alignment":"text-center","container":"container","background_color":"","content_liquid":"","padding_top":0,"padding_bottom":0,"reset_spacing":false}},"banner_image_JYPtCK":{"type":"banner-image","blocks":{"image_banner_fdAwm7":{"type":"image_banner","disabled":true,"settings":{"banner_type":"im