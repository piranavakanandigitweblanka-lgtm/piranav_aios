: 0 20px;\n  box-sizing: border-box;\n}\n\n.promo-banner {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  text-align: center;\n  padding: 18px 25px;\n  border-radius: 16px;\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;\n  flex-wrap: wrap;\n  gap: 18px;\n  backdrop-filter: blur(12px);\n  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  position: relative;\n  overflow: hidden;\n  box-sizing: border-box;\n}\n\n.promo-banner.blue-transparent-ui {\n  background: linear-gradient(135deg,\n    rgba(150, 150, 150, 0.15) 0%,\n    rgba(120, 120, 120, 0.2) 100%);\n  border: 1px solid rgba(255, 255, 255, 0.25);\n  box-shadow:\n    0 8px 32px rgba(120, 120, 120, 0.3),\n    0 1px 0 rgba(255, 255, 255, 0.15) inset,\n    0 -1px 0 rgba(0, 0, 0, 0.1) inset;\n}\n\n.promo-banner.blue-transparent-ui::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: -100%;\n  width: 100%;\n  height: 100%;\n  background: linear-gradient(90deg,\n    transparent,\n    rgba(255, 255, 255, 0.1),\n    transparent);\n  transition: left 0.7s ease;\n  z-index: 1;\n}\n\n.promo-banner.blue-transparent-ui:hover::before { left: 100%; }\n\n.promo-banner.blue-transparent-ui:hover {\n  background: linear-gradient(135deg,\n    rgba(150, 150, 150, 0.25) 0%,\n    rgba(120, 120, 120, 0.3) 100%);\n  box-shadow:\n    0 12px 40px rgba(120, 120, 120, 0.4),\n    0 2px 0 rgba(255, 255, 255, 0.2) inset,\n    0 -1px 0 rgba(0, 0, 0, 0.15) inset;\n  border-color: rgba(255, 255, 255, 0.35);\n  transform: translateY(-2px);\n}\n\n.promo-text {\n  display: flex;\n  flex-direction: column;\n  font-size: 15px;\n  font-weight: 500;\n  color: rgba(22, 6, 6, 0.98);\n  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);\n  position: relative;\n  z-index: 2;\n}\n\n.promo-text .discount {\n  font-size: 20px;\n  font-weight: 700;\n  color: #000000;\n  text-shadow: 0 2px 4px rgba(255, 255, 255, 0.5);\n  letter-spacing: -0.02em;\n}\n\n.promo-text .offer {\n  color: #000000;\n  font-size: 14px;\n  margin-top: 4px;\n  font-weight: 500;\n}\n\n.promo-code {\n  background: linear-gradient(135deg,\n    rgba(140, 140, 140, 0.5) 0%,\n    rgba(110, 110, 110, 0.6) 100%);\n  color: #070303;\n  padding: 12px 24px;\n  border-radius: 10px;\n  cursor: pointer;\n  font-weight: 600;\n  position: relative;\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  border: 1px solid rgba(255, 255, 255, 0.3);\n  backdrop-filter: blur(10px);\n  box-shadow:\n    0 4px 15px rgba(120, 120, 120, 0.4),\n    0 1px 0 rgba(255, 255, 255, 0.2) inset,\n    0 -1px 0 rgba(50, 50, 50, 0.4) inset;\n  z-index: 2;\n  min-width: 180px;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 8px;\n  box-sizing: border-box;\n}\n\n.promo-code:hover {\n  background: linear-gradient(135deg,\n    rgba(150, 150, 150, 0.6) 0%,\n    rgba(120, 120, 120, 0.7) 100%);\n  transform: translateY(-2px) scale(1.02);\n  box-shadow:\n    0 8px 25px rgba(120, 120, 120, 0.5),\n    0 2px 0 rgba(255, 255, 255, 0.25) inset,\n    0 -1px 0 rgba(50, 50, 50, 0.5) inset;\n  border-color: rgba(255, 255, 255, 0.4);\n}\n\n.promo-code:active {\n  transform: translateY(0) scale(1);\n  transition: transform 0.1s;\n  box-shadow: 0 2px 10px rgba(120, 120, 120, 0.4), 0 1px 0 rgba(255, 255, 255, 0.1) inset;\n}\n\n.copy-tooltip {\n  position: absolute;\n  top: 20px;\n  left: 50%;\n  transform: translateX(-50%) translateY(5px) scale(0.95);\n  background: linear-gradient(135deg,\n    rgba(140, 140, 140, 0.95) 0%,\n    rgba(110, 110, 110, 0.95) 100%);\n  color: #fff;\n  font-size: 13px;\n  padding: 10px 16px;\n  border-radius: 8px;\n  opacity: 0;\n  pointer-events: none;\n  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);\n  backdrop-filter: blur(10px);\n  border: 1px solid rgba(255, 255, 255, 0.2);\n  white-space: nowrap;\n  box-shadow: 0 4px 20px rgba(120, 120, 120, 0.5);\n  z-index: 100;\n}\n\n.copy-tooltip::after {\n  content: '';\n  position: absolute;\n  bottom: -6px;\n  left: 50%;\n  transform: translateX(-50%);\n  border-left: 7px solid transparent;\n  border-right: 7px solid transparent;\n  border-top: 7px solid rgba(140, 140, 140, 0.95);\n}\n\n.promo-code #code-label {\n  font-weight: 500;\n  opacity: 0.95;\n  color: rgba(14, 7, 7, 0.95);\n  font-size: 14px;\n}\n\n.promo-code #code-text {\n  color: rgb(19, 10, 10);\n  font-weight: 700;\n  letter-spacing: 1px;\n  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);\n  font-size: 16px;\n  background: linear-gradient(135deg, #ffffff 0%, #cce5ff 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  padding: 2px 6px;\n  border-radius: 4px;\n  background-color: rgba(255, 255, 255, 0.1);\n}\n\n.promo-code:focus-visible {\n  outline: 2px solid rgba(150, 150, 150, 0.8);\n  outline-offset: 2px;\n  box-shadow: 0 0 0 3px rgba(150, 150, 150, 0.2), 0 8px 25px rgba(120, 120, 120, 0.5);\n}\n\n\/* ── TABLET: 768px ── *\/\n@media (max-width: 768px) {\n  .container { padding: 0 16px; }\n\n  .promo-banner {\n    gap: 14px;\n    padding: 16px 20px;\n  }\n\n  .promo-text .discount { font-size: 18px; }\n  .promo-text .offer    { font-size: 13px; }\n\n  .promo-code {\n    min-width: 160px;\n    padding: 10px 20px;\n  }\n\n  .promo-code #code-label { font-size: 13px; }\n  .promo-code #code-text  { font-size: 15px; }\n}\n\n\/* ── MOBILE: 600px ── *\/\n@media (max-width: 600px) {\n  .container { padding: 0 12px; }\n\n  .promo-banner {\n    flex-direction: column;\n    text-align: center;\n    padding: 20px 16px;\n    gap: 14px;\n    border-radius: 14px;\n    backdrop-filter: blur(20px);\n  }\n\n  .promo-text .discount { font-size: 18px; }\n  .promo-text .offer    { font-size: 13px; margin-top: 3px; }\n\n  .promo-code {\n    width: 100%;\n    max-width: 100%;\n    min-width: unset;\n    padding: 12px 16px;\n    justify-content: center;\n    box-sizing: border-box;\n  }\n\n  .promo-code #code-label { font-size: 13px; }\n  .promo-code #code-text  { font-size: 15px; }\n\n  \/* Tooltip above the button on mobile *\/\n  .copy-tooltip {\n    top: auto;\n    bottom: calc(100% + 10px);\n    font-size: 12px;\n    padding: 8px 14px;\n  }\n\n  .copy-tooltip::after {\n    top: 100%;\n    bottom: auto;\n    border-top: none;\n    border-bottom: 7px solid rgba(140, 140, 140, 0.95);\n    border-left: 7px solid transparent;\n    border-right: 7px solid transparent;\n  }\n}\n\n\/* ── SMALL MOBILE: 380px ── *\/\n@media (max-width: 380px) {\n  .container { padding: 0 8px; }\n\n  .promo-banner { padding: 16px 12px; gap: 12px; border-radius: 12px; }\n\n  .promo-text .discount { font-size: 16px; }\n  .promo-text .offer    { font-size: 12px; }\n\n  .promo-code { padding: 10px 14px; }\n  .promo-code #code-label { font-size: 12px; }\n  .promo-code #code-text  { font-size: 14px; }\n}\n\n@media (prefers-color-scheme: dark) {\n  .promo-banner.blue-transparent-ui {\n    background: linear-gradient(135deg,\n      rgba(140, 140, 140, 0.2) 0%,\n      rgba(110, 110, 110, 0.25) 100%);\n    box-shadow: 0 8px 32px rgba(120, 120, 120, 0.35), 0 1px 0 rgba(255, 255, 255, 0.1) inset;\n  }\n  .promo-text .discount {\n    color: #000000;\n    text-shadow: 0 2px 4px rgba(255, 255, 255, 0.6);\n  }\n}\n<\/style>\n\n<script>\nfunction copyCode() {\n  const codeText = document.getElementById(\"code-text\").innerText;\n  navigator.clipboard.writeText(codeText).then(() => {\n    showTooltip();\n  }).catch(() => {\n    const textArea = document.createElement('textarea');\n    textArea.value = codeText;\n    document.body.appendChild(textArea);\n    textArea.select();\n    document.execCommand('copy');\n    document.body.removeChild(textArea);\n    showTooltip();\n  });\n}\n\nfunction showTooltip() {\n  const tooltip = document.getElementById(\"copy-tooltip\");\n  tooltip.style.opacity = \"1\";\n  tooltip.style.transform = \"translateX(-50%) translateY(0) scale(1)\";\n  tooltip.animate([\n    { transform: 'translateX(-50%) translateY(0) scale(1)' },\n    { transform: 'translateX(-50%) translateY(-3px) scale(1.05)', offset: 0.3 },\n    { transform: 'translateX(-50%) translateY(0) scale(1)' }\n  ], { duration: 600, easing: 'cubic-bezier(0.34, 1.56, 0.64, 1)' });\n  setTimeout(() => {\n    tooltip.style.opacity = \"0\";\n    tooltip.style.transform = \"translateX(-50%) translateY(5px) scale(0.95)\";\n  }, 2000);\n}\n\nconst promoCodeEl = document.querySelector('.promo-code');\npromoCodeEl.setAttribute('tabindex', '0');\npromoCodeEl.addEventListener('keydown', (e) => {\n  if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); copyCode(); }\n});\n<\/script>","padding_top":0,"padding_bottom":0,"reset_spacing":false}},"8498460c-0376-40d1-bafc-199edbe0edfc":{"type":"collection-list","blocks":{"616f3472-abe6-41ef-8d49-4e190d1fc5cc":{"type":"collection_item","settings":{"title_collection":"Multi Outlet Pendant","collection":"spider-light","image":"shopify:\/\/shop_images\/pendant_light_spider.jpg"}},"36a53b4a-830c-4660-a410-d73343bf9d7d":{"type":"collection_item","settings":{"title_collection":"Pendant Holder","collection":"pendant-holder","image":"shopify:\/\/shop_images\/1128.jpg"}},"981b08cc-5195-40cd-b5f4-79c51acd6dbb":{"type":"collection_item","settings":{"title_collection":"Hemp Lighting","collection":"hemp-rope-lighting","image":"shopify:\/\/shop_images\/Hemprope.jpg"}},"template--16567751475447__8498460c-0376-40d1-bafc-199edbe0edfc-16665857567f9937b1-3":{"type":"collection_item","settings":{"title_collection":"Cage pendant light","collection":"cage-pendant-light","image":"shopify:\/\/shop_images\/home_Cage_lighting_6f17d2fc-b5ab-4da8-81b9-bfb668c813dc.png"}},"template--16567751475447__8498460c-0376-40d1-bafc-199edbe0edfc-16665857567f9937b1-0":{"type":"collection_item","settings":{"title_collection":"Glass Pendant lights","collection":"glass-pendant-lights","image":"shopify:\/\/shop_images\/Vintage_Lampshades_Amber_Glass_Ceiling_Pendant_Light.webp"}},"template--16567751475447__8498460c-0376-40d1-bafc-199edbe0edfc-16665857