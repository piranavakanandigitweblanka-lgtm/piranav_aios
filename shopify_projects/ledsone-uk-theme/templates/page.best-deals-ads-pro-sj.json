{"sections":{"17610282449714a1b7":{"type":"_blocks","settings":{}},"custom_liquid_eQgPzk":{"type":"custom-liquid","settings":{"heading":"","description":"","text_alignment":"text-center","container":"container","background_color":"","content_liquid":"<link rel=\"preconnect\" href=\"https:\/\/fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https:\/\/fonts.gstatic.com\" crossorigin>\n<link href=\"https:\/\/fonts.googleapis.com\/css2?family=Poppins:wght@400;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n    \/* ==============================================\n       💡 LIGHT & CLEAN THEME (Matches Your Header)\n    ============================================== *\/\n    :root {\n        \/* Matches your Search Button Orange *\/\n        --primary-color: #F59E0B; \n        --primary-dark: #D97706;  \n        \n        \/* Changed to White\/Light to match Header *\/\n        --background-page: #FFFFFF; \n        --background-light: #F8FAFC; \/* Very light grey for contrast *\/\n        \n        --text-main: #0F172A; \/* Dark Slate for headings *\/\n        --text-body: #334155; \/* Softer grey for text *\/\n        \n        --border-color: #E2E8F0;\n        --danger-color: #EF4444; \n        \n        --shadow-soft: 0 4px 20px rgba(0, 0, 0, 0.05);\n        --radius-md: 12px;\n        --radius-pill: 99px;\n    }\n\n    \/* --- LAYOUT FIXER (Removes the White Gap) --- *\/\n    .full-width-fix {\n        width: 100vw; \n        position: relative; \n        left: 50%; \n        right: 50%; \n        margin-left: -50vw; \n        margin-right: -50vw; \n        \n        \/* ADJUST THIS VALUE if there is still a small gap *\/\n        margin-top: -35px; \n    }\n\n    .promo-landing {\n        font-family: 'Inter', sans-serif;\n        background-color: var(--background-page);\n        color: var(--text-body);\n        line-height: 1.6;\n        padding-bottom: 50px;\n    }\n    \n    .promo-landing a { text-decoration: none; color: inherit; }\n    .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }\n\n    \/* --- 1. HERO SECTION (Light & Clean) --- *\/\n    .hero-section {\n        position: relative;\n        padding: 80px 20px;\n        text-align: center;\n        background: linear-gradient(180deg, #FFFFFF 0%, #F1F5F9 100%); \/* Fade from white to light grey *\/\n        overflow: hidden;\n    }\n    \n    .hero-content { position: relative; z-index: 2; max-width: 800px; margin: 0 auto; }\n    \n    .hero-badge {\n        display: inline-block;\n        background: #FFF7ED; \/* Light orange bg *\/\n        color: var(--primary-dark);\n        padding: 8px 24px;\n        border-radius: var(--radius-pill);\n        font-weight: 700;\n        font-size: 0.85rem;\n        text-transform: uppercase;\n        letter-spacing: 1px;\n        margin-bottom: 24px;\n        border: 1px solid #FFEDD5;\n    }\n    \n    .hero-section h1 {\n        font-family: 'Poppins', sans-serif;\n        font-size: clamp(2.5rem, 5vw, 4rem);\n        font-weight: 800;\n        color: var(--text-main);\n        line-height: 1.1;\n        margin-bottom: 20px;\n        letter-spacing: -1px;\n    }\n    \/* Highlight word style *\/\n    .hero-section h1 span { \n        color: var(--primary-color);\n        position: relative;\n    }\n    \n    .hero-section p {\n        font-size: 1.15rem;\n        color: var(--text-body);\n        margin-bottom: 40px;\n        max-width: 600px;\n        margin-left: auto; margin-right: auto;\n    }\n    \n    .cta-button {\n        display: inline-block;\n        background: var(--primary-color);\n        color: white; \/* White text on button *\/\n        padding: 18px 48px;\n        border-radius: var(--radius-pill);\n        font-weight: 700;\n        font-size: 1.1rem;\n        box-shadow: 0 10px 25px rgba(245, 158, 11, 0.3); \/* Orange shadow *\/\n        transition: all 0.3s ease;\n    }\n    .cta-button:hover {\n        transform: translateY(-3px);\n        background: var(--primary-dark);\n        box-shadow: 0 15px 35px rgba(245, 158, 11, 0.4);\n    }\n\n    \/* --- 2. TRUST BAR --- *\/\n    .trust-bar {\n        background: white;\n        border-bottom: 1px solid var(--border-color);\n        padding: 30px 0;\n    }\n    .trust-grid {\n        display: grid;\n        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n        gap: 20px;\n        text-align: center;\n    }\n    .trust-item h3 { font-family: 'Poppins', sans-serif; font-size: 1rem; color: var(--text-main); margin-bottom: 4px; font-weight: 600;}\n    .trust-item p { font-size: 0.85rem; color: var(--text-body); margin: 0; }\n    .trust-icon { color: var(--primary-color); font-size: 1.8rem; margin-bottom: 10px; display: block; }\n\n    \/* --- 3. SECTIONS --- *\/\n    .collection-section { padding: 60px 0; }\n    \n    \/* Alternate background colors for sections *\/\n    .bg-white { background-color: #FFFFFF; }\n    .bg-light { background-color: #F8FAFC; }\n\n    .section-header {\n        display: flex; justify-content: space-between; align-items: flex-end;\n        margin-bottom: 40px; flex-wrap: wrap; gap: 20px;\n    }\n    .section-title p { color: var(--primary-dark); font-weight: 700; margin: 0 0 5px 0; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 1px; }\n    .section-title h2 {\n        font-family: 'Poppins', sans-serif;\n        font-size: 2.2rem; color: var(--text-main); font-weight: 800; margin: 0;\n    }\n    \n    .view-all {\n        color: var(--text-body); font-weight: 600; display: inline-flex; align-items: center; gap: 5px; transition: color 0.2s;\n    }\n    .view-all:hover { color: var(--primary-color); }\n\n    \/* --- 4. SCROLLER & GRID --- *\/\n    .scroller-container {\n        overflow-x: auto; padding-bottom: 20px; \n        scrollbar-width: thin; scrollbar-color: var(--primary-color) #eee;\n    }\n    .scroller-track { display: flex; gap: 24px; }\n\n    .product-grid {\n        display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;\n    }\n    @media (min-width: 768px) { .product-grid { grid-template-columns: repeat(3, 1fr); gap: 24px; } }\n    @media (min-width: 1024px) { .product-grid { grid-template-columns: repeat(4, 1fr); gap: 30px; } }\n\n    \/* --- 5. PRODUCT CARD (Light Theme) --- *\/\n    .product-card {\n        background: white;\n        border: 1px solid var(--border-color);\n        border-radius: var(--radius-md);\n        overflow: hidden;\n        transition: all 0.3s ease;\n        display: flex; flex-direction: column;\n        flex: 0 0 280px;\n        position: relative;\n    }\n    .product-card:hover {\n        transform: translateY(-5px);\n        border-color: var(--primary-color);\n        box-shadow: var(--shadow-soft);\n    }\n\n    .card-image-wrapper {\n        position: relative; aspect-ratio: 1\/1; background: #fff; overflow: hidden;\n        border-bottom: 1px solid #f1f1f1;\n    }\n    .card-image-wrapper img {\n        width: 100%; height: 100%; object-fit: contain; transition: transform 0.5s ease;\n    }\n    .product-card:hover .card-image-wrapper img { transform: scale(1.05); }\n\n    .tag-sale {\n        position: absolute; top: 12px; left: 12px;\n        background: var(--danger-color); color: white;\n        padding: 4px 10px; border-radius: 4px; font-weight: 700; font-size: 0.8rem; z-index: 2;\n    }\n\n    .card-details { padding: 16px; display: flex; flex-direction: column; flex-grow: 1; }\n    .vendor-name { font-size: 0.75rem; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }\n    .product-name {\n        font-family: 'Inter', sans-serif; font-size: 0.95rem; color: var(--text-main); font-weight: 600;\n        margin-bottom: 10px; line-height: 1.4; \n        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.8em;\n    }\n    \n    .price-wrap { display: flex; align-items: baseline; gap: 8px; margin-top: auto; }\n    .price-current { color: var(--primary-dark); font-size: 1.2rem; font-weight: 700; }\n    .price-old { color: #94A3B8; text-decoration: line-through; font-size: 0.9rem; }\n\n    \/* Loader *\/\n    .loader-msg { grid-column: 1\/-1; text-align: center; padding: 40px; color: #94A3B8; font-style: italic; }\n<\/style>\n\n<div class=\"full-width-fix\">\n    <div class=\"promo-landing\">\n        <section class=\"hero-section\">\n            <div class=\"hero-content\">\n                <div class=\"hero-badge\">Official Store Offer<\/div>\n                <h1>Illuminate Your Space With <span>Luxury<\/span><\/h1>\n                <p>Discover exclusive discounts across our finest collections. From premium wall lights to industrial statement pieces, elevate your home decor today.<\/p>\n                <a href=\"#luminous-deals\" class=\"cta-button\">Shop The Sale<\/a>\n            <\/div>\n        <\/section>\n\n        <div class=\"trust-bar\">\n            <div class=\"container\">\n                <div class=\"trust-grid\">\n                    <div class=\"trust-item\"><span class=\"trust-icon\">✨<\/span><h3>Premium Quality<\/h3><p>Finest materials & finish<\/p><\/div>\n                    <div class=\"trust-item\"><span class=\"trust-icon\">🚚<\/span><h3>Fast Delivery<\/h3><p>Reliable UK shipping<\/p><\/div>\n                    <div class=\"trust-item\"><span class=\"trust-icon\">🔒<\/span><h3>Secure Checkout<\/h3><p>100% protected payments<\/p><\/div>\n                    <div class=\"trust-item\"><span class=\"trust-icon\">💡<\/span><h3>Expert Support<\/h3><p>Lighting specialists on hand<\/p><\/div>\n                <\/div>\n            <\/div>\n        <\/div>\n\n        <section class=\"collection-section bg-white\" id=\"luminous-deals\">\n            <div class=\"container\">\n                <div class=\"section-header\">\n                    <div class=\"section-title\">\n                        <p>Limited Time Offers<\/p>\n                        <h2>Luminous Deals<\/h2>\n                    <\/div>\n                    <a href=\"\/collections\/luminous-deals\" class=\"view-all\">View Collection →<\/a>\n                <\/div>\n                <div class=\"scroller-container\">\n                    <div class=\"scroller-track\" id=\"track-luminous-deals\">\n                        <div class=\"loader-msg\">Loading deals...<\/div>\n                    <\/div>\n                <\/div>\n            <\/div>\n        <\/section>\n\n        <section class=\"collection-section bg-light\">\n            <div class=\"container\">\n                <div class=\"section-header\">\n                    <div class=\"section-title\">\n                        <p>Top Rated<\/p>\n                        <h2>Premium Wall Lights<\/h2>\n                    <\/div>\n                    <a href=\"\/collections\/premium-wall-lights-collection-uk\" class=\"view-all\">View Collection →<\/a>\n                <\/div>\n                <div class=\"product-grid\" id=\"grid-premium-wall\">\n                    <div class=\"loader-msg\">Loading wall lights...<\/div>\n                <\/div>\n            <\/div>\n        <\/section>\n\n        <section class=\"collection-section bg-white\">\n            <div class=\"container\">\n                <div class=\"section-header\">\n                    <div class=\"section-title\">\n                        <p>Raw & Authentic<\/p>\n                        <h2>Industrial Collection<\/h2>\n                    <\/div>\n                    <a href=\"\/collections\/industrial-lighting-collection\" class=\"view-all\">View Collection →<\/a>\n                <\/div>\n                <div class=\"product-grid\" id=\"grid-industrial\">\n                    <div class=\"loader-msg\">Loading industrial lighting...<\/div>\n                <\/div>\n            <\/div>\n        <\/section>\n        \n        <section class=\"collection-section bg-light\">\n            <div class=\"container\">\n                <div class=\"section-header\">\n                    <div class=\"section-title\">\n                        <p>Luxury Living<\/p>\n                        <h2>Premium Lighting<\/h2>\n                    <\/div>\n                    <a href=\"\/collections\/premium-lighting\" class=\"view-all\">View Collection →<\/a>\n                <\/div>\n                <div class=\"product-grid\" id=\"grid-premium-lighting\">\n                    <div class=\"loader-msg\">Loading premium lighting...<\/div>\n                <\/div>\n            <\/div>\n        <\/section>\n    <\/div>\n<\/div>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', () => {\n\n    function buildCardHtml(product) {\n        const variant = product.variants[0];\n        if (!variant) return '';\n\n        const price = Number(variant.price);\n        const compareAtPrice = Number(variant.compare_at_price);\n        const isOnSale = compareAtPrice > price;\n        const discountPercentage = isOnSale ? Math.round((1 - price \/ compareAtPrice) * 100) : 0;\n        const imageUrl = product.images[0]?.src || 'https:\/\/placehold.co\/400x400\/F1F5F9\/94A3B8?text=Image';\n\n        return `\n            <a href=\"\/products\/${product.handle}\" class=\"product-card\">\n                <div class=\"card-image-wrapper\">\n                    ${isOnSale && discountPercentage > 0 ? `<div class=\"tag-sale\">-${discountPercentage}%<\/div>` : ''}\n                    <img src=\"${imageUrl}\" alt=\"${product.title.replace(\/\"\/g, '&quot;')}\" loading=\"lazy\">\n                <\/div>\n                <div class=\"card-details\">\n                    <span class=\"vendor-name\">${product.vendor}<\/span>\n                    <h3 class=\"product-name\">${product.title}<\/h3>\n                    <div class=\"price-wrap\">\n                        <span class=\"price-current\">£${price.toFixed(2)}<\/span>\n                        ${isOnSale ? `<span class=\"price-old\">£${compareAtPrice.toFixed(2)}<\/span>` : ''}\n                    <\/div>\n                <\/div>\n            <\/a>\n        `;\n    }\n\n    async function fetchShopifyProducts(collectionHandle, elementId, limit) {\n        const container = document.getElementById(elementId);\n        if (!container) return;\n\n        try {\n            const response = await fetch(`\/collections\/${collectionHandle}\/products.json`);\n            if (!response.ok) throw new Error('Collection fetch failed');\n            \n            const data = await response.json();\n            const products = data.products.slice(0, limit);\n            \n            container.innerHTML = ''; \n\n            if (products.length === 0) {\n                container.innerHTML = `<div class=\"loader-msg\">No products available.<\/div>`;\n                return;\n            }\n\n            products.forEach(product => {\n                container.innerHTML += buildCardHtml(product);\n            });\n\n        } catch (error) {\n            console.error(`Error loading ${collectionHandle}:`, error);\n            container.innerHTML = `<div class=\"loader-msg\">Unable to load products.<\/div>`;\n        }\n    }\n\n    \/\/ Load Collections\n    fetchShopifyProducts('luminous-deals', 'track-luminous-deals', 10);\n    fetchShopifyProducts('premium-wall-lights-collection-uk', 'grid-premium-wall', 8);\n    fetchShopifyProducts('industrial-lighting-collection', 'grid-industrial', 8);\n    fetchShopifyProducts('premium-lighting', 'grid-premium-lighting', 8);\n\n});\n<\/script>","padding_top":0,"padding_bottom":0,"reset_spacing":false}},"main":{"type":"main-page","disabled":true,"settings":{}}},"order":["17610282449714a1b7","custom_liquid_eQgPzk","main"]}