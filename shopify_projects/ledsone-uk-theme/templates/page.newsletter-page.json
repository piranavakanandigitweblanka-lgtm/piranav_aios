\/\/www.w3.org\/2000\/svg\" viewbox=\"0 0 24 24\">\n        <path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"><\/path>\n      <\/svg>\n    <\/a>\n\n<a href=\"https:\/\/uk.trustpilot.com\/review\/ledsone.co.uk\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"trustpilot-clean-button\">\n  Review us on \n  <svg class=\"trustpilot-star\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" viewbox=\"0 0 24 24\">\n    <path d=\"M12 .587l3.668 7.431L24 9.748l-6 5.847 1.416 8.261L12 19.896l-7.416 3.96L6 15.595 0 9.748l8.332-1.73z\"><\/path>\n  <\/svg> \n  <strong>Trustpilot<\/strong>\n<\/a>\n\n<style>\n  .trustpilot-clean-button {\n    display: inline-flex;\n    align-items: center;\n    padding: 8px 16px;\n    border: 1px solid #00B67A;         \/* Fixed green border *\/\n    border-radius: 4px;                 \/* Slight rounded corners (not bent) *\/\n    background-color: #ffffff;          \/* White background *\/\n    color: black;                       \/* Black text *\/\n    font-size: 15px;\n    font-weight: 500;\n    text-decoration: none;\n    cursor: pointer;\n  }\n\n  .trustpilot-clean-button:hover {\n    background-color: #ffffff;          \/* No change on hover *\/\n    border-color: #00B67A;              \/* Keep the same green border *\/\n    color: black;                       \/* Text stays black *\/\n    box-shadow: none;                   \/* No shadow *\/\n  }\n\n  .trustpilot-clean-button .trustpilot-star {\n    width: 18px;\n    height: 18px;\n    fill: #00B67A;                      \/* Trustpilot green *\/\n    margin: 0 5px;\n  }\n<\/style>\n<\/div>\n<\/div>","padding_top":0,"padding_bottom":0,"reset_spacing":false}},"products_recently_viewed_zeHtEA":{"type":"products-recently-viewed","name":"Products recently viewed","settings":{"heading":"Recently viewed products","description":"<p>The best quality products are waiting for you. Choose it now!<\/p>","text_alignment":"text-center","container":"container