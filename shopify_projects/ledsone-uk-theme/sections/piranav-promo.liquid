    <div class="promo-header">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <!-- FULL-WIDTH TIMER -->
    {% if section.settings.show_timer %}
      <div class="promo-timer fullwidth">
        <h3>Today's Deal Ends In</h3>

        <div class="timer-box">
          <div class="unit">
            <span id="t-hours">23</span>
            <label>Hours</label>
          </div>
          <span class="sep">:</span>
          <div class="unit">
            <span id="t-mins">59</span>
            <label>Minutes</label>
          </div>
          <span class="sep">:</span>
          <div class="unit">
            <span id="t-secs">59</span>
            <label>Seconds</label>
          </div>
        </div>

        <div class="timer-note">
          Next promotion starts at midnight<br>
          FREE DELIVERY ON UK ORDER OVER £25<br>
          30-Day Money Back Guarantee
        </div>

        <div class="timer-bar">
          <div id="timer-bar-fill"></div>
        </div>
      </div>
    {% endif %}

    {% if section.settings.collection %}
      {% assign coll = collections[section.settings.collection] %}

      {% if coll and coll.products.size > 0 %}
        
        {% assign per_day = 5 %}
        {% assign product_count = coll.products.size %}
        {% assign day_num = 'now' | date: '%j' | plus: 0 %}

        {% assign total_sets = product_count | plus: per_day | minus: 1 | divided_by: per_day %}
        {% assign today_set = day_num | modulo: total_sets %}
        {% assign offset_num = today_set | times: per_day %}

        <!-- DESKTOP PRODUCT GRID -->
        <div class="promo-grid desktop-view">
          {% for product in coll.products limit: per_day offset: offset_num %}
            {% assign variant = product.selected_or_first_available_variant %}
            {% assign price = variant.price %}
            {% assign compare_at_price = variant.compare_at_price %}
            
            {% assign discount = 0 %}
            {% if compare_at_price and compare_at_price > price %}
              {% assign discount = compare_at_price | minus: price | times: 100.0 | divided_by: compare_at_price | round %}
            {% endif %}

            <div class="promo-card">
              <div class="promo-img-container">
                <!-- PROMO BANNER -->
                <div class="promo-banner">
                  <div class="b1">{{ section.settings.banner_line1 }}</div>
                  <div class="b2">{{ section.settings.banner_line2 }}</div>
                  <div class="bs">{{ section.settings.banner_subtitle }}</div>
                </div>

                <!-- DISCOUNT BADGE -->
                {% if discount > 0 %}
                  <div class="promo-badge">
                    <div class="val">{{ discount }}%</div>
                    <div class="txt">OFF</div>
                  </div>
                {% endif %}

                <!-- PRICE BADGE (NEW POSITION - BELOW BANNER) -->
                <div class="price-badge">
                  {% if discount > 0 %}
                    <div class="price-content">
                      <span class="current-price sale-price">{{ price | money }}</span>
                      <span class="original-price">{{ compare_at_price | money }}</span>
                    </div>
                  {% else %}
                    <div class="price-content">
                      <span class="current-price">{{ price | money }}</span>
                    </div>
                  {% endif %}
                </div>

                <!-- ADD TO CART BUTTON FOR MOBILE -->
                <div class="mobile-cta">
                  <a href="{{ product.url }}" class="mobile-shop-btn">Shop Now 🛒</a>
                </div>

                <!-- PRODUCT IMAGE -->
                <a href="{{ product.url }}" class="promo-img">
  <img
    src="{{ product.featured_image | img_url: '400x533', crop: 'center' }}"
    alt="{{ product.title | escape }}"
    loading="lazy"
    width="400"
    height="533"
  >
</a>

              </div>
            </div>
          {% endfor %}
        </div>

        <!-- IMPROVED MOBILE SWIPER -->
        <div class="mobile-promo-slider mobile-view">
          <div class="swiper-container">
            <div class="swiper-wrapper">
              {% for product in coll.products limit: per_day offset: offset_num %}
                {% assign variant = product.selected_or_first_available_variant %}
                {% assign price = variant.price %}
                {% assign compare_at_price = variant.compare_at_price %}
                
                {% assign discount = 0 %}
                {% if compare_at_price and compare_at_price > price %}
                  {% assign discount = compare_at_price | minus: price | times: 100.0 | divided_by: compare_at_price | round %}
                {% endif %}

                <div class="swiper-slide">
                  <div class="promo-card">
                    <div class="promo-img-container">
                      {% comment %} <!-- PROMO BANNER -->
                      <div class="promo-banner">
                        <div class="b1">{{ section.settings.banner_line1 }}</div>
                        <div class="b2">{{ section.settings.banner_line2 }}</div>
                        <div class="bs">{{ section.settings.banner_subtitle }}</div>
                      </div> {% endcomment %}

                      <!-- DISCOUNT BADGE -->
                      {% if discount > 0 %}
                        <div class="promo-badge">
                          <div class="val">{{ discount }}%</div>
                          <div class="txt">OFF</div>
                        </div>
                      {% endif %}

                      <!-- PRICE BADGE (NEW POSITION - BELOW BANNER) -->
                      <div class="price-badge">
                        {% if discount > 0 %}
                          <div class="price-content">
                            <span class="current-price sale-price">{{ price | money }}</span>
                            <span class="original-price">{{ compare_at_price | money }}</span>
                          </div>
                        {% else %}
                          <div class="price-content">
                            <span class="current-price">{{ price | money }}</span>
                          </div>
                        {% endif %}
                      </div>

                      <!-- PROMINENT CTA BUTTON -->
                      <div class="mobile-cta">
                        <a href="{{ product.url }}" class="mobile-shop-btn">Shop Now 🛒</a>
                      </div>

                      <!-- PRODUCT IMAGE -->
                      <a href="{{ product.url }}" class="promo-img">
  <img
    src="{{ product.featured_image | img_url: '400x533', crop: 'center' }}"
    alt="{{ product.title | escape }}"
    loading="lazy"
    width="400"
    height="533"
  >
</a>

                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
            
            <!-- IMPROVED PAGINATION -->
            <div class="swiper-pagination"></div>
            
            <!-- VISIBLE NAVIGATION ARROWS -->
            <div class="swiper-button-next">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="swiper-button-prev">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            
            <!-- SLIDER PROGRESS BAR -->
            <div class="slider-progress">
              <div class="slider-progress-bar"></div>
            </div>
          </div>
        </div>
      {% endif %}
    {% endif %}

  </div>
</section>

