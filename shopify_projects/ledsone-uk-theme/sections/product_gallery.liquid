<!-- Gallery Section -->
<div class="gallery-section" style="--desktop-columns: {{ section.settings.desktop_columns | default: 3 }};">
    <div class="gallery-container">
      {% for block in section.blocks %}
        <div class="gallery-item" data-product-handle="{{ block.settings.product.handle }}" data-product-id="{{ block.settings.product.id }}" data-feedback="{{ block.settings.feedback | escape }}" data-rating="{{ block.settings.rating }}">
          <div class="gallery-image-wrapper">
            <img 
              src="{{ block.settings.image | img_url: '800x' }}" 
              alt="{{ block.settings.image.alt | escape }}" 
              class="gallery-image"
              width="800"
              height="800"
              loading="lazy"
            >
            <div class="gallery-overlay">
              <div class="gallery-content">
                {% if block.settings.title != blank %}
                  <h3 class="gallery-title">{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.rating %}
                  <div class="star-rating">
                    {% for i in (1..5) %}
                      {% if i <= block.settings.rating %}
                        <span class="star filled">★</span>
                      {% else %}
                        <span class="star">★</span>
                      {% endif %}
                    {% endfor %}
                  </div>
                {% endif %}
                {% if block.settings.subtitle != blank %}
                  <p class="gallery-subtitle">{{ block.settings.subtitle }}</p>
                {% endif %}
              {%comment %}  <button class="gallery-view-btn">View</button>{%endcomment %}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
  
  <!-- Product Modal -->
  <div class="product-modal" id="productModal">
    <div class="modal-overlay"></div>
    <div class="modal-content">
      <button class="modal-close">&times;</button>
      <div class="modal-body">
        <div class="modal-image">
          <img id="modalImage" src="" alt="">
        </div>
        <div class="modal-details">
          <h2 id="modalTitle"></h2>
          <div class="modal-rating" id="modalRating"></div>
          <div class="product-info">
            <a href="#" class="view-product-btn" id="modalViewProduct" target="_blank">View Product</a>
          </div>
          <div class="customer-feedback">
            <h3>Customer Feedback</h3>
            <p id="modalFeedback"></p>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <style>
    /* Gallery Section Styles */
    .gallery-section {
      padding: 5px 10px;
      max-width: 1400px;
      margin: 0 auto;
    }
    
    .gallery-container {
      display: grid;
      grid-template-columns: repeat(var(--desktop-columns, 3), 1fr);
      gap: 10px;
    }
    
    .gallery-item {
      position: relative;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .gallery-item:hover {
      
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    }
    
    .gallery-image-wrapper {
      position: relative;
      aspect-ratio: 1 / 1;
      overflow: hidden;
    }
    
    .gallery-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
    
    .gallery-item:hover .gallery-image {
      transform: scale(1.05);
    }
    
    .gallery-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(to bottom, rgba(0,0,0,0.1), rgba(0,0,0,0.7));
      display: flex;
      align-items: flex-end;
      padding: 25px;
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    
    .gallery-item:hover .gallery-overlay {
      opacity: 1;
    }
    
    .gallery-content {
      color: white;
      width: 100%;
    }
    
    .gallery-title {
      font-size: 1.4rem;
      margin-bottom: 8px;
      font-weight: 600;
      color:white;
    }
    
    .gallery-subtitle {
      font-size: 0.95rem;
      margin-bottom: 15px;
      opacity: 0.9;
    }
    
    .star-rating {
      display: flex;
      margin-bottom: 10px;
    }
    
    .star {
      color: #ddd;
      font-size: 1.2rem;
      margin-right: 2px;
    }
    
    .star.filled {
      color: #ffc107;
    }
    
    .gallery-view-btn {
      background: white;
      color: #333;
      border: none;
      padding: 5px 10px;
      border-radius: 30px;
      font-weight: 300;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    
    .gallery-view-btn:hover {
      background: #f0f0f0;
      transform: translateY(-2px);
    }
    
    /* Modal Styles */
    .product-modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1000;
      overflow-y: auto;
    }
    
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(5px);
    }
    
    .modal-content {
      position: relative;
      background: white;
      max-width: 900px;
      margin: 40px auto;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
      z-index: 1001;
    }
    
    .modal-close {
      position: absolute;
      top: 15px;
      right: 15px;
      background: rgba(255, 255, 255, 0.8);
      border: none;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      font-size: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 10;
      transition: background 0.3s ease;
    }
    
    .modal-close:hover {
      background: white;
    }
    
    .modal-body {
      display: flex;
      flex-direction: row;
    }
    
    .modal-image {
      flex: 1;
      background: #f9f9f9;
    }
    
    .modal-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .modal-details {
      flex: 1;
      padding: 30px;
    }
    
    .modal-details h2 {
      margin-bottom: 15px;
      font-size: 1.8rem;
    }
    
    .modal-rating {
      margin-bottom: 20px;
    }
    
    .modal-rating .star-rating {
      display: flex;
    }
    
    .modal-rating .star {
      color: #ddd;
      font-size: 1.4rem;
      margin-right: 3px;
    }
    
    .modal-rating .star.filled {
      color: #ffc107;
    }
    
    .view-product-btn {
      display: inline-block;
      width: 100%;
      background: #333;
      color: white;
      text-decoration: none;
      text-align: center;
      padding: 10px;
      border-radius: 6px;
      font-size: 1rem;
      font-weight: 400;
      cursor: pointer;
      transition: background 0.3s ease;
    }
    
    .view-product-btn:hover {
      background: #555;
      color: white;
      text-decoration: none;
    }
    
    .customer-feedback {
      margin-top: 30px;
      padding-top: 25px;
      border-top: 1px solid #eee;
    }
    
    .customer-feedback h3 {
      margin-bottom: 15px;
      font-size: 1.2rem;
    }
    
    .customer-feedback p {
      line-height: 1.6;
      color: #555;
      font-style: italic;
    }
    
    /* Responsive Styles */
    @media (max-width: 768px) {
      .gallery-container {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }
      
      .gallery-section {
        padding: 30px 15px;
      }
      
      .modal-body {
        flex-direction: column;
      }
      
      .modal-image {
        height: 300px;
      }
      
      .modal-details {
        padding: 20px;
      }
      
      .modal-content {
        margin: 20px;
      }
    }
    
    @media (max-width: 480px) {
      .gallery-container {
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
      }
      
      .gallery-overlay {
        padding: 20px;
      }
      
      .gallery-title {
        font-size: 1.2rem;
        color:white;
      }
    }
  </style>
  
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const galleryItems = document.querySelectorAll('.gallery-item');
      const modal = document.getElementById('productModal');
      const modalClose = document.querySelector('.modal-close');
      const modalOverlay = document.querySelector('.modal-overlay');
      
      // Open modal when gallery item is clicked
      galleryItems.forEach(item => {
        item.addEventListener('click', function() {
          const productHandle = this.getAttribute('data-product-handle');
          const productId = this.getAttribute('data-product-id');
          const feedback = this.getAttribute('data-feedback');
          const rating = this.getAttribute('data-rating');
          const imageSrc = this.querySelector('img').src;
          const title = this.querySelector('.gallery-title')?.textContent || '';
          
          // Set modal content
          document.getElementById('modalImage').src = imageSrc;
          document.getElementById('modalTitle').textContent = title;
          document.getElementById('modalFeedback').textContent = feedback;
          
          // Set star rating in modal
          const modalRating = document.getElementById('modalRating');
          if (rating) {
            let starsHtml = '<div class="star-rating">';
            for (let i = 1; i <= 5; i++) {
              if (i <= rating) {
                starsHtml += '<span class="star filled">★</span>';
              } else {
                starsHtml += '<span class="star">★</span>';
              }
            }
            starsHtml += '</div>';
            modalRating.innerHTML = starsHtml;
          } else {
            modalRating.innerHTML = '';
          }
          
          // Load product data and set product link
          loadProductData(productHandle);
          
          // Show modal
          modal.style.display = 'block';
          document.body.style.overflow = 'hidden';
        });
      });
      
      // Close modal
      function closeModal() {
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
      }
      
      modalClose.addEventListener('click', closeModal);
      modalOverlay.addEventListener('click', closeModal);
      
      // Close modal with Escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          closeModal();
        }
      });
      
    // Load product data and set product link
    function loadProductData(productHandle) {
      // Set the product link using Shopify's product URL structure
      if (productHandle) {
        const productLink = `/products/${productHandle}`;
        document.getElementById('modalViewProduct').href = productLink;
        document.getElementById('modalViewProduct').textContent = 'View Product';
      } else {
        // Fallback if no product is selected
        document.getElementById('modalViewProduct').href = '#';
        document.getElementById('modalViewProduct').textContent = 'No Product Selected';
      }
    }
    });
  </script>
  
  {% schema %}
  {
    "name": "Product Gallery",
    "class": "gallery-section",
    "max_blocks": 12,
    "settings": [
      {
        "type": "text",
        "id": "section_title",
        "label": "Section Title",
        "default": "Customer Favorites"
      },
      {
        "type": "range",
        "id": "desktop_columns",
        "label": "Desktop Columns",
        "min": 2,
        "max": 6,
        "step": 1,
        "default": 3
      }
    ],
    "blocks": [
      {
        "type": "gallery_item",
        "name": "Gallery Item",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Product Name"
          },
          {
            "type": "text",
            "id": "subtitle",
            "label": "Subtitle",
            "default": "Product description or category"
          },
          {
            "type": "product",
            "id": "product",
            "label": "Product"
          },
          {
            "type": "textarea",
            "id": "feedback",
            "label": "Customer Feedback",
            "default": "This product exceeded my expectations! The quality is outstanding and it arrived quickly."
          },
          {
            "type": "range",
            "id": "rating",
            "label": "Star Rating",
            "min": 1,
            "max": 5,
            "step": 1,
            "default": 5
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Product Gallery",
        "category": "Gallery"
      }
    ]
  }
  {% endschema %}