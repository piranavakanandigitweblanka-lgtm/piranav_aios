{%- schema -%}
{
  "name": "Image with Timer",
  "settings": [
    {
      "type": "header",
      "content": "Heading Settings"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Weekly Special"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h2",
          "label": "Medium"
        },
        {
          "value": "h1",
          "label": "Large"
        },
        {
          "value": "h3",
          "label": "Small"
        }
      ],
      "default": "h2"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Timer Settings"
    },
    {
      "type": "checkbox",
      "id": "show_timer",
      "label": "Show countdown timer",
      "default": true
    },
    {
      "type": "text",
      "id": "timer_text",
      "label": "Timer text",
      "default": "Offer ends in:"
    },
    {
      "type": "color",
      "id": "timer_text_color",
      "label": "Timer text color",
      "default": "#333333"
    },
    {
      "type": "select",
      "id": "timer_end_day",
      "label": "Timer ends on",
      "options": [
        {
          "value": "0",
          "label": "Sunday"
        },
        {
          "value": "1",
          "label": "Monday"
        },
        {
          "value": "2",
          "label": "Tuesday"
        },
        {
          "value": "3",
          "label": "Wednesday"
        },
        {
          "value": "4",
          "label": "Thursday"
        },
        {
          "value": "5",
          "label": "Friday"
        },
        {
          "value": "6",
          "label": "Saturday"
        }
      ],
      "default": "6",
      "info": "Timer will reset weekly on selected day at midnight"
    },
    {
      "type": "color",
      "id": "timer_background",
      "label": "Timer number background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "timer_number_color",
      "label": "Timer number color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "timer_label_color",
      "label": "Timer label color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Image Links"
    },
    {
      "type": "range",
      "id": "image_links_count",
      "label": "Number of image links",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "image_link",
      "name": "Image Link",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "info": "Description of image for SEO"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with Timer",
      "category": "Image",
      "blocks": [
        {
          "type": "image_link"
        },
        {
          "type": "image_link"
        },
        {
          "type": "image_link"
        },
        {
          "type": "image_link"
        },
        {
          "type": "image_link"
        },
        {
          "type": "image_link"
        }
      ]
    }
  ]
}
{%- endschema -%}

{%- liquid
  assign current_day = 'now' | date: '%w'
  assign timer_end_day = section.settings.timer_end_day | plus: 0
  assign days_remaining = timer_end_day | minus: current_day | times: 86400
  
  if days_remaining <= 0
    assign days_remaining = days_remaining | plus: 604800
  endif
  
  assign end_time = 'now' | date: '%s' | plus: days_remaining
-%}

{%- style -%}
  .image-timer-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
    background-color: {{ section.settings.section_background }};
  }
  .section-heading {
    text-align: center;
    margin-bottom: 30px;
    color: {{ section.settings.heading_color }};
  }
  .timer-container {
    text-align: center;
    margin-bottom: 30px;
  }
  .timer-text {
    font-size: 1.2rem;
    margin-bottom: 10px;
    color: {{ section.settings.timer_text_color }};
  }
  .timer-display {
    display: flex;
    justify-content: center;
    gap: 15px;
  }
  .timer-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .timer-value {
    font-size: 2rem;
    font-weight: bold;
    min-width: 60px;
    padding: 5px 10px;
    background: {{ section.settings.timer_background }};
    color: {{ section.settings.timer_number_color }};
    border-radius: 5px;
  }
  .timer-label {
    font-size: 0.8rem;
    margin-top: 5px;
    text-transform: uppercase;
    color: {{ section.settings.timer_label_color }};
  }
  .image-links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 20px;
  }
  .image-link {
    position: relative;
    overflow: hidden;
    border-radius: 5px;
    transition: transform 0.3s ease;
  }
  .image-link:hover {
    transform: translateY(-5px);
  }
  .image-link img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }
  .image-link:hover img {
    transform: scale(1.05);
  }
  @media (max-width: 749px) {
    .image-links-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{%- endstyle -%}

<div class="image-timer-section">
  {%- if section.settings.show_heading -%}
    <{{ section.settings.heading_size }} class="section-heading">
      {{ section.settings.heading }}
    </{{ section.settings.heading_size }}>
  {%- endif -%}

  {%- if section.settings.show_timer -%}
    <div class="timer-container">
      <div class="timer-text">{{ section.settings.timer_text }}</div>
      <div class="timer-display" data-end-time="{{ end_time }}">
        <div class="timer-unit">
          <div class="timer-value" data-days>00</div>
          <div class="timer-label">Days</div>
        </div>
        <div class="timer-unit">
          <div class="timer-value" data-hours>00</div>
          <div class="timer-label">Hours</div>
        </div>
        <div class="timer-unit">
          <div class="timer-value" data-minutes>00</div>
          <div class="timer-label">Minutes</div>
        </div>
        <div class="timer-unit">
          <div class="timer-value" data-seconds>00</div>
          <div class="timer-label">Seconds</div>
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="image-links-grid">
    {%- for block in section.blocks limit: section.settings.image_links_count -%}
      <a href="{{ block.settings.link }}" class="image-link" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | img_url: '600x' }}" 
               alt="{{ block.settings.alt_text | escape }}" 
               loading="lazy" 
               width="600" 
               height="{{ 600 | divided_by: block.settings.image.aspect_ratio | round }}">
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const timerDisplay = document.querySelector('.timer-display');
    if (!timerDisplay) return;

    const endTime = parseInt(timerDisplay.dataset.endTime) * 1000;
    
    function updateTimer() {
      const now = new Date().getTime();
      const distance = endTime - now;
      
      if (distance < 0) {
        // Timer has ended, reload page to reset timer
        window.location.reload();
        return;
      }
      
      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);
      
      if (timerDisplay.querySelector('[data-days]')) {
        timerDisplay.querySelector('[data-days]').textContent = String(days).padStart(2, '0');
      }
      if (timerDisplay.querySelector('[data-hours]')) {
        timerDisplay.querySelector('[data-hours]').textContent = String(Math.floor(hours)).padStart(2, '0');
      }
      if (timerDisplay.querySelector('[data-minutes]')) {
        timerDisplay.querySelector('[data-minutes]').textContent = String(Math.floor(minutes)).padStart(2, '0');
      }
      if (timerDisplay.querySelector('[data-seconds]')) {
        timerDisplay.querySelector('[data-seconds]').textContent = String(Math.floor(seconds)).padStart(2, '0');
      }
    }
    
    updateTimer();
    const timerInterval = setInterval(updateTimer, 1000);
  });
</script>