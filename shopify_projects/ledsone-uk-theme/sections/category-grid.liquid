{% comment %}
  Section: Category Image Grid (1 Large + 4 Small)
{% endcomment %}

<section class="category-grid-section">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <div class="section-header">
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}
    
    <div class="category-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}"
           class="grid-item {% if block.settings.is_large %}grid-large{% else %}grid-small{% endif %}"
           {{ block.shopify_attributes }}>

 {% if block.settings.image != blank %}
  {% liquid
    assign img = block.settings.image

    if block.settings.is_large
      assign img_width = 900
      assign img_sizes = '(max-width: 768px) 100vw, 66vw'
    else
      assign img_width = 500
      assign img_sizes = '(max-width: 768px) 50vw, 33vw'
    endif
  %}

  <img
    src="{{ img | image_url: width: img_width }}"
    srcset="
      {{ img | image_url: width: 200 }} 200w,
      {{ img | image_url: width: 400 }} 400w,
      {{ img | image_url: width: 600 }} 600w,
      {{ img | image_url: width: 900 }} 900w
    "
    sizes="{{ img_sizes }}"
    width="{{ img.width }}"
    height="{{ img.height }}"
     {% if forloop.index <= 3 %}
      loading="eager"
      fetchpriority="high"
    {% else %}
    loading="lazy"
     {% endif %}
    alt="{{ block.settings.title | escape }}"
  >
{% endif %}


          <span class="grid-title">{{ block.settings.title }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  /* ===== 1600px Desktop Container ===== */
  .category-grid-section .page-width {
    max-width: 1450px;
    margin: 0 auto;
    padding-left: 24px;
    padding-right: 24px;
  }

  @media (max-width: 768px) {
    .category-grid-section .page-width {
      padding-left: 16px;
      padding-right: 16px;
    }
  }

  .category-grid-section {
    background: #fff;
    padding: 40px 0 20px;
  }

  /* Section Header Styles */
  .section-header {
    text-align: center;
    margin-bottom: 30px;
  }

  .section-heading {
    font-size: 32px;
    font-weight: 600;
    color: #111;
    margin: 0;
    line-height: 1.2;
  }

  @media (max-width: 768px) {
    .section-heading {
      font-size: 24px;
    }
  }

  /* Grid Styles */
  .category-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: repeat(2, minmax(0, 1fr));
    gap: 10px;
    {% comment %} box-shadow: 0 4px 20px rgb(28 22 22 / 44%); {% endcomment %}
  }

  .grid-item {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 8px;
    text-decoration: none;
    background: #f8f8f8;
  }

  .grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

 

  .grid-large {
    grid-row: span 2;
  }

  /* Title placement – Lights.co.uk style */
  .grid-title {
    position: absolute;
    left: 16px;
    bottom: 16px;
    padding: 6px 12px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 6px;
    font-size: 15px;
    font-weight: 500;
    color: #111;
    line-height: 1.2;
  }

  /* ===== Mobile Grid Logic (Large first, then 2x2 grid) ===== */
  @media (max-width: 768px) {
    .category-grid {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: auto;
      gap: 8px;
      padding-right:5px;
      padding-left:5px;
    }

    /* Large tile full width and first */
    .grid-large {
      grid-column: span 2;
      order: -1;
      height: 250px;
    }

    /* Small tiles - will naturally flow 2 per row */
    .grid-small {
      height: 180px;
    }

    /* Ensure all small items are same height */
    .grid-small:nth-child(2),
    .grid-small:nth-child(3),
    .grid-small:nth-child(4),
    .grid-small:nth-child(5),
    .grid-small:nth-child(6) {
      height: 180px;
    }

    .grid-title {
      left: 12px;
      bottom: 12px;
      font-size: 14px;
      padding: 6px 10px;
    }
  }
</style>

{% schema %}
{
  "name": "Category Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "is_large",
          "label": "Make this the large item",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Category Grid",
      "settings": {
        "heading": "Shop by Category"
      },
      "blocks": [
        { "type": "category", "settings": { "is_large": true } },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}