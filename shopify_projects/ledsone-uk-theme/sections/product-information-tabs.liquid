<div id="dec" style="margin-left:5%; margin-right:5%;">
{% # theme-check-disable ContentForHeaderModification %}
{%- capture contentForQuerystring -%}
  {{ content_for_header }}
{%- endcapture -%}
{% # theme-check-enable ContentForHeaderModification %}
{%- assign pageUrl = contentForQuerystring
  | split: '"pageurl":"'
  | last
  | split: '"'
  | first
  | split: request.host
  | last
  | replace: '\/', '/'
  | replace: '%20', ' '
  | replace: '\u0026', '&'
-%}
{%- assign pageQuerystring = pageUrl | split: '?' | last -%}
{%- liquid
  assign st = section.settings
  assign design = st.design
  assign bg_color = st.bg_color
  assign custom_class = st.custom_class
  if pageQuerystring contains 'tab_info='
    assign tab = pageQuerystring | split: 'tab_info=' | last | split: '&' | first
    if tab == 'tab' or tab == 'accordition' or tab == 'show_all'
      assign design = tab
    endif
  endif
  assign position = st.position
  if pageQuerystring contains 'position_tab='
    assign position_tab = pageQuerystring | split: 'position_tab=' | last | split: '&' | first
    if position_tab == 'default'
      assign position = '1'
    elsif position_tab == 'accordions-inner'
      assign position = '2'
    endif
  endif
-%}
{%- capture style -%}
  {%- if bg_color != blank -%}--section-bg-color: {{ bg_color }};{%- endif -%}
{%- endcapture -%}
{%- if section.blocks.size > 0 -%}
  <div
    id="{{ section.id }}"
    class="bls__section {{ custom_class }} bls__product-tabs design-{{design}}{% if design == 'accordition' and position == '2' %} inside-product-main-infomation d-none{% endif %}"
    data-section-type="tabs"
    style="{{ style | strip | strip_newlines }}"
    data-section-id="{{ section.id }}"
  >
    <div class="{{ st.layout }}">
      <div class="product info detailed">
        <div class="product data items">
          {%- if design == 'tab' or design == 'accordition' -%}
            {%- if design == 'tab' -%}
              <ul class="nav nav-tabs list-none text-center pl-0 flex flex-wrap justify-content-center mb-40 mt-0">
                {%- for block in section.blocks %}
                  {% assign bk_st = block.settings %}
                  {% assign bk_id = block.id -%}
                  <li class="data item{% if forloop.first %} active{% endif %}">
                    <a
                      class="is-nav-tabs heading-weight relative heading-color px-30 py-10 inline-block"
                      href="#{{ block.id }}"
                      data-block-id="proTabs{{ block.id }}"
                      {%- if block.type == 'review' -%}
                        tab-review
                      {%- endif -%}
                    >
                      {{- bk_st.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
            <div class="tab-content">
              {%- for block in section.blocks %}
                {% assign bk_st = block.settings %}
                {% assign bk_id = block.id -%}
                <div
                  id="proTabs{{ block.id }}"
                  class="tab-item{% if forloop.first and design == 'accordition' and st.open_first_tab %} active{% endif %}{% if forloop.first and design == 'tab' %} active{% endif %}"
                >
                  <div class="data item title" id="tab-label-{{ bk_id }}">
                    <a
                      class="data accordition relative flex align-items-center"
                      href="javascript:;"
                      data-block-id="proTabs{{ block.id }}"
                      aria-label="Toogle"
                      {%- if block.type == 'review' -%}
                        tab-review
                      {%- endif -%}
                    >
                      <span class="txt_h_tab d-blokc w-full heading-color heading-weight">
                        {{- bk_st.title -}}
                      </span>
                      <span class="open-children-toggle"></span>
                    </a>
                  </div>
                  <div
                    class="tab-panel"
                    {% if forloop.first and design == 'accordition' and st.open_first_tab %}
                      style="display: block;"
                    {% endif -%}
                    {% if forloop.first and design == 'tab' %}
                      style="display: block;"
                    {% endif %}
                  >
                    {%- case block.type -%}
                      {%- when 'description' -%}
                         {% comment %}piranav disable defalut description on 2025.09.15
                        {{ product.description }}
                          {% endcomment %}

{% comment %}start the dynamic description{% endcomment %}
                        <div id="dynamic-variant-description">
    {% if product.selected_or_first_available_variant.metafields.custom.variant_description %}
      {{ product.selected_or_first_available_variant.metafields.custom.variant_description | metafield_tag }}
    {% else %}
      {{ product.description }}
    {% endif %}
  </div>
{% comment %}end the dynamic description{% endcomment %}

                      {%- when 'review' -%}
                    <!-- Start of Judge.me code -->
      <div style='clear:both'></div>
      <div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-product-title='{{ product.title | escape }}' data-id='{{ product.id }}' data-auto-install='false'>
        {{ product.metafields.judgeme.widget }}
      </div>
      <!-- End of Judge.me code -->
                        <div id="shopify-product-reviews" data-id="{{ product.id }}">
                          {{ product.metafields.spr.reviews }}
                        </div>
                      {%- when 'custom_tab' -%}
                        {% assign tab_content = bk_st.tab_content %}
                        {%- case tab_content -%}
                          {%- when 'content' -%}
                            {{ bk_st.content }}
                          {%- when 'content_page' -%}
                            {%- if bk_st.page != blank -%}
                              {{ pages[bk_st.page].content }}
                            {%- endif -%}
                        {%- endcase -%}
                    {%- endcase -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- else -%}
            {%- for block in section.blocks %}
              {% assign bk_st = block.settings %}
              {% assign bk_id = block.id -%}
              <div
                class="tab-content-all"
                {%- if block.type == 'review' -%}
                  tab-review
                {%- endif -%}
              >
                <div class="data item title" id="tab-label-{{ bk_id }}">
                  <h4 id="tab-label-{{ bk_id }}-title">
                    {{ bk_st.title }}
                  </h4>
                </div>
                <div class="tab-panel">
                  {%- case block.type -%}
                    {%- when 'description' -%}
                       {% comment %}piranav disable defalut description on 2025.09.15
                      {{ product.description }}
                        {% endcomment %}

{% comment %}start the dynamic description{% endcomment %}
                        <div id="dynamic-variant-description">
    {% if product.selected_or_first_available_variant.metafields.custom.variant_description %}
      {{ product.selected_or_first_available_variant.metafields.custom.variant_description | metafield_tag }}
    {% else %}
      {{ product.description }}
    {% endif %}
  </div>
{% comment %}end the dynamic description{% endcomment %}


                    {%- when 'review' -%}
                      <div id="shopify-product-reviews" data-id="{{ product.id }}">
                        {{ product.metafields.spr.reviews }}
                      </div>
                    {%- when 'custom_tab' -%}
                      {% assign tab_content = bk_st.tab_content %}
                      {%- case tab_content -%}
                        {%- when 'content' -%}
                          {{ bk_st.content }}
                        {%- when 'content_page' -%}
                          {%- if bk_st.page != blank -%}
                            {{ pages[bk_st.page].content }}
                          {%- endif -%}
                      {%- endcase -%}
                  {%- endcase -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}
</div>
{% schema %}
{
  "name": "Product information tabs",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "container",
      "options": [
        {
          "value": "container",
          "label": "Default"
        },
        {
          "value": "container-fluid",
          "label": "Fluid container"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ]
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color"
    },
    {
      "type": "select",
      "id": "design",
      "label": "Design",
      "default": "accordition",
      "options": [
        {
          "value": "tab",
          "label": "Tabs"
        },
        {
          "value": "accordition",
          "label": "Accordition"
        },
        {
          "value": "show_all",
          "label": "Show open all"
        }
      ]
    },
    {
      "type": "select",
      "id": "position",
      "label": "Position (only for accordition)",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "Default"
        },
        {
          "value": "2",
          "label": "Inside Product main infomation"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "open_first_tab",
      "label": "Enable auto open first tab",
      "info": "Only working with layout 'Accordion'",
      "default": true
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    }
  ],
  "blocks": [
    {
      "type": "description",
      "name": "Description",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Description"
        }
      ]
    },
    {
      "type": "review",
      "name": "Review",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Review"
        }
      ]
    },
    {
      "type": "custom_tab",
      "name": "Custom tab",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Custom Tab"
        },
        {
          "type": "select",
          "id": "tab_content",
          "label": "Tab content",
          "default": "content",
          "options": [
            {
              "value": "content",
              "label": "Content"
            },
            {
              "value": "content_page",
              "label": "Content page"
            }
          ]
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Tab content",
          "default": "<p></p>"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Tab content from page"
        }
      ]
    }
  ]
}
{% endschema %}
