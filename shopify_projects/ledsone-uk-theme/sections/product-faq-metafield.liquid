{%- liquid
  assign st = section.settings
  assign text_align = st.text_alignment
  assign heading = st.heading
  assign description = st.description
  assign bg_color = st.background_color
  assign container = st.container
  assign enabled_animations = settings.animations_enabled

  # Metafield source
  # Primary: Metaobject list from product.metafields.custom.faq
  assign faq_metafield = product.metafields.custom.faq.value
-%}

{{ 'faqs.css' | asset_url | stylesheet_tag }}

{%- capture style -%}
  {%- if bg_color != blank -%}
    --section-bg-color: {{ bg_color }};
  {%- endif -%}
  --section-padding-top: {{ st.padding_top }}px; 
  --section-padding-bottom: {{ st.padding_bottom }}px;
{%- endcapture -%}

<section
  class="bls__section bls__faq-metafield {{ st.custom_class }}"
  style="{{ style | strip | strip_newlines }}"
  id="{{ section.id }}"
  data-section-type="faq-metafield"
  data-section-id="{{ section.id }}"
>
  <div class="{{ container }}">
    {%- if heading != blank or description != blank -%}
      <div class="bls__section-header {{ text_align }} {% if enabled_animations %}scroll-trigger animate--slide-in{% endif %}">
        {%- if heading != blank -%}
          <h2 class="bls__section-heading mb-10">{{ heading }}</h2>
        {%- endif -%}
        {%- if description != blank -%}
          <div class="bls__section-des">
            {{ description }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="bls__faq-container">
      {%- liquid
        assign has_content = false
        assign render_generated_schema = true
      -%}

      {%- # Metafield Items -%}
      {%- if faq_metafield != blank -%}
        {%- for item in faq_metafield -%}
          {%- liquid
            assign question = item.question | default: item.title
            assign answer = item.answer | default: item.content
          -%}
          {%- if question != blank and answer != blank -%}
            {%- assign has_content = true -%}
            <div class="bls__page-faq-items bls-toggle relative {% if enabled_animations %}scroll-trigger animate--slide-in{% endif %}" style="--animation-order: {{ forloop.index }};">
              <h4 class="bls__page-faq-title fs-18 border-bottom py-20 mb-0 relative cursor-pointer flex align-items-center justify-content-between">
                <span>{{ question }}</span>
                <span class="open-children-toggle d-block-important"></span>
              </h4>
              <div class="bls__page-faq-content overflow-hidden py-20" style="display: none">
                <div class="rich-text-content">
                  {{ answer | metafield_tag }}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- # Manual Block Items (as backup or additional) -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.title != blank and block.settings.content != blank -%}
          {%- assign has_content = true -%}
          <div class="bls__page-faq-items bls-toggle relative {% if enabled_animations %}scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}>
            <h4 class="bls__page-faq-title fs-18 border-bottom py-20 mb-0 relative cursor-pointer flex align-items-center justify-content-between">
              <span>{{ block.settings.title }}</span>
              <span class="open-children-toggle d-block-important"></span>
            </h4>
            <div class="bls__page-faq-content overflow-hidden py-20" style="display: none">
              <div class="rich-text-content">
                {{ block.settings.content }}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- # Parse custom schema metafield if it exists -%}
      {%- assign custom_faq_schema = product.metafields.custom.faq_schema -%}
      {%- if custom_faq_schema != blank -%}
        {%- assign schema_str = custom_faq_schema | strip -%}
        {%- if schema_str contains '<script' -%}
          <div id="faq-schema-raw-{{ section.id }}" style="display: none;">
            {{ custom_faq_schema }}
          </div>
          {%- assign has_content = true -%}
          {%- assign render_generated_schema = false -%}
          <div id="bls__dynamic-schema-faq-{{ section.id }}"></div>
          
          <script>
            document.addEventListener("DOMContentLoaded", function() {
              const rawContainer = document.getElementById('faq-schema-raw-{{ section.id }}');
              if (!rawContainer) return;

              const scriptTags = rawContainer.querySelectorAll('script[type="application/ld+json"]');
              let html = '';
              
              scriptTags.forEach(scriptTag => {
                try {
                  const faqJson = JSON.parse(scriptTag.innerHTML);
                  if (faqJson && faqJson.mainEntity) {
                    faqJson.mainEntity.forEach((item) => {
                      if (item['@type'] === 'Question') {
                        const q = item.name || '';
                        const a = (item.acceptedAnswer && item.acceptedAnswer.text) ? item.acceptedAnswer.text : '';
                        if (q && a) {
                          html += `
                            <div class="bls__page-faq-items bls-toggle relative scroll-trigger animate--slide-in">
                              <h4 class="bls__page-faq-title fs-18 border-bottom py-20 mb-0 relative cursor-pointer flex align-items-center justify-content-between">
                                <span>${q}</span>
                                <span class="open-children-toggle d-block-important"></span>
                              </h4>
                              <div class="bls__page-faq-content overflow-hidden py-20" style="display: none">
                                <div class="rich-text-content">
                                  ${a}
                                </div>
                              </div>
                            </div>
                          `;
                        }
                      }
                    });
                  }
                } catch (e) {
                  console.error("Failed to parse FAQ schema", e);
                }
              });

              if (html) {
                const container = document.getElementById('bls__dynamic-schema-faq-{{ section.id }}');
                if (container) {
                  container.innerHTML = html;
                  const generatedItems = container.querySelectorAll('.bls__page-faq-items');
                  generatedItems.forEach((item) => {
                    const title = item.querySelector('.bls__page-faq-title');
                    const content = item.querySelector('.bls__page-faq-content');
                    title.addEventListener('click', () => {
                      const isOpen = item.classList.contains('active');
                      if (isOpen) {
                        item.classList.remove('active');
                        if (typeof jQuery !== 'undefined') $(content).slideUp();
                        else content.style.display = 'none';
                      } else {
                        item.classList.add('active');
                        if (typeof jQuery !== 'undefined') $(content).slideDown();
                        else content.style.display = 'block';
                      }
                    });
                  });
                }
              }
            });
          </script>
        {%- else -%}
          {%- comment -%} Handle if it is a JSON type metafield {%- endcomment -%}
          {%- assign schema_obj = custom_faq_schema.value | default: custom_faq_schema -%}
          {%- if schema_obj.mainEntity != blank -%}
            {%- assign render_generated_schema = false -%}
            <script type="application/ld+json">
              {{ schema_obj | json }}
            </script>
            {%- for item in schema_obj.mainEntity -%}
              {%- if item['@type'] == 'Question' -%}
                {%- assign has_content = true -%}
                <div class="bls__page-faq-items bls-toggle relative {% if enabled_animations %}scroll-trigger animate--slide-in{% endif %}" style="--animation-order: {{ forloop.index }};">
                  <h4 class="bls__page-faq-title fs-18 border-bottom py-20 mb-0 relative cursor-pointer flex align-items-center justify-content-between">
                    <span>{{ item.name }}</span>
                    <span class="open-children-toggle d-block-important"></span>
                  </h4>
                  <div class="bls__page-faq-content overflow-hidden py-20" style="display: none">
                    <div class="rich-text-content">
                      {{ item.acceptedAnswer.text }}
                    </div>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}

      {%- if has_content == false and request.design_mode -%}
        <div class="alert alert-info text-center p-20">
          <p>No FAQ data found.</p>
          <p><small>Link a Metaobject list to <strong>product.metafields.custom.faq_list</strong> or add manual blocks below.</small></p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{%- if has_content and render_generated_schema -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- liquid
      assign schema_output = ""
      if faq_metafield != blank
        for item in faq_metafield
          assign q = item.question | default: item.title
          assign a = item.answer | default: item.content | metafield_tag | strip_html | strip_newlines | escape
          if q != blank and a != blank
            capture item_json
              echo '{"@type":"Question","name":' | append: q | json | append: ',"acceptedAnswer":{"@type":"Answer","text":' | append: a | json | append: '}}'
            endcapture
            if schema_output != ""
              assign schema_output = schema_output | append: ","
            endif
            assign schema_output = schema_output | append: item_json
          endif
        endfor
      endif

      for block in section.blocks
        assign q = block.settings.title
        assign a = block.settings.content | strip_html | strip_newlines | escape
        if q != blank and a != blank
          capture item_json
            echo '{"@type":"Question","name":' | append: q | json | append: ',"acceptedAnswer":{"@type":"Answer","text":' | append: a | json | append: '}}'
          endcapture
          if schema_output != ""
            assign schema_output = schema_output | append: ","
          endif
          assign schema_output = schema_output | append: item_json
        endif
      endfor
      echo schema_output
    -%}
  ]
}
</script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqSection = document.getElementById('{{ section.id }}');
    if (!faqSection) return;

    const items = faqSection.querySelectorAll('.bls__page-faq-items');
    items.forEach(item => {
      const title = item.querySelector('.bls__page-faq-title');
      const content = item.querySelector('.bls__page-faq-content');
      
      title.addEventListener('click', () => {
        const isOpen = item.classList.contains('active');
        
        // Close others if you want accordion behavior (optional)
        // items.forEach(i => { i.classList.remove('active'); i.querySelector('.bls__page-faq-content').style.display = 'none'; });

        if (isOpen) {
          item.classList.remove('active');
          if (typeof jQuery !== 'undefined') {
            $(content).slideUp();
          } else {
            content.style.display = 'none';
          }
        } else {
          item.classList.add('active');
          if (typeof jQuery !== 'undefined') {
            $(content).slideDown();
          } else {
            content.style.display = 'block';
          }
        }
      });
    });
  });
</script>
{%- endif -%}

{% schema %}
{
  "name": "Product FAQ (Metafield)",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product FAQs"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Find answers to common questions about this product below.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Header Alignment",
      "default": "text-center",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Center" },
        { "value": "text-right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Layout & Styling"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Layout",
      "default": "container",
      "options": [
        { "value": "container", "label": "Default" },
        { "value": "container-fluid", "label": "Fluid Container" },
        { "value": "full-width", "label": "Full Width" }
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 30,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 30,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item (Manual)",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product FAQ (Metafield/Items)",
      "blocks": [
        { "type": "faq_item" }
      ]
    }
  ]
}
{% endschema %}
