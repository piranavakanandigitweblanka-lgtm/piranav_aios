{% schema %}
{
  "name": "Square Promo Grid",
  "settings": [
    {
      "type": "number",
      "id": "section_max_width",
      "label": "Max Section Width (px)",
      "default": 1800
    },
    {
      "type": "number",
      "id": "section_padding",
      "label": "Section Padding (px)",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "promo_image",
      "name": "Promo Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "promo_image",
          "label": "Promo Image"
        },
        {
          "type": "url",
          "id": "promo_link",
          "label": "Promo Link"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Square Promo Grid (5 images)",
      "category": "Custom",
      "blocks": [
        { "type": "promo_image" },
        { "type": "promo_image" },
        { "type": "promo_image" },
        { "type": "promo_image" },
        { "type": "promo_image" }
      ]
    }
  ]
}
{% endschema %}

<style>
.image-promo-wrapper {
  max-width: {{ section.settings.section_max_width }}px;
  margin: 0 auto;
  padding: {{ section.settings.section_padding }}px;
  box-sizing: border-box;
}

.image-promo-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
}

.image-promo-item {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: 8px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.08);
  transition: transform 0.3s ease;
}

.image-promo-item:hover {
  transform: scale(1.02);
}

.image-promo-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
</style>

<div class="image-promo-wrapper">
  <div class="image-promo-grid">
    {% for block in section.blocks %}
      {% if block.settings.promo_image != blank %}
        <a href="{{ block.settings.promo_link }}" class="image-promo-item">
          {{ block.settings.promo_image | image_url: width: 600 | image_tag: alt: "Promo" }}
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>
