<style>
  /* =========================================================
   Wholesale Trendy Discovery — wholesale-trendy-discovery.css
   Place this file in: assets/
   ========================================================= */

  .wholesale-trendy-discovery {
    background: #FFFFFF;
  }

  .wholesale-trendy-discovery .page-width {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  /* ── Header ── */
  .wtd-header {
    display: flex;
    align-items: center;
    gap: 10px;

  }

  .wtd-heading {
    font-size: clamp(18px, 2.2vw, 24px);
    font-weight: 500;
    white-space: nowrap;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }

  .wtd-line {
    flex: 1;
    height: 1px;
    background: #d0cec9;
    display: block;
  }

  /* ── Grids ── */
  .wtd-grid--top {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .wtd-grid--bottom {
    display: grid;
    grid-template-columns: repeat(3, 1fr) 280px;
    gap: 14px;
    margin-top: 14px;
    align-items: start;
  }

  /* ── Collection card ── */
  .wtd-card {
    display: block;
    background: #ffffff;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.26s ease, box-shadow 0.26s ease;
  }

  .wtd-card:hover {

    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.09);
  }

  /* ── Card image block ── */
  .wtd-card__images {
    display: flex;
    height: 210px;
    gap: 3px;
    background: #e8e4de;
    overflow: hidden;
  }

  .wtd-card__img-main {
    flex: 0 0 60%;
    overflow: hidden;
  }

  .wtd-card__img-stack {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .wtd-card__img-stack-top,
  .wtd-card__img-stack-bottom {
    flex: 1;
    overflow: hidden;
  }

  .wtd-card__images img,
  .wtd-card__images .wtd-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.38s ease;
  }

  .wtd-card:hover .wtd-card__images img {
    transform: scale(1.05);
  }

  /* Shopify placeholder SVG */
  .wtd-placeholder {
    background: #e8e4de;
    fill: #ccc9c3;
  }

  /* ── Card info ── */
  .wtd-card__info {
    padding: 11px 13px 13px;
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .wtd-card__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #7c3aed;
    flex-shrink: 0;
    margin-top: 4px;
    display: block;
  }

  .wtd-card__title {
    display: block;
    font-size: 13.5px;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1.4;
  }

  .wtd-card__count {
    display: block;
    font-size: 11.5px;
    color: #4b5563;
    margin-top: 2px;
  }

  /* ── Quick links panel ── */
  .wtd-quicklinks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: #ffffff;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid #ede9e3;
    grid-column: span var(--desktop-span, 1);
  }

  .wtd-quicklinks__link {
    display: block;
    padding: 13px 14px;
    font-size: 12.5px;
    font-weight: 400;
    color: #374151;
    text-decoration: none;
    border-bottom: 1px solid #ede9e3;
    border-right: 1px solid #ede9e3;
    transition: background 0.16s, color 0.16s;
    line-height: 1.3;
  }

  .wtd-quicklinks__link:hover {
    background: #f5f3ef;
    color: #1a1a1a;
  }

  .wtd-quicklinks__link:nth-child(even) {
    border-right: none;
  }

  .wtd-quicklinks__link:nth-last-child(-n + 2) {
    border-bottom: none;
  }

  /* If "View More" is the only last item (odd total), span full width */
  .wtd-quicklinks__link:last-child:nth-child(odd) {
    grid-column: span 2;
    border-right: none;
  }

  .wtd-quicklinks__link--more {
    font-weight: 500;
    color: #222;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Responsive ── */
  @media screen and (max-width: 1100px) {
    .wtd-grid--top {
      grid-template-columns: repeat(2, 1fr);
    }
    .wtd-grid--bottom {
      grid-template-columns: repeat(2, 1fr);
    }
    .wtd-quicklinks {
      grid-column: span var(--mobile-span, 1);
    }
  }

  @media screen and (max-width: 600px) {
    .wtd-grid--top,
    .wtd-grid--bottom {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .wtd-quicklinks {
      grid-column: span var(--mobile-span, 1);
    }
    .wtd-card__images {
      height: 140px;
    }
    .wtd-card__info {
      padding: 8px 10px 10px;
    }
    .wtd-card__title {
      font-size: 12px;
    }
    .wtd-card__count {
      font-size: 10px;
    }
  }
</style>

<section
  class="wholesale-trendy-discovery"
  id="shopify-section-{{ section.id }}"
  style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="wtd-header">
        <h2 class="wtd-heading">{{ section.settings.heading }}</h2>
        <span class="wtd-line"></span>
      </div>
    {%- endif -%}

    {%- comment -%} Separate collection blocks from quick-link blocks {%- endcomment -%}
    {%- assign collection_blocks = section.blocks | where: 'type', 'collection' -%}
    {%- assign quicklink_blocks = section.blocks | where: 'type', 'quick_link' -%}
    {%- assign view_more_url = section.settings.view_more_url -%}
    {%- assign view_more_label = section.settings.view_more_label | default: 'VIEW MORE >>' -%}

    {%- comment -%} ── TOP ROW: first 4 collection cards ── {%- endcomment -%}
    {%- assign top_blocks = collection_blocks | slice: 0, 4 -%}
    {%- if top_blocks.size > 0 -%}
      <div class="wtd-grid wtd-grid--top">
        {%- for block in top_blocks -%}
          {%- assign col = collections[block.settings.collection] -%}
          {%- assign products = col.products -%}

          {%- assign img1 = block.settings.manual_image_1 | default: products[0].featured_image -%}
          {%- assign img2 = block.settings.manual_image_2 | default: products[1].featured_image -%}
          {%- assign img3 = block.settings.manual_image_3 | default: products[2].featured_image -%}

          {%- comment -%} Fallback: use collection image if no manual/product images {%- endcomment -%}
          {%- if img1 == blank -%}{%- assign img1 = col.image -%}{%- endif -%}

          {%- assign custom_label = block.settings.custom_label -%}
          {%- if custom_label == blank -%}
            {%- assign custom_label = col.products_count | append: '+ Products' -%}
          {%- endif -%}

          <a
            class="wtd-card"
            href="{{ col.url }}?ref=wholesale_trendy"
            {{ block.shopify_attributes }}
            aria-label="{{ col.title | escape }}"
          >
            <div class="wtd-card__images">
              <div class="wtd-card__img-main">
                {%- if img1 != blank -%}
                  <img
                    src="{{ img1 | image_url: width: 480, height: 440, crop: 'center' }}"
                    srcset="
                      {{ img1 | image_url: width: 240, height: 220, crop: 'center' }} 240w,
                      {{ img1 | image_url: width: 480, height: 440, crop: 'center' }} 480w
                    "
                    sizes="(max-width: 560px) 60vw, (max-width: 1024px) 30vw, 15vw"
                    alt="{{ img1.alt | default: col.title | escape }}"
                    width="480"
                    height="440"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'wtd-placeholder' }}
                {%- endif -%}
              </div>

              <div class="wtd-card__img-stack">
                <div class="wtd-card__img-stack-top">
                  {%- if img2 != blank -%}
                    <img
                      src="{{ img2 | image_url: width: 240, height: 220, crop: 'center' }}"
                      alt="{{ img2.alt | default: col.title | escape }}"
                      width="240"
                      height="220"
                      loading="lazy"
                    >
                  {%- elsif img1 != blank -%}
                    <img
                      src="{{ img1 | image_url: width: 240, height: 220, crop: 'center' }}"
                      alt="{{ img1.alt | default: col.title | escape }}"
                      width="240"
                      height="220"
                      loading="lazy"
                    >
                  {%- else -%}
                    {{ 'collection-2' | placeholder_svg_tag: 'wtd-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="wtd-card__img-stack-bottom">
                  {%- if img3 != blank -%}
                    <img
                      src="{{ img3 | image_url: width: 240, height: 220, crop: 'center' }}"
                      alt="{{ img3.alt | default: col.title | escape }}"
                      width="240"
                      height="220"
                      loading="lazy"
                    >
                  {%- elsif img1 != blank -%}
                    <img
                      src="{{ img1 | image_url: width: 240, height: 220, crop: 'center' }}"
                      alt="{{ img1.alt | default: col.title | escape }}"
                      width="240"
                      height="220"
                      loading="lazy"
                    >
                  {%- else -%}
                    {{ 'collection-3' | placeholder_svg_tag: 'wtd-placeholder' }}
                  {%- endif -%}
                </div>
              </div>
            </div>

            <div class="wtd-card__info">
              <span class="wtd-card__dot"></span>
              <div class="wtd-card__info-text">
                <span class="wtd-card__title">{{ col.title | escape }}</span>
                <span class="wtd-card__count">{{ custom_label }}</span>
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── BOTTOM ROW: next 3 collection cards + quick links panel ── {%- endcomment -%}
    {%- assign bottom_blocks = collection_blocks | slice: 4, 3 -%}
    {%- if bottom_blocks.size > 0 or quicklink_blocks.size > 0 -%}
      {%- comment -%} Calculate dynamic span to fill space {%- endcomment -%}
      {%- assign b_size = bottom_blocks.size -%}
      {%- assign d_span = 4 | minus: b_size | at_least: 1 -%}
      {%- assign m_mod = b_size | modulo: 2 -%}
      {%- if m_mod == 0 -%}{%- assign m_span = 2 -%}{%- else -%}{%- assign m_span = 1 -%}{%- endif -%}

      <div class="wtd-grid wtd-grid--bottom">
        {%- for block in bottom_blocks -%}
          {%- assign col = collections[block.settings.collection] -%}
          {%- assign products = col.products -%}

          {%- assign img1 = block.settings.manual_image_1 | default: products[0].featured_image -%}
          {%- assign img2 = block.settings.manual_image_2 | default: products[1].featured_image -%}
          {%- assign img3 = block.settings.manual_image_3 | default: products[2].featured_image -%}

          {%- if img1 == blank -%}{%- assign img1 = col.image -%}{%- endif -%}

          {%- assign custom_label = block.settings.custom_label -%}
          {%- if custom_label == blank -%}
            {%- assign custom_label = col.products_count | append: '+ Products' -%}
          {%- endif -%}

          <a
            class="wtd-card"
            href="{{ col.url }}?ref=wholesale_trendy"
            {{ block.shopify_attributes }}
            aria-label="{{ col.title | escape }}"
          >
            <div class="wtd-card__images">
              <div class="wtd-card__img-main">
                {%- if img1 != blank -%}
                  <img
                    src="{{ img1 | image_url: width: 480, height: 440, crop: 'center' }}"
                    srcset="
                      {{ img1 | image_url: width: 240, height: 220, crop: 'center' }} 240w,
                      {{ img1 | image_url: width: 480, height: 440, crop: 'center' }} 480w
                    "
                    sizes="(max-width: 560px) 60vw, (max-width: 1024px) 30vw, 15vw"
                    alt="{{ img1.alt | default: col.title | escape }}"
                    width="480"
                    height="440"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'wtd-placeholder' }}
                {%- endif -%}
              </div>
              <div class="wtd-card__img-stack">
                <div class="wtd-card__img-stack-top">
                  {%- if img2 != blank -%}
                    <img
                      src="{{ img2 | image_url: width: 240, height: 220, crop: 'center' }}"
                      alt="{{ img2.alt | default: col.title | escape }}"
                      width="240"
                      height="220"
                      loading="lazy"
                    >
                  {%- elsif img1 != blank -%}
                    <img
                      src="{{ img1 | image_url: width: 240, height: 220, crop: 'center' }}"
                      alt="{{ img1.alt | escape }}"
                      width="240"
                      height="220"
                      loading="lazy"
                    >
                  {%- else -%}
                    {{ 'collection-2' | placeholder_svg_tag: 'wtd-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="wtd-card__img-stack-bottom">
                  {%- if img3 != blank -%}
                    <img
                      src="{{ img3 | image_url: width: 240, height: 220, crop: 'center' }}"
                      alt="{{ img3.alt | default: col.title | escape }}"
                      width="240"
                      height="220"
                      loading="lazy"
                    >
                  {%- elsif img1 != blank -%}
                    <img
                      src="{{ img1 | image_url: width: 240, height: 220, crop: 'center' }}"
                      alt="{{ img1.alt | escape }}"
                      width="240"
                      height="220"
                      loading="lazy"
                    >
                  {%- else -%}
                    {{ 'collection-3' | placeholder_svg_tag: 'wtd-placeholder' }}
                  {%- endif -%}
                </div>
              </div>
            </div>
            <div class="wtd-card__info">
              <span class="wtd-card__dot"></span>
              <div class="wtd-card__info-text">
                <span class="wtd-card__title">{{ col.title | escape }}</span>
                <span class="wtd-card__count">{{ custom_label }}</span>
              </div>
            </div>
          </a>
        {%- endfor -%}

        {%- comment -%} Quick links panel {%- endcomment -%}
        {%- if quicklink_blocks.size > 0 -%}
          <div class="wtd-quicklinks" style="--desktop-span: {{ d_span }}; --mobile-span: {{ m_span }};">
            {%- for block in quicklink_blocks -%}
              <a
                class="wtd-quicklinks__link"
                href="{% if block.settings.link_url contains '?' %}{{ block.settings.link_url }}&ref=wholesale_trendy{% else %}{{ block.settings.link_url }}?ref=wholesale_trendy{% endif %}"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.link_label | escape -}}
              </a>
            {%- endfor -%}
            {%- if view_more_url != blank -%}
              <a class="wtd-quicklinks__link wtd-quicklinks__link--more" href="{% if view_more_url contains '?' %}{{ view_more_url }}&ref=wholesale_trendy{% else %}{{ view_more_url }}?ref=wholesale_trendy{% endif %}">
                {{- view_more_label | escape -}}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Wholesale Trendy",
  "tag": "section",
  "class": "section",
  "max_blocks": 25,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Wholesale Trendy Discovery"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width (px)",
      "min": 800,
      "max": 1600,
      "step": 40,
      "default": 1400
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60
    },
    {
      "type": "header",
      "content": "Quick links panel"
    },
    {
      "type": "url",
      "id": "view_more_url",
      "label": "\"View More\" link URL"
    },
    {
      "type": "text",
      "id": "view_more_label",
      "label": "\"View More\" label",
      "default": "VIEW MORE >>"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "custom_label",
          "label": "Custom product count label",
          "info": "e.g. \"14k+ Products\". Leave blank to auto-generate from collection count.",
          "placeholder": "14k+ Products"
        },
        {
          "type": "header",
          "content": "Manual Collage Images"
        },
        {
          "type": "image_picker",
          "id": "manual_image_1",
          "label": "Main image (Left)"
        },
        {
          "type": "image_picker",
          "id": "manual_image_2",
          "label": "Sub image (Top right)"
        },
        {
          "type": "image_picker",
          "id": "manual_image_3",
          "label": "Sub image (Bottom right)"
        }
      ]
    },
    {
      "type": "quick_link",
      "name": "Quick link",
      "settings": [
        {
          "type": "text",
          "id": "link_label",
          "label": "Label",
          "default": "Chain Jewelry"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Wholesale Trendy Discovery",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "quick_link", "settings": { "link_label": "Nihao Choice" } },
        { "type": "quick_link", "settings": { "link_label": "NIHAO Best Sellers" } },
        { "type": "quick_link", "settings": { "link_label": "Chain Jewelry" } },
        { "type": "quick_link", "settings": { "link_label": "Two Tone Jewelry" } },
        { "type": "quick_link", "settings": { "link_label": "Letter Jewelry" } },
        { "type": "quick_link", "settings": { "link_label": "Flower Jewelry" } },
        { "type": "quick_link", "settings": { "link_label": "Heart Jewelry" } },
        { "type": "quick_link", "settings": { "link_label": "Mother's Day" } }
      ]
    }
  ]
}
{% endschema %}