          <img src="{{ section.settings.deal_image_1 |  img_url: 'master' }}" alt="{{ section.settings.deal_text_1 }}">
        </div>
      {% else %}
        
        <p>{{ section.settings.deal_text_1 }}<br><span class="discount">{{ section.settings.discount_1}}</span></p>
        {% if section.settings.deal_description_1 %}
          <div class="deal-description">{{ section.settings.deal_description_2 }}</div>
        {% endif %}
        {% if section.settings.show_coupon_code_1 %}
          <p>Use code: <b>{{ section.settings.coupon_code_1 }}</b></p>
        {% endif %}
        {% if section.settings.enable_timer_1 %}
          <div id="countdown-timer-1" class="timer">
            <span id="timer-1">00:00:00</span>
          </div>
        {% endif %}
        {% if section.settings.show_button_1 %}
