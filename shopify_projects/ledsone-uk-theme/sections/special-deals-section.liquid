<script>
  document.addEventListener("DOMContentLoaded", function() {
    function startCountdown(timerId, endDate) {
      const timerElement = document.getElementById(timerId);
      if (!timerElement) return;

      const endTime = Math.floor(new Date(endDate).getTime() / 1000);

      function updateTimer() {
        const now = Math.floor(Date.now() / 1000);
        let remainingTime = endTime - now;

        if (remainingTime > 0) {
          let hours = Math.floor(remainingTime / 3600);
          let minutes = Math.floor((remainingTime % 3600) / 60);
          let seconds = remainingTime % 60;
          timerElement.innerText = `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
        } else {
          timerElement.innerText = "Expired";
        }
      }

      updateTimer();
      setInterval(updateTimer, 1000);
    }

    {% if section.settings.enable_timer_1 %}
      startCountdown("timer-1", "{{ section.settings.end_date_1 }}");
    {% endif %}
    {% if section.settings.enable_timer_2 %}
      startCountdown("timer-2", "{{ section.settings.end_date_2 }}");
    {% endif %}
    {% if section.settings.enable_timer_3 %}
      startCountdown("timer-3", "{{ section.settings.end_date_3 }}");
    {% endif %}
  });
</script>

<style>


  .collections-container {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 20px;
    flex-wrap: wrap;
     box-shadow: 0px 5px 15px rgba(0, 0, 0, 0.1);
