      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "price_label_color",
      "label": "Label Color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "price_border_color",
      "label": "Border Color",
      "default": "#e5e8ec"
    },
    {
      "type": "range",
      "id": "price_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Border Radius",
