      "label": "Default Description",
      "default": "Select a product to view details"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Product Title",
      "default": "Premium Product"
    },
    {
      "type": "header",
      "content": "💰 Price Box"
    },
    {
      "type": "text",
      "id": "price_label",
      "label": "Price Label",
      "default": "Price"
    },
    {
      "type": "range",
      "id": "price_font_size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
