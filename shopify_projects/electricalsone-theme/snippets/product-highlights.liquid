{%- liquid
  assign warranty_raw = product.metafields.custom.warranty.value
  if warranty_raw == blank
    assign warranty_label = "5 Year Warranty"
  elsif warranty_raw contains "Warranty" or warranty_raw contains "warranty"
    assign warranty_label = warranty_raw
  else
    assign warranty_label = warranty_raw | append: " Year Warranty"
  endif

  assign features_raw = product.metafields.custom.key_features.value
  if features_raw != blank
    assign features = features_raw | split: ","
  endif
-%}

<div class="ph-section">

  <div class="ph-trust-grid" role="list" aria-label="Product trust signals">

    <div class="ph-trust-item" role="listitem">
      <span class="ph-trust-icon ph-icon--blue" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </span>
      <div class="ph-trust-text">
        <strong class="ph-trust-title">{{ warranty_label }}</strong>
        <span class="ph-trust-sub">Manufacturer backed</span>
      </div>
    </div>

    <div class="ph-trust-item" role="listitem">
      <span class="ph-trust-icon ph-icon--green" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      </span>
      <div class="ph-trust-text">
        <strong class="ph-trust-title">UK Stock</strong>
        <span class="ph-trust-sub">Fast despatch available</span>
      </div>
    </div>

    <div class="ph-trust-item" role="listitem">
      <span class="ph-trust-icon ph-icon--amber" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </span>
      <div class="ph-trust-text">
        <strong class="ph-trust-title">Next Day Available</strong>
        <span class="ph-trust-sub">Order before 3 pm</span>
      </div>
    </div>

    <div class="ph-trust-item" role="listitem">
      <span class="ph-trust-icon ph-icon--purple" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </span>
      <div class="ph-trust-text">
        <strong class="ph-trust-title">UK Safety Certified</strong>
        <span class="ph-trust-sub">CE &amp; UKCA marked</span>
      </div>
    </div>

  </div>

  {%- if features != nil and features.size > 0 -%}
  <ul class="ph-features-list" aria-label="Key product features">
    {%- for feature in features limit: 6 -%}
    <li class="ph-feature-item">
      <svg class="ph-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
      {{ feature | strip }}
    </li>
    {%- endfor -%}
  </ul>
  {%- endif -%}

</div>

<style>
.ph-section {
  margin: 24px 0 0;
  padding: 20px 0 0;
  border-top: 1px solid rgba(var(--color-foreground, 18, 18, 18), 0.08);
}

.ph-trust-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.ph-trust-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.ph-trust-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 10px;
  flex-shrink: 0;
}

.ph-icon--blue   { background: #eff6ff; color: #2563eb; }
.ph-icon--green  { background: #f0fdf4; color: #16a34a; }
.ph-icon--amber  { background: #fffbeb; color: #d97706; }
.ph-icon--purple { background: #faf5ff; color: #7c3aed; }

.ph-trust-text {
  min-width: 0;
}

.ph-trust-title {
  display: block;
  font-size: 0.875rem;
  font-weight: 600;
  line-height: 1.3;
  color: rgb(var(--color-foreground, 18, 18, 18));
}

.ph-trust-sub {
  display: block;
  font-size: 0.8125rem;
  color: rgba(var(--color-foreground, 18, 18, 18), 0.55);
  margin-top: 2px;
}

.ph-features-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6px 20px;
  list-style: none;
  margin: 0;
  padding: 16px 0 0;
  border-top: 1px solid rgba(var(--color-foreground, 18, 18, 18), 0.06);
  margin-top: 16px;
}

.ph-feature-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.875rem;
  color: rgba(var(--color-foreground, 18, 18, 18), 0.75);
}

.ph-check-icon {
  color: #16a34a;
  flex-shrink: 0;
}

@media screen and (max-width: 749px) {
  .ph-trust-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .ph-trust-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
  }

  .ph-features-list {
    gap: 6px 16px;
  }
}
</style>
