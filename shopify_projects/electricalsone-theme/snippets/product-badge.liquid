{%- assign nweBadgeDate = product.metafields.metaname.product_new_badge.value | date: '%s' -%}
{%- assign today_date = 'now' | date: '%s' -%}

<span class="product__card__badges">
  {%- if product.metafields.metaname.product_new_badge.value -%}
  {%- if today_date < nweBadgeDate -%}
  <span class="badge color-{{ settings.new_badge_color_scheme }}">New</span>
  {%- endif -%}
  {%- endif -%}

  {%- if product.available == false -%}
  <span class="badge badge--bottom-left color-{{ settings.sold_out_badge_color_scheme }}" aria-hidden="true">{{ 'products.product.sold_out' | t }}</span>
  {%- elsif product.compare_at_price > product.price and product.available -%}
  <span class="badge badge--bottom-left color-{{ settings.sale_badge_color_scheme }}" aria-hidden="true">
    <span class="sale__save--percent">-{{- product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | times: 100.0 | divided_by: product.selected_or_first_available_variant.compare_at_price | money_without_currency | replace: ',', '.' | times: 100 | remove: '.0' -}} </span>% <span class="sale__text">{{ 'products.product.on_sale' | t }}</span>
  </span>
  {%- endif -%}

</span>