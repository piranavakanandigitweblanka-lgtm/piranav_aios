{%- liquid
  assign shipping_policy   = product.metafields.metaname.product_shipping_policy.value
  assign important_notes   = product.metafields.custom.important_notes.value
  assign specifications    = product.metafields.custom.specifications.value
  assign desc_panel_id     = 'pdt-desc-'     | append: product.id
  assign specs_panel_id    = 'pdt-specs-'    | append: product.id
  assign delivery_panel_id = 'pdt-delivery-' | append: product.id
  assign notes_panel_id    = 'pdt-notes-'    | append: product.id
-%}

{%- if product.description != blank or shipping_policy != blank or specifications != blank or important_notes != blank -%}
<div class="pdt-section">

  {%- if product.description != blank -%}
  <div class="pdt-accordion">
    <button
      class="pdt-accordion__trigger"
      type="button"
      aria-expanded="true"
      aria-controls="{{ desc_panel_id }}"
      id="{{ desc_panel_id }}-btn"
    >
      <span class="pdt-accordion__label">Product Description</span>
      <svg class="pdt-accordion__chevron" viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="20" height="20"><polyline points="6 9 12 15 18 9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div
      id="{{ desc_panel_id }}"
      class="pdt-accordion__panel"
      role="region"
      aria-labelledby="{{ desc_panel_id }}-btn"
    >
      <div class="pdt-accordion__body rte pdt-rte-wrap">
        {{ product.description }}
      </div>
    </div>
  </div>
  {%- endif -%}

  {%- if specifications != blank -%}
  <div class="pdt-accordion">
    <button
      class="pdt-accordion__trigger"
      type="button"
      aria-expanded="false"
      aria-controls="{{ specs_panel_id }}"
      id="{{ specs_panel_id }}-btn"
    >
      <span class="pdt-accordion__label">Specifications</span>
      <svg class="pdt-accordion__chevron" viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="20" height="20"><polyline points="6 9 12 15 18 9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div
      id="{{ specs_panel_id }}"
      class="pdt-accordion__panel pdt-accordion__panel--closed"
      role="region"
      aria-labelledby="{{ specs_panel_id }}-btn"
    >
      <div class="pdt-accordion__body rte pdt-rte-wrap">
        {{ specifications }}
      </div>
    </div>
  </div>
  {%- endif -%}

  {%- if shipping_policy != blank -%}
  <div class="pdt-accordion">
    <button
      class="pdt-accordion__trigger"
      type="button"
      aria-expanded="false"
      aria-controls="{{ delivery_panel_id }}"
      id="{{ delivery_panel_id }}-btn"
    >
      <span class="pdt-accordion__label">Delivery &amp; Returns</span>
      <svg class="pdt-accordion__chevron" viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="20" height="20"><polyline points="6 9 12 15 18 9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div
      id="{{ delivery_panel_id }}"
      class="pdt-accordion__panel pdt-accordion__panel--closed"
      role="region"
      aria-labelledby="{{ delivery_panel_id }}-btn"
    >
      <div class="pdt-accordion__body rte">
        {%- if product.metafields.metaname.product_shipping_policy.type == "file_reference" -%}
          <img src="{{ shipping_policy | img_url: 'master' }}" alt="Delivery and Returns Policy" loading="lazy" style="max-width:100%;height:auto;">
        {%- else -%}
          {{ shipping_policy }}
        {%- endif -%}
      </div>
    </div>
  </div>
  {%- endif -%}

  {%- if important_notes != blank -%}
  <div class="pdt-accordion">
    <button
      class="pdt-accordion__trigger"
      type="button"
      aria-expanded="false"
      aria-controls="{{ notes_panel_id }}"
      id="{{ notes_panel_id }}-btn"
    >
      <span class="pdt-accordion__label">Important Notes</span>
      <svg class="pdt-accordion__chevron" viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="20" height="20"><polyline points="6 9 12 15 18 9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div
      id="{{ notes_panel_id }}"
      class="pdt-accordion__panel pdt-accordion__panel--closed"
      role="region"
      aria-labelledby="{{ notes_panel_id }}-btn"
    >
      <div class="pdt-accordion__body pdt-accordion__body--notice rte">
        {{ important_notes }}
      </div>
    </div>
  </div>
  {%- endif -%}

</div>
{%- endif -%}

<style>
.pdt-section {
  margin: 32px 0;
}

.pdt-accordion {
  border-top: 1px solid rgba(var(--color-foreground, 18, 18, 18), 0.12);
}

.pdt-accordion:last-child {
  border-bottom: 1px solid rgba(var(--color-foreground, 18, 18, 18), 0.12);
}

.pdt-accordion__trigger {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 18px 0;
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: inherit;
  font-weight: 600;
  color: inherit;
  text-align: left;
  gap: 12px;
  font-family: inherit;
}

.pdt-accordion__trigger:focus-visible {
  outline: 2px solid rgb(var(--color-foreground, 18, 18, 18));
  outline-offset: 3px;
  border-radius: 2px;
}

.pdt-accordion__chevron {
  flex-shrink: 0;
  transition: transform 0.25s ease;
}

.pdt-accordion__trigger[aria-expanded="true"] .pdt-accordion__chevron {
  transform: rotate(180deg);
}

.pdt-accordion__panel {
  overflow: hidden;
}

.pdt-accordion__panel--closed {
  display: none;
}

.pdt-accordion__body {
  padding-bottom: 24px;
}

.pdt-accordion__body--notice {
  background: #fffbeb;
  border-left: 4px solid #f59e0b;
  padding: 16px 20px;
  margin-bottom: 24px;
  border-radius: 0 6px 6px 0;
}

.pdt-rte-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.pdt-rte-wrap table {
  min-width: 400px;
}

@media screen and (max-width: 749px) {
  .pdt-accordion__trigger {
    padding: 16px 0;
  }
}
</style>

<script>
(function () {
  'use strict';

  function pdtInit() {
    document.querySelectorAll('.pdt-accordion__trigger').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var expanded = this.getAttribute('aria-expanded') === 'true';
        var panel = document.getElementById(this.getAttribute('aria-controls'));
        if (!panel) return;
        if (expanded) {
          this.setAttribute('aria-expanded', 'false');
          panel.classList.add('pdt-accordion__panel--closed');
        } else {
          this.setAttribute('aria-expanded', 'true');
          panel.classList.remove('pdt-accordion__panel--closed');
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', pdtInit);
  } else {
    pdtInit();
  }
})();
</script>
