{% doc %}
  @prompt
    Build a clean, modern website hero section for an e-commerce brand.
    
    Header: Large bold sans-serif title 'Professional Lighting Components'.
    
    Subtext: A gray descriptive sentence below the title.
    
    Search Bar: A wide, centered input field with rounded corners and a placeholder 'Find components by type...'. Include a blue 'Search' button inside/at the end of the bar.
    
    Trust Badges: Below the search bar, a horizontal row of four items with blue checkmarks: 'UK Stock', 'Trade Friendly', 'Fast Dispatch', and 'CE / UKCA Compliant'.
    
    Styling: Use a white background, plenty of whitespace, and a professional, minimalist aesthetic."
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    width: 100%;
  }

  .ai-hero-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-hero-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.2;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
  }

  .ai-hero-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    line-height: 1.6;
    color: {{ block.settings.subtext_color }};
    margin: 0 0 {{ block.settings.subtext_spacing }}px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-hero-search-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.search_width }}px;
    margin: 0 auto {{ block.settings.search_spacing }}px;
    position: relative;
  }

  .ai-hero-search-form-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    background-color: {{ block.settings.search_bg_color }};
    border: {{ block.settings.search_border_width }}px solid {{ block.settings.search_border_color }};
    border-radius: {{ block.settings.search_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .ai-hero-search-input-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.search_padding }}px 20px;
    border: none;
    background: transparent;
    font-size: {{ block.settings.search_font_size }}px;
    color: {{ block.settings.search_text_color }};
    outline: none;
  }

  .ai-hero-search-input-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_bg_color }};
    outline-offset: -2px;
  }

  .ai-hero-search-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.search_placeholder_color }};
  }

  .ai-hero-search-button-{{ ai_gen_id }} {
    padding: {{ block.settings.search_padding }}px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    white-space: nowrap;
  }

  .ai-hero-search-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-hero-search-button-{{ ai_gen_id }}:focus {
    outline: 2px solid #ffffff;
    outline-offset: -2px;
  }

  .ai-hero-trust-badges-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.badge_spacing }}px;
    flex-wrap: wrap;
  }

  .ai-hero-badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.badge_font_size }}px;
    color: {{ block.settings.badge_text_color }};
  }

  .ai-hero-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.badge_icon_size }}px;
    height: {{ block.settings.badge_icon_size }}px;
    flex-shrink: 0;
  }

  .ai-hero-badge-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.badge_icon_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.65 }}px;
    }

    .ai-hero-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }

    .ai-hero-search-form-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-hero-search-input-{{ ai_gen_id }} {
      width: 100%;
      padding: 14px 20px;
    }

    .ai-hero-search-button-{{ ai_gen_id }} {
      width: 100%;
      padding: 14px 32px;
    }

    .ai-hero-trust-badges-{{ ai_gen_id }} {
      gap: 16px;
    }

    .ai-hero-badge-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      {% if template == 'index' %}
        <h1 class="ai-hero-title-{{ ai_gen_id }}">{{ block.settings.title }}</h1>
      {% else %}
        <h2 class="ai-hero-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-hero-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}

    <div class="ai-hero-search-wrapper-{{ ai_gen_id }}">
      <form action="/search" method="get" class="ai-hero-search-form-{{ ai_gen_id }}" role="search">
        <input
          type="search"
          name="q"
          class="ai-hero-search-input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.search_placeholder }}"
          aria-label="Search"
        >
        <button type="submit" class="ai-hero-search-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </button>
      </form>
    </div>

    <div class="ai-hero-trust-badges-{{ ai_gen_id }}">
      {% if block.settings.badge_1_text != blank %}
        <div class="ai-hero-badge-{{ ai_gen_id }}">
          <div class="ai-hero-badge-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
            </svg>
          </div>
          <span>{{ block.settings.badge_1_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.badge_2_text != blank %}
        <div class="ai-hero-badge-{{ ai_gen_id }}">
          <div class="ai-hero-badge-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
            </svg>
          </div>
          <span>{{ block.settings.badge_2_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.badge_3_text != blank %}
        <div class="ai-hero-badge-{{ ai_gen_id }}">
          <div class="ai-hero-badge-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
            </svg>
          </div>
          <span>{{ block.settings.badge_3_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.badge_4_text != blank %}
        <div class="ai-hero-badge-{{ ai_gen_id }}">
          <div class="ai-hero-badge-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
            </svg>
          </div>
          <span>{{ block.settings.badge_4_text }}</span>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
  (function() {
    var form = document.querySelector('.ai-hero-search-form-{{ ai_gen_id }}');
    if (form) {
      form.addEventListener('submit', function(event) {
        var input = form.querySelector('.ai-hero-search-input-{{ ai_gen_id }}');
        if (input && !input.value.trim()) {
          event.preventDefault();
        }
      });
    }
  })();
</script>

