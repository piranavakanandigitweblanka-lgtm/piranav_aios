{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-recommendations-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-recommendations__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-recommendations__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-product-recommendations__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-product-recommendations__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-product-recommendations__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ai-product-card-{{ ai_gen_id }} {
    position: relative;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
   
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-product-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
    flex-shrink: 0;
  }

  .ai-product-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }

  .ai-product-card__image--secondary-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card__image--secondary-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-product-card__badges-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    z-index: 2;
  }

  .ai-product-card__badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-product-card__badge--sale-{{ ai_gen_id }} {
    background-color: {{ block.settings.sale_badge_color }};
    color: {{ block.settings.sale_badge_text_color }};
  }

  .ai-product-card__badge--new-{{ ai_gen_id }} {
    background-color: {{ block.settings.new_badge_color }};
    color: {{ block.settings.new_badge_text_color }};
  }

  .ai-product-card__badge--sold-out-{{ ai_gen_id }} {
    background-color: {{ block.settings.sold_out_badge_color }};
    color: {{ block.settings.sold_out_badge_text_color }};
  }

  .ai-product-card__badge--discount-{{ ai_gen_id }} {
    background-color: {{ block.settings.discount_badge_color }};
    color: {{ block.settings.discount_badge_text_color }};
  }

  .ai-product-card__actions-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    opacity: 0;
    transform: translateX(10px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: 2;
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card__actions-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateX(0);
  }

  .ai-product-card__action-btn-{{ ai_gen_id }} {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.action_button_background }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-product-card__action-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.action_button_hover_background }};
    transform: scale(1.1);
  }

  .ai-product-card__action-btn-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
    stroke: {{ block.settings.action_button_icon_color }};
  }

  .ai-product-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .ai-product-card__vendor-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.vendor_color }};
    margin: 0 0 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

.ai-product-card__title-{{ ai_gen_id }} {
  font-size: {{ block.settings.product_title_size }}px;
  color: {{ block.settings.product_title_color }};
  margin: 0 0 10px;
  font-weight: 500;
  line-height: 1.4;
  
  /* 2 line limit */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  
  /* Consistent height for all cards */
  height: calc({{ block.settings.product_title_size }}px * 1.4 * 2);
  min-height: calc({{ block.settings.product_title_size }}px * 1.4 * 2);
}

/* Mobile adjustment */
@media screen and (max-width: 749px) {
  .ai-product-card__title-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.product_title_size }}px * 0.9);
    height: calc({{ block.settings.product_title_size }}px * 0.9 * 1.4 * 2);
    min-height: calc({{ block.settings.product_title_size }}px * 0.9 * 1.4 * 2);
  }
}

  .ai-product-card__title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ai-product-card__title-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-product-card__price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-product-card__price--regular-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-product-card__price--compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size | minus: 2 }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-product-card__price--sale-{{ ai_gen_id }} {
    color: {{ block.settings.sale_price_color }};
  }

  .ai-product-card__rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
  }

  .ai-product-card__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-product-card__star-{{ ai_gen_id }} {
    width: 14px;
    height: 14px;
    fill: {{ block.settings.star_color }};
  }

  .ai-product-card__star--empty-{{ ai_gen_id }} {
    fill: #e0e0e0;
  }

  .ai-product-card__rating-count-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.rating_text_color }};
  }

  .ai-product-card__add-to-cart-{{ ai_gen_id }} {
    width: 100%;
    padding: 10px 16px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: auto;
  }

  .ai-product-card__add-to-cart-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  .ai-product-card__add-to-cart-{{ ai_gen_id }}:disabled {
    background-color: #cccccc;
    cursor: not-allowed;
    transform: none;
  }

  .ai-product-recommendations__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666666;
  }

  .ai-product-recommendations__empty-icon-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    opacity: 0.3;
  }

  .ai-product-recommendations__empty-text-{{ ai_gen_id }} {
    font-size: 16px;
    color: #999999;
  }

  @media screen and (max-width: 989px) {
    .ai-product-recommendations__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_tablet }}, 1fr);
    }

    .ai-product-recommendations__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-recommendations__container-{{ ai_gen_id }} {
      padding: 0;
    }

    .ai-product-recommendations__header-{{ ai_gen_id }} {
      padding: 0 20px;
      margin-bottom: 24px;
    }

    .ai-product-recommendations__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-product-recommendations__grid-wrapper-{{ ai_gen_id }} {
      position: relative;
      overflow: hidden;
      padding: 0 20px;
    }

    .ai-product-recommendations__grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      gap: 16px;
      padding-bottom: 10px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .ai-product-recommendations__grid-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-product-card-{{ ai_gen_id }} {
      flex: 0 0 calc({{ block.settings.mobile_card_width }}% - 8px);
      scroll-snap-align: start;
    }

    .ai-product-card__content-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.7 }}px;
    }

    .ai-product-card__actions-{{ ai_gen_id }} {
      opacity: 1;
      transform: translateX(0);
    }

    .ai-product-card__add-to-cart-{{ ai_gen_id }} {
      padding: 8px 14px;
      font-size: 12px;
    }

    .ai-product-card-{{ ai_gen_id }}:hover {
      transform: none;
    }

    .ai-swiper-dots-{{ ai_gen_id }} {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 20px;
      padding: 0 20px;
    }

    .ai-swiper-dot-{{ ai_gen_id }} {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background-color: #d1d1d1;
      transition: background-color 0.3s ease, width 0.3s ease;
      cursor: pointer;
      border: none;
      padding: 0;
    }

    .ai-swiper-dot-{{ ai_gen_id }}.active {
      background-color: {{ block.settings.button_background }};
      width: 24px;
      border-radius: 4px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-swiper-dots-{{ ai_gen_id }} {
      display: none;
    }
  }

  .ai-cart-toast-{{ ai_gen_id }} {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: #000;
  color: #fff;
  padding: 12px 18px;
  border-radius: 30px;
  font-size: 14px;
  font-weight: 600;
  opacity: 0;
  transition: all 0.3s ease;
  z-index: 9999;
}

.ai-cart-toast-{{ ai_gen_id }}.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

{% endstyle %}

<product-recommendations-{{ ai_gen_id }}
  class="ai-product-recommendations-{{ ai_gen_id }}"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ block.settings.products_to_show }}"
  {{ block.shopify_attributes }}
>
  {% if recommendations.performed and recommendations.products_count > 0 %}
    <div class="ai-product-recommendations__container-{{ ai_gen_id }}">
      {% if block.settings.heading != blank or block.settings.subheading != blank %}
        <div class="ai-product-recommendations__header-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-product-recommendations__title-{{ ai_gen_id }}">
              {{ block.settings.heading }}
            </h2>
          {% endif %}
          {% if block.settings.subheading != blank %}
            <p class="ai-product-recommendations__subtitle-{{ ai_gen_id }}">
              {{ block.settings.subheading }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      <div class="ai-product-recommendations__grid-wrapper-{{ ai_gen_id }}">
        <ul class="ai-product-recommendations__grid-{{ ai_gen_id }}" data-swiper-container>
          {% for product in recommendations.products %}
            <li class="ai-product-card-{{ ai_gen_id }}">
              <div class="ai-product-card__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-product-card__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                  {% if product.images[1] and block.settings.show_second_image %}
                    <img
                      src="{{ product.images[1] | image_url: width: 600 }}"
                      alt="{{ product.images[1].alt | escape }}"
                      class="ai-product-card__image-{{ ai_gen_id }} ai-product-card__image--secondary-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="600"
                    >
                  {% endif %}
                {% else %}
                  <div class="ai-product-card__image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                {% if block.settings.show_badges %}
                  <div class="ai-product-card__badges-{{ ai_gen_id }}">
                    {% if product.available == false %}
                      <span class="ai-product-card__badge-{{ ai_gen_id }} ai-product-card__badge--sold-out-{{ ai_gen_id }}">
                        Sold Out
                      </span>
                    {% elsif product.compare_at_price > product.price %}
                      <span class="ai-product-card__badge-{{ ai_gen_id }} ai-product-card__badge--sale-{{ ai_gen_id }}">
                        Sale
                      </span>
                      {% if block.settings.show_discount_badge %}
                        {% assign discount = product.compare_at_price | minus: product.price %}
                        {% assign discount_percent = discount | times: 100.0 | divided_by: product.compare_at_price | round %}
                        <span class="ai-product-card__badge-{{ ai_gen_id }} ai-product-card__badge--discount-{{ ai_gen_id }}">
                          -{{ discount_percent }}%
                        </span>
                      {% endif %}
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.show_quick_actions %}
                  <div class="ai-product-card__actions-{{ ai_gen_id }}">
                    <button
                      class="ai-product-card__action-btn-{{ ai_gen_id }}"
                      aria-label="Add to wishlist"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                      </svg>
                    </button>
                    <button
                      class="ai-product-card__action-btn-{{ ai_gen_id }}"
                      aria-label="Quick view"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                    </button>
                  </div>
                {% endif %}
              </div>

              <div class="ai-product-card__content-{{ ai_gen_id }}">
                {% if block.settings.show_vendor and product.vendor %}
                  <p class="ai-product-card__vendor-{{ ai_gen_id }}">{{ product.vendor }}</p>
                {% endif %}

                <h3 class="ai-product-card__title-{{ ai_gen_id }}">
                  <a
                    href="{{ product.url }}"
                    class="ai-product-card__title-link-{{ ai_gen_id }}"
                  >
                    {{ product.title }}
                  </a>
                </h3>

                {% if block.settings.show_rating %}
                  <div class="ai-product-card__rating-{{ ai_gen_id }}">
                    <div class="ai-product-card__stars-{{ ai_gen_id }}">
                      {% for i in (1..5) %}
                        <svg class="ai-product-card__star-{{ ai_gen_id }} {% if i > 4 %}ai-product-card__star--empty-{{ ai_gen_id }}{% endif %}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      {% endfor %}
                    </div>
                    <span class="ai-product-card__rating-count-{{ ai_gen_id }}">(4.0)</span>
                  </div>
                {% endif %}

                <div class="ai-product-card__price-{{ ai_gen_id }}">
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-product-card__price--regular-{{ ai_gen_id }} ai-product-card__price--sale-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </span>
                    <span class="ai-product-card__price--compare-{{ ai_gen_id }}">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% else %}
                    <span class="ai-product-card__price--regular-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </span>
                  {% endif %}
                </div>

               {% if block.settings.show_add_to_cart %}
  <button
    class="ai-product-card__add-to-cart-{{ ai_gen_id }}"
    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
    {% unless product.available %}disabled{% endunless %}
  >

                    {% if product.available %}
                      {{ block.settings.add_to_cart_text }}
                    {% else %}
                      Sold Out
                    {% endif %}
                  </button>
                {% endif %}
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="ai-swiper-dots-{{ ai_gen_id }}" data-swiper-dots></div>
    </div>
  {% endif %}
  <div class="ai-cart-toast-{{ ai_gen_id }}" hidden>
  ✔ Added to cart
</div>

</product-recommendations-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductRecommendations{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.swiperInitialized = false;
      }

      connectedCallback() {
        const handleIntersection = (entries, observer) => {
          if (!entries[0].isIntersecting) return;
          observer.unobserve(this);

          fetch(this.dataset.url)
            .then(response => response.text())
            .then(text => {
              const html = document.createElement('div');
              html.innerHTML = text;
              const recommendations = html.querySelector('product-recommendations-{{ ai_gen_id }}');

              if (recommendations && recommendations.innerHTML.trim().length) {
                this.innerHTML = recommendations.innerHTML;
                this.initSwiper();
              }
            })
            .catch(e => {
              console.error(e);
            });
        };

        new IntersectionObserver(handleIntersection.bind(this), {rootMargin: '0px 0px 200px 0px'}).observe(this);
      }

      initSwiper() {
        if (window.innerWidth > 749 || this.swiperInitialized) return;

        const container = this.querySelector('[data-swiper-container]');
        const dotsContainer = this.querySelector('[data-swiper-dots]');
        
        if (!container || !dotsContainer) return;

        const cards = container.querySelectorAll('.ai-product-card-{{ ai_gen_id }}');
        const cardWidth = {{ block.settings.mobile_card_width }};
        const totalCards = cards.length;
        const visibleCards = Math.floor(100 / cardWidth);
        const totalDots = Math.ceil(totalCards / visibleCards);

        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-swiper-dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          if (i === 0) dot.classList.add('active');
          
          dot.addEventListener('click', () => {
            const scrollPosition = container.scrollWidth * (i / totalDots);
            container.scrollTo({
              left: scrollPosition,
              behavior: 'smooth'
            });
          });
          
          dotsContainer.appendChild(dot);
        }

        let scrollTimeout;
        container.addEventListener('scroll', () => {
          clearTimeout(scrollTimeout);
          scrollTimeout = setTimeout(() => {
            const scrollLeft = container.scrollLeft;
            const scrollWidth = container.scrollWidth - container.clientWidth;
            const currentIndex = Math.round((scrollLeft / scrollWidth) * (totalDots - 1));
            
            const dots = dotsContainer.querySelectorAll('.ai-swiper-dot-{{ ai_gen_id }}');
            dots.forEach((dot, index) => {
              if (index === currentIndex) {
                dot.classList.add('active');
              } else {
                dot.classList.remove('active');
              }
            });
          }, 100);
        });

        this.swiperInitialized = true;
      }
    }

    customElements.define('product-recommendations-{{ ai_gen_id }}', ProductRecommendations{{ ai_gen_id }});
  })();
document.addEventListener('click', function (e) {
  const button = e.target.closest('.ai-product-card__add-to-cart-{{ ai_gen_id }}');
  if (!button) return;

  const variantId = button.dataset.variantId;
  if (!variantId) return;

  button.disabled = true;
  const originalText = button.textContent;
  button.textContent = 'Adding...';

  fetch('/cart/add.js', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    },
    body: JSON.stringify({
      id: variantId,
      quantity: 1
    })
  })
  .then(res => res.json())
  .then(() => {
    // Show toast
    const toast = document.querySelector('.ai-cart-toast-{{ ai_gen_id }}');
    toast.hidden = false;
    toast.classList.add('show');

    // Hide toast after 2 seconds
    setTimeout(() => {
      toast.classList.remove('show');
      setTimeout(() => toast.hidden = true, 300);
    }, 2000);

    button.textContent = 'Added ✓';

    setTimeout(() => {
      button.textContent = originalText;
      button.disabled = false;
    }, 1500);
  })
  .catch(() => {
    button.textContent = 'Error';
    button.disabled = false;
  });
});
</script>

