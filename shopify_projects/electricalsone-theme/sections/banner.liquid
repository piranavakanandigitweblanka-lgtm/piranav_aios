{%- if section.settings.show_on_desktop or section.settings.show_on_mobile -%}
  <style>
    .mobile-banner-container {
      width: 100%;
      max-width: 407.41px;
      margin: 0 auto;
    }
    .mobile-banner-container img {
      width: 407.41px;
      height: 135.67px;
      object-fit: cover;
      display: block;
    }
    {%- if section.settings.show_on_desktop and section.settings.show_on_mobile -%}
      /* Both enabled: show on all devices */
    {%- elsif section.settings.show_on_desktop and section.settings.show_on_mobile == false -%}
      @media screen and (max-width: 767px) {
        .mobile-banner-container {
          display: none;
        }
      }
    {%- elsif section.settings.show_on_mobile and section.settings.show_on_desktop == false -%}
      @media screen and (min-width: 768px) {
        .mobile-banner-container {
          display: none;
        }
      }
    {%- endif -%}
  </style>

  <div class="mobile-banner-container">
    {%- if section.settings.image != blank and section.settings.link != blank -%}
      <a href="{{ section.settings.link | escape }}">
        <img
          src="{{ section.settings.image | img_url: 'master' }}"
          alt="{{ section.settings.image.alt | escape }}"
          width="407.41"
          height="135.67"
          loading="eager"
          fetchpriority="high"
        >
      </a>
    {%- elsif section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | img_url: 'master' }}"
        alt="{{ section.settings.image.alt | escape }}"
        width="407.41"
        height="135.67"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Mobile Banner",
  "class": "section-mobile-banner",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner Image",
      "info": "Recommended size: 407.41px x 135.67px"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner Link",
      "info": "Optional: Add a URL to make the banner clickable"
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Mobile Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}