{% schema %}
{
  "name": "Category Grid (Manual)",
  "settings": [
    {
      "type": "header",
      "content": "Browse Components by Function"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "info": "Number of columns to display on desktop screens"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Lamp Holders"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "E27, E14, B22, GU10"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "category": "Sections",
      "settings": {
        "desktop_columns": 4
      },
      "blocks": [
        {"type": "category"},
        {"type": "category"},
        {"type": "category"},
        {"type": "category"}
      ]
    }
  ]
}
{% endschema %}

<section class="category-grid-section">
  <div class="page-width">
    <h2>{{ section.settings.header }}</h2>
    <div class="category-grid" style="--desktop-columns: {{ section.settings.desktop_columns | default: 4 }}">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="category-item">
          {% if block.settings.icon %}
            <div class="category-icon">
              <img src="{{ block.settings.icon | img_url: '200x200' }}" alt="{{ block.settings.title | escape }}" width="60" height="60" loading="lazy">
            </div>
          {% endif %}
          <h3 class="category-title">{{ block.settings.title }}</h3>
          <p class="category-description">{{ block.settings.description }}</p>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .page-width {
    max-width: 1400px;
}
.category-grid-section {
 
  text-align: center;
}

.category-grid-section h2 {
  font-size: 2em;
  margin-bottom: 30px;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(var(--desktop-columns, 4), 1fr);
  gap: 20px;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 15px;
 /* border: 1px solid #e1e1e1;*/
  border-radius: 8px;
  text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s;
  background: #fff;
  height: 100%;
  box-sizing: border-box;
}

.category-item:hover {
  transform: translateY(-5px);
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
}

.category-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 80px;
  margin-bottom: 15px;
  flex-shrink: 0;
}

.category-icon img {
  max-width: 100%;
  max-height: 80px;
  width: auto;
  height: auto;
  object-fit: contain;
}

.category-title {
  font-size: 1em;
  margin: 0 0 8px 0;
  color: #000;
  font-weight: 600;
  line-height: 1.3;
  width: 100%;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  min-height: 2.6em;
  max-height: 2.6em;
}

.category-description {
  font-size: 0.85em;
  color: #666;
  margin: 0;
  line-height: 1.4;
  width: 100%;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  min-height: 2.8em;
  max-height: 2.8em;
}

/* Make all items same height */
.category-item {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.category-icon {
  flex: 0 0 auto;
}

.category-title {
  flex: 0 0 auto;
}

.category-description {
  flex: 1 0 auto;
  margin-top: auto;
}

/* Responsive styles */
@media (max-width: 989px) {
  .category-grid-section {
    padding: 30px 0;
  }
  
  .category-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  
  .category-icon {
    height: 55px;
    margin-bottom: 12px;
  }
  
  .category-icon img {
    max-height: 55px;
  }
}

@media (max-width: 749px) {
  .category-grid-section h2 {
    font-size: 1.75em;
    margin-bottom: 25px;
  }
  
  .category-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }
  
  .category-item {
    padding: 15px 10px;
  }
  
  .category-icon {
    height: 50px;
    margin-bottom: 10px;
  }
  
  .category-icon img {
    max-height: 50px;
  }
  
  .category-title {
    font-size: 0.95em;
    min-height: 2.47em;
    max-height: 2.47em;
  }
  
  .category-description {
    font-size: 0.82em;
    min-height: 2.46em;
    max-height: 2.46em;
  }
}

@media (max-width: 480px) {
  .category-grid-section {
    padding: 25px 0;
  }
  
  .category-grid-section h2 {
    font-size: 1.5em;
    margin-bottom: 20px;
  }
  
  .category-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  
  .category-item {
    padding: 12px 8px;
  }
  
  .category-icon {
    height: 45px;
    margin-bottom: 8px;
  }
  
  .category-icon img {
    max-height: 45px;
  }
  
  .category-title {
    font-size: 0.9em;
    min-height: 2.34em;
    max-height: 2.34em;
    margin-bottom: 6px;
  }
  
  .category-description {
    font-size: 0.8em;
    min-height: 2.4em;
    max-height: 2.4em;
  }
}

@media (max-width: 360px) {
  .category-grid {
    grid-template-columns: 1fr;
    max-width: 280px;
    margin: 0 auto;
  }
  
  .category-item {
    padding: 15px;
  }
  
  .category-icon {
    height: 50px;
    margin-bottom: 12px;
  }
  
  .category-icon img {
    max-height: 50px;
  }
}
</style>