      "default": "masonry",
      "label": "Layout"
    },
	{
        "type": "select",
        "id": "column",
        "label": "Number of columns on desktop",
	  	"info": "Works on the grid layout",
        "options": [
		  {
            "value": "1",
            "label": "1"
          },
          {
            "value": "2",
            "label": "2"
          },
          {
            "value": "3",
            "label": "3"
          },
          {
            "value": "4",
            "label": "4"
          },
		  {
            "value": "5",
            "label": "5"
          }	
        ],
        "default": "3"
    },
    {
          "type": "checkbox",
          "id": "product_count",
          "default": true,
          "label": "Show product count"
        },
    {
      "type": "select",
      "id": "image_ratio",
