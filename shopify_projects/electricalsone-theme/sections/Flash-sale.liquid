{%- style -%}
  /* ===== Main Container ===== */
  .flash-sale-section {
    position: relative;
    width: 100%;
    max-width: 1634px;
    height: 510px;
    margin: 0 auto;
    padding: 20px 30px;
    box-sizing: border-box;
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    border-radius: 12px;
    overflow: hidden;
     
  }

 
  /* ===== Background ===== */
  .section-background img {
    width: 100%;
    height: 57%;
    object-fit: cover;
  }
  .section-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: {{ section.settings.background_opacity | divided_by: 100.0 }};
     
  }
  .section-background-link {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  display: block;
}

  /* ===== Content Structure ===== */
  .section-content {
    position: relative;
    z-index: 3;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* ===== Header Section ===== */
  .section-header {
    height: 490px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    
  }
  
  .heading-container {
    display: flex;
    flex-direction: column;
     
  }
 h2 .heading-container {
  text-align:center;
     
  }
  
  .section-heading {
    font-size: 28px;
    font-weight: 700;
    margin: 0;
    color: {{ section.settings.heading_color }};
    line-height: 1.2;
    white-space: nowrap;
   
  }

  /* ===== Countdown Timer ===== */
  .countdown-timer {
    display: flex;
    gap: 15px;
    align-items: center;
  }
  
  .timer-segment {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 50px;
  }
  
  .timer-value {
    font-size: 22px;
    font-weight: 700;
    background: {{ section.settings.timer_background }};
    color: {{ section.settings.timer_text_color }};
    padding: 4px 8px;
    border-radius: 6px;
    min-width: 36px;
    text-align: center;
    line-height: 1;
  }
  
  .timer-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 2px;
    color: {{ section.settings.timer_label_color }};
  }

  /* ===== Collection Slider ===== */
  .collections-slider {
    height: calc(100% - 100px);
    margin-top: 20px;
    position: relative;
    overflow: hidden;
  }
  
  .collections-track {
    display: flex;
    gap: 15px;
    height: 100%;
    transition: transform 0.5s ease;
  }

  /* ===== Collection Cards ===== */
  .collection-card {
    flex: 0 0 23%; /* 4 cards with gap */
    height: 198px;
    max-height: 240px;
    background: {{ section.settings.card_background }};
    border-radius: 6px;
    padding: 12px;
    display: flex;
    flex-direction: column;
    transition: all 0.3s ease;
    overflow: hidden;
    text-align: center;
  }
  
  .collection-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
  }
  
  .collection-image {
    width: 100%;
    height: 75%;
    max-height: 160px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
  }
  
  .collection-title {
    font-size: 14px;
    margin: 8px 0 0;
    color: {{ section.settings.card_text_color }};
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    height: 20px;
    line-height: 1.2;
  }

  /* ===== Slider Navigation ===== */
  .slider-nav {
    height: 20px;
    display: show;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
  }
  
  .slider-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: {{ section.settings.dot_color | color_modify: 'alpha', 0.3 }};
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .slider-dot.active {
    background: {{ section.settings.dot_color }};
    transform: scale(1.2);
  }

  /* ===== Responsive Adjustments ===== */
  @media (max-width: 1200px) {
    .collection-card {
      flex: 0 0 30%; /* 3 cards */
    }
    
    .section-heading {
      font-size: 24px;
    }
    
    .timer-value {
      font-size: 20px;
      min-width: 32px;
    }
  }

  @media (max-width: 768px) {
    .flash-sale-section {
      height: auto;
      min-height: 400px;
      padding: 20px;
    }
    
    .section-header {
      height: auto;
      flex-direction: column;
      align-items: center;
      gap: 15px;
    }
    
    .collections-slider {
      height: calc(100% - 150px);
    }
    
    .collection-card {
      flex: 0 0 45%; /* 2 cards */
      max-height: 220px;
    }
    
    .collection-image {
      height: 70%;
    }
    
    .section-heading {
      font-size: 22px;
      white-space: normal;
      text-align: center;
    }
    
    .timer-value {
      font-size: 18px;
      min-width: 28px;
    }
    
    .countdown-timer {
      margin-top: 15px;
    }
  }

  @media (max-width: 480px) {
    .flash-sale-section {
      padding: 15px;
      min-height: 380px;
    }
    
    .section-header {
      height: 176px;
    }
    
    .collection-card {
      flex: 0 0 90%; /* 1 card */
      max-height: 180px;
    }
    
    .collection-image {
      height: 65%;
    }
    .slider-dot {
      display:none;
    }
    .section-heading {
      font-size: 20px;
    }
    .section-background img {
    width: 150%;
    height: 40%;
    object-fit: cover;
   opacity: 100%;

  }
    
    .countdown-timer {
      gap: 6px;
    }
    
    .timer-segment {
      min-width: 40px;
    }
    
    .timer-value {
      font-size: 16px;
      min-width: 24px;
    }
    
    .timer-label {
      font-size: 8px;
    }
  }
{%- endstyle -%}

<div class="flash-sale-section">
  {% if section.settings.background_image != blank %}
    <a href="{{ section.settings.background_link }}" class="section-background-link">
      <div class="section-background">
        <img src="{{ section.settings.background_image | img_url: '2000x' }}" alt="" width="100%" height=57%>
      </div>
    </a>
  {% endif %}
  
  <div class="section-content">
    <div class="section-header">
      <div class="heading-container">
        {% if section.settings.label != blank %}
          <div class="section-label">{{ section.settings.label }}</div>
        {% endif %}
        
        {% if section.settings.heading != blank %}
          <h2 class="section-heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
      
      {% if section.settings.show_countdown %}
        <div class="countdown-timer" 
             data-end-date="{{ section.settings.end_date | date: '%Y-%m-%d %H:%M:%S' }}"
             data-days="{{ section.settings.show_days }}"
             data-hours="{{ section.settings.show_hours }}"
             data-minutes="{{ section.settings.show_minutes }}"
             data-seconds="{{ section.settings.show_seconds }}">
          {% if section.settings.show_days %}
            <div class="timer-segment">
              <div class="timer-value" id="days">00</div>
              <div class="timer-label">Days</div>
            </div>
          {% endif %}
          <div class="timer-segment">
            <div class="timer-value" id="hours">00</div>
            <div class="timer-label">Hours</div>
          </div>
          <div class="timer-segment">
            <div class="timer-value" id="minutes">00</div>
            <div class="timer-label">Minutes</div>
          </div>
          <div class="timer-segment">
            <div class="timer-value" id="seconds">00</div>
            <div class="timer-label">Seconds</div>
          </div>
        </div>
      {% endif %}
    </div>
    
    <div class="collections-slider">
      <div class="collections-track" id="collectionsTrack">
        {% for block in section.blocks %}
          {% if block.type == 'collection' and block.settings.collection != blank %}
            {% assign collection = block.settings.collection %}
            <div class="collection-card">
              <a href="{{ collection.url }}" class="collection-link">
                {% comment %} Use custom image if provided, otherwise fall back to collection image {% endcomment %}
                {% if block.settings.custom_image != blank %}
                  <img src="{{ block.settings.custom_image | img_url: '400x' }}" alt="{{ collection.title }}" class="collection-image" width="100%" height=75% >
                {% elsif collection.image != blank %}
                  <img src="{{ collection.image | img_url: '400x' }}" alt="{{ collection.title }}" class="collection-image" width="100%" height=75% >
                {% else %}
                  {{ 'collection-1' | placeholder_svg_tag: 'collection-image' }}
                {% endif %}
                <h3 class="collection-title">{{ collection.title }}</h3>
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      
      {% assign collection_count = section.blocks | where: "type", "collection" | size %}
      {% if collection_count > 1 %}
        <div class="slider-nav">
          {% for block in section.blocks %}
            {% if block.type == 'collection' %}
              <div class="slider-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}"></div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Collection Slider
  const sliderTrack = document.getElementById('collectionsTrack');
  if (sliderTrack) {
    const slides = sliderTrack.querySelectorAll('.collection-card');
    const dots = document.querySelectorAll('.slider-dot');
    let currentSlide = 0;
    let autoSlideInterval;
    const slideCount = slides.length;
    let touchStartX = 0;
    let touchEndX = 0;
    
    // Calculate visible slides based on screen width
    function getVisibleSlides() {
      if (window.innerWidth < 480) return 1;
      if (window.innerWidth < 768) return 2;
      if (window.innerWidth < 1024) return 3;
      return 4; // Default for desktop
    }
    
    function updateSlider() {
      const visibleSlides = getVisibleSlides();
      const slideWidth = slides[0].offsetWidth + 15; // Include gap
      const maxSlide = Math.max(0, slideCount - visibleSlides);
      
      // Ensure currentSlide stays within bounds
      currentSlide = Math.min(currentSlide, maxSlide);
      
      sliderTrack.style.transform = `translateX(-${currentSlide * slideWidth}px)`;
      
      // Update dots
      dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === currentSlide);
      });
    }
    
    // Navigation dots
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        currentSlide = parseInt(dot.dataset.index);
        updateSlider();
        resetAutoSlide();
      });
    });
    
    // Touch event handlers for mobile swipe
    sliderTrack.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, {passive: true});
    
    sliderTrack.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    }, {passive: true});
    
    function handleSwipe() {
      const swipeThreshold = 50; // Minimum swipe distance in pixels
      const visibleSlides = getVisibleSlides();
      const maxSlide = Math.max(0, slideCount - visibleSlides);
      
      if (touchStartX - touchEndX > swipeThreshold) {
        // Swipe left - next slide
        currentSlide = Math.min(currentSlide + 1, maxSlide);
      } else if (touchEndX - touchStartX > swipeThreshold) {
        // Swipe right - previous slide
        currentSlide = Math.max(currentSlide - 1, 0);
      }
      
      updateSlider();
      resetAutoSlide();
    }
    
    function startAutoSlide() {
      if (slideCount > getVisibleSlides() && {{ section.settings.auto_slide | default: true }}) {
        autoSlideInterval = setInterval(() => {
          const visibleSlides = getVisibleSlides();
          const maxSlide = Math.max(0, slideCount - visibleSlides);
          
          currentSlide = (currentSlide + 1) % (maxSlide + 1);
          updateSlider();
        }, {{ section.settings.slide_duration | default: 5 }}000);
      }
    }
    
    function resetAutoSlide() {
      clearInterval(autoSlideInterval);
      startAutoSlide();
    }
    
    // Handle window resize
    function handleResize() {
      currentSlide = 0;
      updateSlider();
      resetAutoSlide();
    }
    
    // Initialize
    updateSlider();
    startAutoSlide();
    
    // Add event listeners
    window.addEventListener('resize', handleResize);
    
    // Cleanup on unmount
    document.addEventListener('shopify:section:unload', function() {
      clearInterval(autoSlideInterval);
      window.removeEventListener('resize', handleResize);
      sliderTrack.removeEventListener('touchstart');
      sliderTrack.removeEventListener('touchend');
    });
  }

  // Countdown Timer
  const countdownTimer = document.querySelector('.countdown-timer');
  if (countdownTimer) {
    const endDate = new Date(countdownTimer.dataset.endDate).getTime();
    const showDays = countdownTimer.dataset.days === 'true';
    const showHours = countdownTimer.dataset.hours === 'true';
    const showMinutes = countdownTimer.dataset.minutes === 'true';
    const showSeconds = countdownTimer.dataset.seconds === 'true';
    
    function updateTimer() {
      const now = new Date().getTime();
      const distance = endDate - now;
      
      if (distance < 0) {
        clearInterval(timerInterval);
        countdownTimer.innerHTML = '<div class="timer-ended">' + {{ section.settings.expired_message | json }} + '</div>';
        return;
      }
      
      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);
      
      if (showDays) document.getElementById('days').textContent = days.toString().padStart(2, '0');
      if (showHours) document.getElementById('hours').textContent = hours.toString().padStart(2, '0');
      if (showMinutes) document.getElementById('minutes').textContent = minutes.toString().padStart(2, '0');
      if (showSeconds) document.getElementById('seconds').textContent = seconds.toString().padStart(2, '0');
    }
    
    updateTimer();
    const timerInterval = setInterval(updateTimer, 1000);
  }
});
  document.addEventListener('DOMContentLoaded', function() {
  // Get the background link element
  const backgroundLink = document.querySelector('.section-background-link');
  
  // Only proceed if the link element exists
  if (backgroundLink) {
    // Get the link URL from the section settings
    const linkUrl = backgroundLink.getAttribute('href');
    
    // If there's a valid URL, make the background clickable
    if (linkUrl && linkUrl !== '#') {
      // Make the entire section clickable
      const flashSaleSection = document.querySelector('.flash-sale-section');
      
      if (flashSaleSection) {
        // Change cursor to pointer when hovering over the section
        flashSaleSection.style.cursor = 'pointer';
        
        // Add click event listener to the entire section
        flashSaleSection.addEventListener('click', function(e) {
          // Don't trigger if clicking on interactive elements inside
          if (!e.target.closest('.collection-link') && 
              !e.target.closest('.countdown-timer') &&
              !e.target.closest('.slider-dot')) {
            window.location.href = linkUrl;
          }
        });
        
        // Visual feedback on hover
        flashSaleSection.addEventListener('mouseenter', function() {
          flashSaleSection.style.opacity = '0.95';
        });
        
        flashSaleSection.addEventListener('mouseleave', function() {
          flashSaleSection.style.opacity = '1';
        });
      }
    } else {
      // If no valid URL, remove the link wrapper
      backgroundLink.remove();
    }
  }
});
</script>

