        .map(word => word.toLowerCase());
    }

    function scoreProduct(product, keywords) {
      const title = product.querySelector('.product-title')?.textContent?.toLowerCase() || '';
      const handle = product.href.split('/products/')[1]?.toLowerCase() || '';
      
      if (handle.includes(keywords.join('-'))) return 100;
      if (keywords.every(kw => title.includes(kw))) return 90;
      
      const matchedKeywords = keywords.filter(kw => 
        title.includes(kw) || handle.includes(kw)
      ).length;
      return (matchedKeywords / keywords.length) * 80;
    }

    async function findBestRedirect() {
      const cleanPath = cleanWpmUrl(window.location.pathname);
      if (cleanPath !== window.location.pathname) {
        return cleanPath;
