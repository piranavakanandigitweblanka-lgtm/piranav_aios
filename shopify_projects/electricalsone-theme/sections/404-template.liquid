          score: scoreProduct(product, keywords)
        })).filter(p => p.score > 40);
        
        if (!scoredProducts.length) return '/search?q=' + keywords.join('+');
        
        scoredProducts.sort((a, b) => b.score - a.score);
        return scoredProducts[0].product.href;
        
