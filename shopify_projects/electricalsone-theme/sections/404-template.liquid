    // Rest of your existing functions remain exactly the same
    function extractCollectionName(url) {
      const match = url.match(/\/(collections?[s]*)\/([^\/]+)/i);
      if (!match) return null;
      return '/collections/' + match[2];
    }

    function extractKeywords(url) {
      const slug = url.split('/products/')[1]?.replace(/-\d+$/, '') || '';
      return slug.split('-')
