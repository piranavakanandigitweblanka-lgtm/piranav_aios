{% comment %}
  Collection Show
  A responsive grid of collection cards. Each card shows the collection's
  featured image as a background, the collection title, and a "VIEW ALL" button.
  Configure the collections from the theme editor.
{% endcomment %}

<style>
  .collection-show-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .collection-show-{{ section.id }} .collection-show__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .collection-show-{{ section.id }} .collection-show__heading {
    text-align: center;
    margin: 0 0 28px;
    font-size: 28px;
    font-weight: 700;
  }

  .collection-show-{{ section.id }} .collection-show__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.grid_gap }}px;
  }

  @media (min-width: 600px) {
    .collection-show-{{ section.id }} .collection-show__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .collection-show-{{ section.id }} .collection-show__grid {
      grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    }
  }

  .collection-show-{{ section.id }} .collection-card {
    position: relative;
    display: block;
    border-radius: {{ section.settings.corner_radius }}px;
    overflow: hidden;
    aspect-ratio: {{ section.settings.image_ratio }};
    text-decoration: none;
    color: #fff;
    background-color: #2b2b2b;
  }

  .collection-show-{{ section.id }} .collection-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .collection-show-{{ section.id }} .collection-card:hover .collection-card__image {
    transform: scale(1.05);
  }

  .collection-show-{{ section.id }} .collection-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.45) 100%);
  }

  .collection-show-{{ section.id }} .collection-card__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 22px;
    gap: 14px;
  }

  .collection-show-{{ section.id }} .collection-card__title {
    margin: 0;
     align-items: center;
    color:white;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-shadow: 0 1px 6px rgba(194, 181, 181, 0.4);
  }

  .collection-show-{{ section.id }} .collection-card__button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border: 1px solid rgba(255,255,255,0.85);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: transparent;
    transition: background 0.25s ease, color 0.25s ease;
  }

  .collection-show-{{ section.id }} .collection-card:hover .collection-card__button {
    background: #ffffff83;
    color: #111;
  }

  .collection-show-{{ section.id }} .collection-card__button svg {
    width: 14px;
    height: 14px;
  }
</style>

<div class="collection-show-{{ section.id }} collection-show">
  <div class="collection-show__inner">
    {% if section.settings.heading != blank %}
      <h2 class="collection-show__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="collection-show__grid">
      {% for block in section.blocks %}
        {%- liquid
          assign collection = collections[block.settings.collection]
          assign card_title = block.settings.title
          if card_title == blank and collection != blank
            assign card_title = collection.title
          endif
          assign card_url = block.settings.link
          if card_url == blank and collection != blank
            assign card_url = collection.url
          endif
          assign card_image = block.settings.image
          if card_image == blank and collection != blank
            assign card_image = collection.featured_image
          endif
        -%}

        <a
          href="{{ card_url | default: '#' }}"
          class="collection-card"
          {{ block.shopify_attributes }}
        >
          {% if card_image != blank %}
            <img
              src="{{ card_image | image_url: width: 800 }}"
              srcset="{{ card_image | image_url: width: 400 }} 400w, {{ card_image | image_url: width: 800 }} 800w, {{ card_image | image_url: width: 1200 }} 1200w"
              sizes="(min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw"
              alt="{{ card_title | escape }}"
              class="collection-card__image"
              loading="lazy"
            >
          {% endif %}

          <span class="collection-card__overlay"></span>

          <span class="collection-card__content">
            <h3 class="collection-card__title">{{ card_title | default: 'Collection' }}</h3>
            <span class="collection-card__button">
              {{ block.settings.button_text | default: 'View all' }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M10 8l4 4-4 4"></path>
              </svg>
            </span>
          </span>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Show",
  "tag": "section",
  "class": "section-collection-show",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "16/9", "label": "16:9" },
        { "value": "3/2", "label": "3:2" },
        { "value": "4/3", "label": "4:3" },
        { "value": "1/1", "label": "Square" }
      ],
      "default": "16/9"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title override",
          "info": "Defaults to the collection title."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override",
          "info": "Defaults to the collection's featured image."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link override",
          "info": "Defaults to the collection URL."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "View all"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Show",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
