            "label": "Heading"
          },
		  {
            "type": "text",
            "id": "subheading",
            "default": "subheading promotion",
            "label": "Subheading"
          },
		  {
            "type": "select",
            "id": "icon_type",
            "options": [
              {
                "value": "icon",
                "label": "Icon "
              },
              {
                "value": "image",
