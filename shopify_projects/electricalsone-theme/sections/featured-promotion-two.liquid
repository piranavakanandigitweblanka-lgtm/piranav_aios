            {
              "value": "background-2",
              "label": "t:sections.header.settings.color_scheme.options__4.label"
            },
            {
              "value": "inverse",
              "label": "t:sections.header.settings.color_scheme.options__5.label"
            }
          ],
          "default": "background-1",
          "label": "t:sections.header.settings.color_scheme.label"
