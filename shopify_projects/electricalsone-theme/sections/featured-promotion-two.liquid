{{ 'featured-promotion.css' | asset_url | stylesheet_tag }}


<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .section-{{ section.id }}-padding.shipping__style3{
    margin-bottom: -{{ section.settings.margin }}px;
  }
    
   
</style>

<div class="shipping__section2 section-{{ section.id }}-padding  shipping__style3">
  <div class="container">
    <div class="shipping__section2--inner shipping__style3--inner d-flex justify-content-between color-{{ section.settings.color_scheme }}">
      
      {%- for block in section.blocks -%}
      {%- case block.type -%}
      {%- when 'featured_promotion' -%}
      <div class="shipping__items2 d-flex align-items-center" {{ block.shopify_attributes }}>
        <div class="{% if block.settings.icon_type == "icon" %}shipping__items--icon {% else %} shipping__items2--icon {% endif %} mb-0">
          {%- if block.settings.icon_type == "icon" -%}
          {%- render 'icon-featured-promotion', icon: block.settings.icon -%}
          {%- else -%}
          {%- if block.settings.image -%}
          <img
               src="{{ block.settings.image | img_url: '50x' }}"
               alt="{{ block.settings.image.alt | escape }}"
               width="50"
               height="{{ 50 | divided_by: block.settings.image.aspect_ratio | ceil }}"
               loading="lazy"
               >
          {%- endif -%}
          {%- endif -%}
        </div>
        <div class="shipping__items2--content">
          <h2 class="shipping__items2--content__title h3">{{ block.settings.heading }}</h2>
          <p class="shipping__items2--content__desc">{{ block.settings.subheading }}</p>
        </div>
      </div>
      {%- endcase -%}
      {%- endfor -%}
      
    </div>
  </div>
</div>


{% schema %}
  {
    "name": "Featured promotion two",
    "settings": [
	   {
        "type": "header",
