{% schema %}
{
  "name": "Discount Popup",
  "settings": [
    {
      "type": "header",
      "content": "Popup Settings"
    },
    {
      "type": "checkbox",
      "id": "show_discount_popup",
      "label": "Enable Discount Popup",
      "default": true
    },
    {
      "type": "text",
      "id": "popup_title",
      "label": "Popup Title",
      "default": "Limited Time Offer!"
    },
    {
      "type": "richtext",
      "id": "popup_message",
      "label": "Popup Message",
      "default": "<p>Use this special code at checkout!</p>"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount Code",
      "default": "HOT10"
    },
    {
      "type": "image_picker",
      "id": "popup_image",
      "label": "Popup Image"
    },
    {
      "type": "url",
      "id": "popup_link",
      "label": "Image Link URL"
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link URL"
    },
    {
      "type": "header",
      "content": "Design Settings"
    },
    {
      "type": "color",
      "id": "popup_bg",
      "label": "Popup Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Discount Popup",
      "category": "Promotional"
    }
  ]
}
{% endschema %}

<style>
  .discount-popup {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .discount-popup.show {
    opacity: 1;
    visibility: visible;
  }

  .popup-content {
    position: relative;
    width: 370px; /* Fixed width */
    height: 366px; /* Fixed height */
    padding: 20px;
    border-radius: 25px;
    text-align: center;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
    animation: popupFadeIn 0.5s ease;
    overflow-y: auto; /* Add scroll if content overflows */
    box-sizing: border-box; /* Include padding in dimensions */
  }

  .popup-image {
    max-width: 100%;
    max-height: 150px; /* Limit image height */
    width: auto;
    margin-bottom: 5px;
    border-radius: 4px;
    object-fit: contain;
  }

  .popup-image-link {
    display: block;
    margin-bottom: 10px;
  }

  .popup-content h3 {
    margin-top: 0;
    margin-bottom: 4px;
    font-size: 20px;
    font-weight: 700;
  }

  .popup-content p {
    margin-bottom: -3px;
    font-size: 14px;
  }

  .discount-code {
    font-size: 16px;
    font-weight: bold;
    color: #e63946;
    background-color: #f8f9fa;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .popup-button {
    display: inline-block;
    padding: 10px 20px;
    margin: 15px 0;
    border-radius: 4px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    font-size: 14px;
  }

  .copy-code-wrapper {
    margin-top: -35px;
    font-size: 12px;
  }

  .close-popup {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 20px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  @keyframes popupFadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive adjustments */
  @media (max-width: 480px) {
    .popup-content {
      width: 90%;
      height: auto;
      max-height: 80vh;
    }
  }
</style>

{%- if section.settings.show_discount_popup -%}
<div id="discount-popup" class="discount-popup">
  <div class="popup-content" style="background: {{ section.settings.popup_bg }}; color: {{ section.settings.text_color }};">
    <span class="close-popup">&times;</span>
    
    {%- if section.settings.popup_image -%}
      <a href="{{ section.settings.popup_link }}" class="popup-image-link">
        <img src="{{ section.settings.popup_image | img_url: '370x' }}" alt="{{ section.settings.popup_title }}" class="popup-image">
      </a>
    {%- endif -%}
    
    <h3>{{ section.settings.popup_title }}</h3>
    <div style="max-height: 60px; overflow: hidden; margin-bottom: 10px;">
      {{ section.settings.popup_message }}
    </div>
    
    <p>Use code <strong class="discount-code">{{ section.settings.discount_code }}</strong></p>
    
    <a href="{{ section.settings.button_link }}" class="popup-button" style="background: {{ settings.color_button }}; color: {{ settings.color_button_text }};">
      {{ section.settings.button_text }}
    </a>
    
    <div class="copy-code-wrapper">
      <span>Your code: </span>
      <button class="copy-code" onclick="copyDiscountCode('{{ section.settings.discount_code }}')">
        {{ section.settings.discount_code }}
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const popup = document.getElementById('discount-popup');
    const closeBtn = document.querySelector('.close-popup');

    setTimeout(() => {
      popup.classList.add('show');
    }, 3000);

    closeBtn.addEventListener('click', () => {
      popup.classList.remove('show');
    });

    popup.addEventListener('click', (e) => {
      if (e.target === popup) {
        popup.classList.remove('show');
      }
    });
  });

  function copyDiscountCode(code) {
    navigator.clipboard.writeText(code).then(() => {
      const btn = document.querySelector('.copy-code');
      btn.textContent = 'Copied!';
      setTimeout(() => {
        btn.textContent = code;
      }, 2000);
    });
  }
</script>
{%- endif -%}